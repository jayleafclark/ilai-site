---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

export interface Props {
  title?: string;
  ogTitle?: string;
  description?: string;
  image?: string;
  path?: string;
  // Extra JSON-LD graph objects for a given page (FAQPage, BlogPosting,
  // BreadcrumbList, etc.). Each is emitted as its own ld+json block, on top of
  // the site-wide Organization node below.
  schemas?: Record<string, unknown>[];
}

const {
  title = "Ilai Collective · Content studio for experts and personal brands",
  ogTitle = title,
  description = "Your audience and voice, studied first. Then a month of content, created and published in your voice across every platform, with your community engaged. Made by real people. No AI slop.",
  image = "/og.png?v=3",
  path = "",
  schemas = [],
} = Astro.props;

const site = "https://ilaicollective.com";
// GitHub Pages serves directory URLs with a trailing slash and 301-redirects
// the slashless form, so canonical + og:url must use the trailing-slash form
// (the real 200 URL) to avoid Google crawling redirects.
const canonical =
  path && path !== "/" ? site + path.replace(/\/+$/, "") + "/" : site + "/";

// Site-wide identity node. Ilai is a US, human-led content studio for experts.
// ProfessionalService + Organization so both general and local/service search
// (and AI assistants) resolve the entity, its offer model, and how to reach it.
// sameAs is intentionally empty until real, owned social URLs are confirmed —
// do not invent profiles.
const orgLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "ProfessionalService"],
  "@id": site + "/#org",
  name: "Ilai Collective",
  url: site,
  description,
  slogan: "Proven to spread.",
  logo: site + "/logo-mark.png",
  image: site + "/og.png?v=3",
  email: "hello@ilaicollective.com",
  areaServed: { "@type": "Country", name: "United States" },
  address: { "@type": "PostalAddress", addressCountry: "US" },
  priceRange: "From $5,500/mo per service line",
  knowsAbout: [
    "Content strategy",
    "Podcast production",
    "Short-form video",
    "Social media marketing",
    "Community engagement",
    "Search engine optimization",
    "Generative engine optimization",
  ],
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "sales",
    email: "hello@ilaicollective.com",
    areaServed: "US",
    availableLanguage: "English",
  },
  makesOffer: [
    {
      "@type": "Offer",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        priceCurrency: "USD",
        price: 5500,
        minPrice: 5500,
        unitText: "MONTH",
      },
      itemOffered: {
        "@type": "Service",
        name: "Social content production",
        description:
          "Research, writing, editing, and multi-platform publishing of short-form and long-form content in your voice.",
      },
    },
    {
      "@type": "Offer",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        priceCurrency: "USD",
        price: 5500,
        minPrice: 5500,
        unitText: "MONTH",
      },
      itemOffered: {
        "@type": "Service",
        name: "Podcast production",
        description:
          "Full episode editing, clips and reels, long-form video, show notes, and SEO from a single recording cadence.",
      },
    },
    {
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: "Community engagement",
        description:
          "First-response community engagement in your voice, offered as an add-on to a production line.",
      },
    },
  ],
  sameAs: [],
};

const allSchemas = [orgLd, ...schemas];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Mark JS as active BEFORE first paint so the scroll-reveal hidden state
         (opacity:0) only applies when we can guarantee it gets animated back
         in. If this never runs, [data-reveal] content stays visible rather
         than stuck invisible. -->
    <script is:inline>document.documentElement.classList.add("reveal-js");</script>
    <!-- Neutralize any service worker + caches left by a previous site on this
         domain (e.g. the old Lovable app), so returning visitors always get the
         current site. The new site registers no service worker, so this is a
         one-way cleanup, safe to run on every load. -->
    <script is:inline>
      (function () {
        try {
          if (window.caches && caches.keys) {
            caches.keys().then(function (keys) {
              keys.forEach(function (k) { caches.delete(k); });
            }).catch(function () {});
          }
          if ("serviceWorker" in navigator) {
            var controlled = !!navigator.serviceWorker.controller;
            navigator.serviceWorker.getRegistrations().then(function (regs) {
              var had = regs.length > 0;
              regs.forEach(function (r) { r.unregister(); });
              // If an old service worker was serving this page from its cache,
              // unregistering alone won't refresh what's on screen. Reload once
              // (guarded, so it can never loop) to pull the live page.
              if ((had || controlled) && !sessionStorage.getItem("__sw_reset")) {
                sessionStorage.setItem("__sw_reset", "1");
                location.reload();
              }
            }).catch(function () {});
          }
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.png?v=4`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.png?v=4`} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={site + image} />
    <meta property="og:site_name" content="Ilai Collective" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={site + image} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {allSchemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Mobile-only: ensure anchored headings clear the fixed pill header
         (pill ~46px + top padding), so a jumped-to heading never lands
         beneath the opaque header. Desktop keeps the global 6rem. -->
    <style is:global>
      @media (max-width: 899px) {
        html {
          scroll-padding-top: 92px;
        }
      }
    </style>
  </head>
  <body>
    <a href="#main" class="sr-only">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Base-path aware: prefix root-relative in-site links with the build base
      // (no-op when deployed at the root domain).
      const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
      if (BASE) {
        document.querySelectorAll('a[href^="/"]').forEach((a) => {
          const h = a.getAttribute("href");
          if (h && !h.startsWith("//") && !h.startsWith(BASE + "/")) {
            a.setAttribute("href", BASE + h);
          }
        });
      }
    </script>

    <script>
      // Scroll-entrance reveals (transform/opacity only, respects reduced-motion)
      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      const revealEls = Array.from(document.querySelectorAll("[data-reveal]"));
      if (prefersReduced || !("IntersectionObserver" in window)) {
        revealEls.forEach((el) => el.classList.add("is-visible"));
      } else {
        const pending = new Set(revealEls);
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) reveal(entry.target);
            });
          },
          { threshold: 0, rootMargin: "0px 0px -5% 0px" },
        );
        function reveal(el) {
          el.classList.add("is-visible");
          pending.delete(el);
          io.unobserve(el);
        }
        revealEls.forEach((el) => io.observe(el));
        // Fail-safe: nothing may stay invisible. Reveal anything already within
        // the viewport (covers fast/fling scroll, anchor jumps, and any missed
        // observer callback) on load and on scroll — animation still plays on
        // entry for normal scrolling, but content can never get stuck at 0.
        const sweep = () => {
          if (!pending.size) {
            window.removeEventListener("scroll", onScroll);
            return;
          }
          [...pending].forEach((el) => {
            const r = el.getBoundingClientRect();
            // Reveal anything in the viewport OR already scrolled past above it
            // (r.top < innerHeight covers both). Catches fast/fling scrolls that
            // jump an element from below to above without a sweep landing on it.
            if (r.top < window.innerHeight) reveal(el);
          });
        };
        let ticking = false;
        let trailing;
        const onScroll = () => {
          if (!ticking) {
            ticking = true;
            requestAnimationFrame(() => {
              sweep();
              ticking = false;
            });
          }
          // Trailing sweep: guarantees the final resting viewport is revealed
          // even if the last scroll delta fell inside the rAF throttle window.
          clearTimeout(trailing);
          trailing = setTimeout(sweep, 140);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("scrollend", sweep, { passive: true });
        window.addEventListener("load", sweep, { once: true });
        sweep();
        // Re-sweep as layout settles: the first sweep can run before lazy
        // cover images load and push cards into view, leaving in-viewport
        // content stuck hidden until a scroll. These timed passes reveal
        // anything already on screen without needing the user to scroll.
        [120, 400, 1000, 2500].forEach((t) => setTimeout(sweep, t));
      }

      // Animated metric counters
      const counters = document.querySelectorAll<HTMLElement>("[data-count]");
      if (counters.length) {
        const format = (n: number, decimals: number) =>
          n.toLocaleString("en-US", {
            minimumFractionDigits: decimals,
            maximumFractionDigits: decimals,
          });
        const run = (el: HTMLElement) => {
          const target = parseFloat(el.dataset.count || "0");
          const decimals = parseInt(el.dataset.decimals || "0", 10);
          const prefix = el.dataset.prefix || "";
          const suffix = el.dataset.suffix || "";
          if (prefersReduced) {
            el.textContent = prefix + format(target, decimals) + suffix;
            return;
          }
          const dur = 1400;
          const start = performance.now();
          const tick = (now: number) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = prefix + format(target * eased, decimals) + suffix;
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        const cio = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                run(entry.target as HTMLElement);
                cio.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.5 },
        );
        counters.forEach((el) => cio.observe(el));
      }
    </script>
  </body>
</html>
