---
export interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: "left" | "center";
}
const { eyebrow, title, lead, align = "left" } = Astro.props;
---

<div class={`sechead sechead--${align}`} data-reveal>
  {eyebrow && <span class="eyebrow eyebrow--dot">{eyebrow}</span>}
  <h2 class="sechead__title">{title}</h2>
  {lead && <p class="lead sechead__lead">{lead}</p>}
</div>

<style>
  .sechead {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    max-width: 42ch;
  }
  .sechead--center {
    align-items: center;
    text-align: center;
    max-width: 56ch;
    margin-inline: auto;
  }
  .sechead__lead {
    margin-top: var(--sp-1);
  }
  .sechead--center .sechead__lead {
    max-width: 52ch;
  }
</style>
