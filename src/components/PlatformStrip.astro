---
// Real platform logos (simplified monochrome marks, currentColor).
export interface Props {
  label?: string;
}
const { label = "We create, publish, and grow audiences across" } = Astro.props;

const platforms = [
  { name: "YouTube", svg: `<path d="M23 7.5a3 3 0 00-2.1-2.1C19 5 12 5 12 5s-7 0-8.9.4A3 3 0 001 7.5 31 31 0 00.6 12 31 31 0 001 16.5a3 3 0 002.1 2.1C5 19 12 19 12 19s7 0 8.9-.4a3 3 0 002.1-2.1A31 31 0 0023.4 12 31 31 0 0023 7.5zM9.75 15.5v-7l6 3.5-6 3.5z"/>` },
  { name: "Instagram", svg: `<rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.9"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.9"/><circle cx="17.3" cy="6.7" r="1.2"/>` },
  { name: "TikTok", svg: `<path d="M15.5 3c.3 2.1 1.6 3.6 3.7 3.9v2.6c-1.3.1-2.5-.3-3.7-1v5.4a5.5 5.5 0 11-5.5-5.5c.3 0 .6 0 .9.1v2.7a2.8 2.8 0 102 2.7V3h2.6z"/>` },
  { name: "X", svg: `<path d="M17.5 3h3l-6.6 7.6L21.8 21h-6l-4.7-6.1L5.6 21H2.5l7.1-8.1L2.2 3h6.1l4.3 5.6L17.5 3zm-1 16h1.7L7.6 4.8H5.8L16.5 19z"/>` },
  { name: "Facebook", svg: `<path d="M22 12a10 10 0 10-11.6 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.2c-1.2 0-1.6.8-1.6 1.5V12h2.7l-.4 2.9h-2.3v7A10 10 0 0022 12z"/>` },
  { name: "Threads", svg: `<path fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" d="M12 21c-5 0-8-3.4-8-9s3-9 8-9c4 0 6.6 2.3 7.3 5.4M8.5 12.5c1-2 5.5-2.8 6.8-.3 1.5 2.8-1 5.3-3.3 4.8-1.7-.4-2-3.4.6-3.8 2.8-.4 5.4 1 5.4 4"/>` },
  { name: "Bluesky", svg: `<path d="M12 10.8C10.8 8.3 7.6 4.7 5.2 4.1 3 3.6 2 4.6 2 6.9c0 2 1.3 6.5 2.2 7.6.7.9 2 1 3.2.7-2.4.6-2.9 2.8-1.6 4.4C7 21 8.6 20 12 15.3c3.4 4.7 5 5.7 6.2 4.3 1.3-1.6.8-3.8-1.6-4.4 1.2.3 2.5.2 3.2-.7.9-1.1 2.2-5.6 2.2-7.6 0-2.3-1-3.3-3.2-2.8-2.4.6-5.6 4.2-6.8 6.7z"/>` },
  { name: "LinkedIn", svg: `<path d="M4.98 3.5a2.5 2.5 0 100 5 2.5 2.5 0 000-5zM3 9h4v12H3V9zm6 0h3.8v1.7h.05c.53-1 1.8-2 3.7-2 4 0 4.7 2.6 4.7 6V21h-4v-5.3c0-1.3 0-2.9-1.8-2.9s-2.05 1.4-2.05 2.8V21H9V9z"/>` },
  { name: "Substack", svg: `<path d="M4 3h16v2.6H4V3zm0 4.3h16V10H4V7.3zM4 11.6l8 4.5 8-4.5V21l-8-4.5L4 21v-9.4z"/>` },
];
---

<div class="pstrip">
  <p class="pstrip__label">{label}</p>
  <ul class="pstrip__row">
    {platforms.map((p) => (
      <li class="pstrip__item" title={p.name}>
        <svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24" aria-hidden="true" set:html={p.svg} />
        <span>{p.name}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .pstrip__label {
    text-align: center;
    font-family: var(--font-accent);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--muted);
  }
  .pstrip__row {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--sp-4) var(--sp-6);
    margin-top: var(--sp-5);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--line);
  }
  .pstrip__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    opacity: 0.5;
    transition:
      opacity var(--dur-base) var(--ease),
      color var(--dur-base) var(--ease);
  }
  .pstrip__item span {
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
  }
  .pstrip__item:hover {
    opacity: 1;
    color: var(--coral);
  }
  @media (max-width: 620px) {
    .pstrip__item span {
      display: none;
    }
    .pstrip__row {
      gap: var(--sp-5);
    }
  }
</style>
