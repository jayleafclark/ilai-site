---
import Logo from "./Logo.astro";

const links = [
  { href: "/what-we-do", label: "What we do" },
  { href: "/method", label: "How it works" },
  { href: "/work/dr-caroline-leaf", label: "Case study" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
];
---

<header class="nav" data-nav>
  <div class="nav__pill">
    <Logo />
    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <a href="/contact" class="btn btn--pink nav__cta">
      Book a call
      <span class="btn__arrow" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path
            d="M3 11L11 3M11 3H5M11 3V9"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </a>
    <button class="nav__burger" aria-label="Open menu" aria-expanded="false" data-burger>
      <span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" data-mobile>
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
    <a href="/contact" class="btn btn--pink nav__mobilecta">Book a call</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: clamp(0.75rem, 2vw, 1.25rem) var(--gutter);
    pointer-events: none;
  }
  .nav__pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    width: 100%;
    max-width: var(--maxw);
    padding: 9px 9px 9px 20px;
    border-radius: var(--r-pill);
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    transition:
      transform var(--dur-base) var(--ease),
      box-shadow var(--dur-base) var(--ease);
  }
  .nav__links {
    display: none;
    align-items: center;
    gap: clamp(1.1rem, 2.2vw, 1.9rem);
    margin-left: auto;
    font-size: 1.02rem;
    font-weight: 500;
  }
  .nav__links a {
    position: relative;
    color: var(--ink-2);
    padding-bottom: 2px;
    transition:
      color var(--dur-micro) var(--ease),
      transform var(--dur-base) var(--ease);
  }
  /* animated underline that grows from the left on hover */
  .nav__links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -2px;
    height: 2px;
    width: 100%;
    border-radius: 2px;
    background: var(--pink);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .nav__links a:hover {
    color: var(--ink);
    transform: translateY(-1px);
  }
  .nav__links a:hover::after {
    transform: scaleX(1);
  }
  .nav__cta {
    display: none;
    padding: 10px 10px 10px 18px;
  }
  .nav__cta .btn__arrow {
    width: 26px;
    height: 26px;
  }

  .nav__burger {
    margin-left: auto;
    display: grid;
    gap: 5px;
    width: 46px;
    height: 46px;
    place-content: center;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--line);
    cursor: pointer;
  }
  .nav__burger span {
    display: block;
    width: 18px;
    height: 1.8px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform var(--dur-base) var(--ease);
  }
  .nav__burger[aria-expanded="true"] span:first-child {
    transform: translateY(3.4px) rotate(45deg);
  }
  .nav__burger[aria-expanded="true"] span:last-child {
    transform: translateY(-3.4px) rotate(-45deg);
  }

  .nav__mobile {
    pointer-events: auto;
    display: none;
    flex-direction: column;
    gap: var(--sp-3);
    width: 100%;
    max-width: var(--maxw);
    margin-top: var(--sp-2);
    padding: var(--sp-5);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-float);
  }
  .nav__mobile a:not(.btn) {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: var(--sp-3) 0;
    font-size: 1.12rem;
    font-weight: 500;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
  }
  /* drop the divider on the last plain link (the one directly before the CTA) */
  .nav__mobile a:not(.btn):has(+ .btn) {
    border-bottom: 0;
  }
  .nav__mobile .btn {
    margin-top: var(--sp-3);
    padding-block: 15px;
    justify-content: center;
    font-size: 1.02rem;
  }

  .nav__mobile.is-open {
    display: flex;
  }

  /* --- Mobile (phones): give the pill a solid, opaque backdrop so page
     text can never bleed through or sit legibly under the fixed header.
     The translucent blur look is kept for desktop only. --- */
  @media (max-width: 899px) {
    /* Frost the whole fixed band (not just the pill) so content scrolling
       through the top strip + side gutters is obscured, never sliced/bleeding. */
    .nav {
      background: rgba(241, 243, 238, 0.72);
      backdrop-filter: saturate(140%) blur(12px);
      -webkit-backdrop-filter: saturate(140%) blur(12px);
    }
    .nav__pill {
      /* Near-solid powder-white; opacity high enough that scrolled body
         text behind it reads as a clean surface, not a see-through panel. */
      background: #f7f9f4;
      backdrop-filter: saturate(160%) blur(20px);
      -webkit-backdrop-filter: saturate(160%) blur(20px);
      box-shadow: var(--shadow-float);
    }
    /* Match the open panel to the pill so the whole header reads as one
       opaque surface when the menu is down. */
    .nav__mobile {
      background: #f7f9f4;
    }
  }

  @media (min-width: 900px) {
    .nav__links,
    .nav__cta {
      display: flex;
    }
    .nav__burger {
      display: none;
    }
    .nav__mobile {
      display: none !important;
    }
  }
</style>

<script>
  const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
  const mobile = document.querySelector<HTMLElement>("[data-mobile]");
  const setMenu = (open: boolean) => {
    burger?.setAttribute("aria-expanded", String(open));
    burger?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    mobile?.classList.toggle("is-open", open);
    // lock page scroll while the panel is open so it can't drift underneath
    document.body.style.overflow = open ? "hidden" : "";
  };
  burger?.addEventListener("click", () => {
    setMenu(burger.getAttribute("aria-expanded") !== "true");
  });
  // close on link tap and on Escape
  mobile?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => setMenu(false)),
  );
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setMenu(false);
  });

  // Subtle lift on scroll
  const nav = document.querySelector<HTMLElement>("[data-nav] .nav__pill");
  const onScroll = () => {
    if (!nav) return;
    nav.style.boxShadow =
      window.scrollY > 12 ? "var(--shadow-float)" : "var(--shadow-card)";
  };
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
