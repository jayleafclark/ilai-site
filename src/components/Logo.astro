---
// Ilai three-leaf sprout mark (recreated from the supplied brand logo) + wordmark.
// Two broad forest-green side leaves + a narrow upright powder-pink centre leaf.
export interface Props {
  variant?: "ink" | "light";
}
const { variant = "ink" } = Astro.props;
const wordColor = variant === "light" ? "#ffffff" : "var(--ink)";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const src = `${base}/${variant === "light" ? "logo-mark-light.png" : "logo-mark.png"}`;
---

<a href="/" class="logo" aria-label="Ilai Collective home">
  <span class="logo__markwrap">
    <img class="logo__mark" src={src} width="38" height="29" alt="" aria-hidden="true" />
  </span>
  <span class="logo__word" style={`color:${wordColor}`}>ilai</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
  }
  .logo__markwrap {
    position: relative;
    display: grid;
    place-items: center;
  }
  /* very soft breathing glow behind the mark */
  .logo__markwrap::before {
    content: "";
    position: absolute;
    inset: -55%;
    z-index: 0;
    border-radius: 50%;
    background: radial-gradient(
      closest-side,
      color-mix(in srgb, var(--pink) 55%, transparent),
      color-mix(in srgb, var(--coral) 22%, transparent) 55%,
      transparent 75%
    );
    filter: blur(6px);
    opacity: 0.55;
    animation: logoGlow 4.5s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes logoGlow {
    0%, 100% { opacity: 0.4; transform: scale(0.94); }
    50% { opacity: 0.7; transform: scale(1.06); }
  }
  .logo__mark {
    position: relative;
    z-index: 1;
    height: 29px;
    width: auto;
    display: block;
    transition: transform var(--dur-base) var(--ease);
  }
  .logo:hover .logo__mark {
    transform: translateY(-2px) scale(1.05);
  }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    letter-spacing: -0.03em;
  }
  @media (prefers-reduced-motion: reduce) {
    .logo__markwrap::before { animation: none; }
  }
</style>
