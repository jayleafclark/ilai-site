---
// Ilai wordmark + three-leaf sprout mark.
export interface Props {
  variant?: "ink" | "light";
}
const { variant = "ink" } = Astro.props;
const wordColor = variant === "light" ? "#ffffff" : "var(--ink)";
const markColor = variant === "light" ? "#ffffff" : "var(--coral)";
---

<a href="/" class="logo" aria-label="Ilai Collective home">
  <svg class="logo__mark" width="26" height="24" viewBox="0 0 24 24" aria-hidden="true">
    <g fill={markColor}>
      <path d="M12 16.5C10.4 12.8 10.4 7.6 12 3.5C13.6 7.6 13.6 12.8 12 16.5Z" />
      <path d="M12 16.8C14 12.9 17.7 9.4 21.4 8.2C21 12.4 17.6 16 12 16.8Z" />
      <path d="M12 16.8C10 12.9 6.3 9.4 2.6 8.2C3 12.4 6.4 16 12 16.8Z" />
    </g>
  </svg>
  <span class="logo__word" style={`color:${wordColor}`}>ilai</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--ink);
  }
  .logo__mark {
    transition: transform var(--dur-base) var(--ease);
  }
  .logo:hover .logo__mark {
    transform: translateY(-2px) scale(1.04);
  }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    letter-spacing: -0.03em;
  }
</style>
