---
// Ilai three-leaf sprout mark (matches supplied logo) + wordmark.
// Broad side leaves + narrow upright center leaf. Center leaf is power-pink.
export interface Props {
  variant?: "ink" | "light";
}
const { variant = "ink" } = Astro.props;
const wordColor = variant === "light" ? "#ffffff" : "var(--ink)";
const leafColor = variant === "light" ? "#ffffff" : "var(--coral)";
// Broad side leaf: base at local origin (0,0), tip pointing up.
const sideLeaf = "M0 -12 C 4.4 -7 4.4 -2 0 0 C -4.4 -2 -4.4 -7 0 -12 Z";
// Narrow upright center leaf.
const centerLeaf = "M12 5.6 C 13.5 9.2 13.5 13.4 12 16.8 C 10.5 13.4 10.5 9.2 12 5.6 Z";
---

<a href="/" class="logo" aria-label="Ilai Collective home">
  <svg class="logo__mark" width="30" height="28" viewBox="0 0 24 24" aria-hidden="true">
    <path d={sideLeaf} transform="translate(12 17.2) rotate(-40)" fill={leafColor} />
    <path d={sideLeaf} transform="translate(12 17.2) rotate(40)" fill={leafColor} />
    <path d={centerLeaf} fill="var(--pink)" />
  </svg>
  <span class="logo__word" style={`color:${wordColor}`}>ilai</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--ink);
  }
  .logo__mark {
    transition: transform var(--dur-base) var(--ease);
  }
  .logo:hover .logo__mark {
    transform: translateY(-2px) scale(1.04);
  }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    letter-spacing: -0.03em;
  }
</style>
