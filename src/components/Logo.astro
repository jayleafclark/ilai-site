---
// Ilai wordmark + 8-point compass-star mark.
export interface Props {
  variant?: "ink" | "light";
}
const { variant = "ink" } = Astro.props;
const wordColor = variant === "light" ? "#ffffff" : "var(--ink)";
const starColor = variant === "light" ? "var(--gold)" : "var(--coral)";
---

<a href="/" class="logo" aria-label="Ilai Collective home">
  <svg class="logo__mark" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M12 1 L13 9.6 L16.1 7.9 L14.4 11 L23 12 L14.4 13 L16.1 16.1 L13 14.4 L12 23 L11 14.4 L7.9 16.1 L9.6 13 L1 12 L9.6 11 L7.9 7.9 L11 9.6 Z"
      fill={starColor}
    ></path>
  </svg>
  <span class="logo__word" style={`color:${wordColor}`}>ilai</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
  }
  .logo__mark {
    transition: transform var(--dur-base) var(--ease);
  }
  .logo:hover .logo__mark {
    transform: rotate(45deg);
  }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: -0.03em;
  }
</style>
