---
// Ilai wordmark (text only for now; logo mark TBD).
export interface Props {
  variant?: "ink" | "light";
}
const { variant = "ink" } = Astro.props;
const wordColor = variant === "light" ? "#ffffff" : "var(--ink)";
---

<a href="/" class="logo" aria-label="Ilai Collective home">
  <span class="logo__word" style={`color:${wordColor}`}>ilai</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
  }
  .logo__word {
    font-weight: 800;
    font-size: 1.4rem;
    letter-spacing: -0.045em;
  }
</style>
