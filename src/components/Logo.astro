---
// Ilai wordmark + three-leaf sprout mark (matches the supplied logo).
export interface Props {
  variant?: "ink" | "light";
}
const { variant = "ink" } = Astro.props;
const wordColor = variant === "light" ? "#ffffff" : "var(--ink)";
const markColor = variant === "light" ? "#ffffff" : "var(--coral)";
// One slender leaf, pointed at both ends, base at local origin (0,0), tip up.
const leaf =
  "M0 -11.5 C 1.9 -7.5 1.9 -3.2 0 0 C -1.9 -3.2 -1.9 -7.5 0 -11.5 Z";
---

<a href="/" class="logo" aria-label="Ilai Collective home">
  <svg class="logo__mark" width="30" height="28" viewBox="0 0 24 24" aria-hidden="true">
    <g fill={markColor}>
      <path d={leaf} transform="translate(12 20) rotate(-56) scale(1.05)" />
      <path d={leaf} transform="translate(12 20) scale(0.78)" />
      <path d={leaf} transform="translate(12 20) rotate(56) scale(1.05)" />
    </g>
  </svg>
  <span class="logo__word" style={`color:${wordColor}`}>ilai</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--ink);
  }
  .logo__mark {
    transition: transform var(--dur-base) var(--ease);
  }
  .logo:hover .logo__mark {
    transform: translateY(-2px) scale(1.04);
  }
  .logo__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.7rem;
    letter-spacing: -0.03em;
  }
</style>
