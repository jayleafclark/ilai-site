---
import Layout from "../layouts/Layout.astro";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const budgets = [
  "Under $3k",
  "$3k–$5k",
  "$5.5k–$10k",
  "$10k+",
  "Not sure yet",
];

const steps = [
  {
    n: "01",
    t: "We research you before we meet",
    d: "We study your brand, your market, and the people you sell to, so we come to the call already knowing your audience.",
    c: "var(--coral)",
    icon: `<circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.6"/><path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="9" cy="9" r="2" fill="currentColor"/>`,
  },
  {
    n: "02",
    t: "We show you what we found",
    d: "On the call we walk you through the teardown and where your audience is, platform by platform, and what we'd post first.",
    c: "var(--brand)",
    icon: `<path d="M4 15.5V9M9.5 15.5V4.5M15 15.5v-4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/><path d="M3 17.5h13.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>`,
  },
  {
    n: "03",
    t: "If it's a fit, we build month one",
    d: "We set your voice, build the content system, and start publishing. You approve everything before it ships.",
    c: "var(--green)",
    icon: `<path d="M3.5 11L19 4l-6 15-2.5-6-7-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
];

// The free teardown preview: a small checklist mock for visual interest.
const teardown = [
  "Audience map, platform by platform",
  "Where the attention already is",
  "The first month of posts, outlined",
  "A voice and look built for you",
];

// Starts-at rows. Numeric ones animate with the shared counter.
const pricing = [
  { k: "Teardown", free: true, note: "yours to keep" },
  { k: "Pilot month", value: 1950, prefix: "$", note: "fully credited" },
  { k: "Engagements", value: 5500, prefix: "from $", suffix: "/mo", note: "" },
];
---

<Layout
  title="Get your free teardown | Ilai Collective"
  description="Get a free teardown of your brand, market, and audience from Ilai Collective, a real US team building human-led content that grows the audience you'll sell to. Pilot month $1,950 fully credited, engagements from $5,500/mo."
  path="/contact"
>
  <section class="contact section">
    <div class="container contact__grid">
      <!-- ============ LEFT: THE FORM ============ -->
      <div class="form-col" data-reveal>
        <span class="eyebrow eyebrow--pill">Start with a free teardown</span>
        <h1 class="form-col__title">Get your free <br />teardown.</h1>
        <p class="lead form-col__lead">
          We research your brand, market, and audience and show you where the attention is. It
          is free, and yours to keep whether or not we work together. We take a handful of
          clients at a time to keep the work senior and hands-on, so tell us about your work and
          we'll start there.
        </p>

        <div class="formcard">
          <span class="formcard__glow" aria-hidden="true"></span>
          <div class="formcard__head">
            <span class="formcard__ico" aria-hidden="true" style="--ic:var(--coral)">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <path d="M4 6.5h14v10H4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M4.5 7l6.5 5 6.5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <p class="formcard__t">A handful of clients at a time</p>
              <p class="formcard__s">We keep the roster small so the work stays senior and hands-on.</p>
            </div>
          </div>

          <div class="capacity">
            <p class="capacity__p">
              Leave a few details and we'll send a free teardown of your brand, market, and
              audience, yours to keep whether or not we work together. If a spot is open, we'll
              map out your pilot month.
            </p>

            <form
              class="lead-form"
              data-lead-form
              data-endpoint="https://api.web3forms.com/submit"
              data-access-key="YOUR_WEB3FORMS_ACCESS_KEY"
              novalidate
            >
              <!-- Honeypot: hidden from people, tempting to bots -->
              <input
                type="text"
                name="company"
                class="hp"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />
              <div class="field">
                <label for="lf-name">Your name</label>
                <input id="lf-name" type="text" name="name" required autocomplete="name" placeholder="Jane Doe" />
              </div>
              <div class="field">
                <label for="lf-email">Email</label>
                <input id="lf-email" type="email" name="email" required autocomplete="email" placeholder="you@yourbrand.com" />
              </div>
              <div class="field">
                <label for="lf-about">About your work</label>
                <textarea id="lf-about" name="about" rows="3" required placeholder="What you do, who you sell to, and where you want to grow."></textarea>
              </div>
              <div class="field">
                <label for="lf-budget">Monthly budget <span class="field__opt">(optional)</span></label>
                <div class="select-wrap">
                  <select id="lf-budget" name="budget">
                    <option value="">Prefer not to say</option>
                    {budgets.map((b) => <option value={b}>{b}</option>)}
                  </select>
                  <span class="select-caret" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3.5 5l3.5 3.5L10.5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </div>
              <button type="submit" class="btn btn--pink lead-form__submit">
                <span class="lead-form__submit-lab">Get your free teardown</span>
                <span class="btn__arrow" aria-hidden="true" set:html={arrow} />
              </button>
              <p class="lead-form__status" data-form-status role="status" aria-live="polite" hidden></p>
              <p class="lead-form__mail">
                Prefer email? <a href="mailto:hello@ilaicollective.com">hello@ilaicollective.com</a>
              </p>
            </form>

            <div class="lead-done" data-lead-done hidden>
              <span class="lead-done__mark" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M5 11.5l4 4 8-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <div>
                <p class="lead-done__t">Got it. We're on it.</p>
                <p class="lead-done__s">We'll be in touch within one business day with your free teardown. If a spot is open, we'll include next steps.</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ============ RIGHT: REASSURANCE ============ -->
      <aside class="side-col">
        <!-- Vibrant numbered stepper -->
        <div class="next" data-reveal data-reveal-delay="1">
          <span class="eyebrow eyebrow--dot">What happens next</span>
          <ol class="steps">
            {
              steps.map((s, i) => (
                <li class="step" data-reveal data-reveal-delay={String(i + 1)}>
                  <span class="step__ico" aria-hidden="true" style={`--ic:${s.c}`}>
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" set:html={s.icon} />
                    <span class="step__n">{s.n}</span>
                  </span>
                  <div class="step__body">
                    <h3 class="step__t">{s.t}</h3>
                    <p class="step__d muted">{s.d}</p>
                  </div>
                </li>
              ))
            }
          </ol>
        </div>

        <!-- Teardown preview mini-mock (glass over dark) -->
        <div class="preview" data-reveal data-reveal-delay="2" aria-hidden="true">
          <span class="preview__glow"></span>
          <div class="preview__bar">
            <span class="preview__dot"></span>
            <span class="preview__dot"></span>
            <span class="preview__dot"></span>
            <span class="preview__url">your free teardown</span>
          </div>
          <div class="preview__body glass">
            <span class="preview__label">Included in your teardown</span>
            <ul class="checklist">
              {
                teardown.map((t) => (
                  <li class="checklist__item">
                    <span class="checklist__mark">
                      <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
                        <path d="M3 7.2l2.6 2.6L11 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <span>{t}</span>
                  </li>
                ))
              }
            </ul>
            <div class="preview__foot">
              <span class="preview__cost">Cost</span>
              <span class="preview__free">Free</span>
            </div>
          </div>
        </div>

        <!-- Starts-at pricing card, with animated counters -->
        <div class="starts" data-reveal data-reveal-delay="2">
          <span class="starts__label">Starts at</span>
          <ul class="starts__list">
            {
              pricing.map((p) => (
                <li class="starts__row">
                  <span class="starts__k">{p.k}</span>
                  {p.free ? (
                    <span class="starts__v">
                      <span class="starts__v--free">Free</span>
                      {p.note && <span class="starts__note"> {p.note}</span>}
                    </span>
                  ) : (
                    <span class="starts__v">
                      <span
                        data-count={p.value}
                        data-decimals="0"
                        data-prefix={p.prefix ?? ""}
                        data-suffix={p.suffix ?? ""}
                      >
                        {(p.prefix ?? "") + p.value.toLocaleString("en-US") + (p.suffix ?? "")}
                      </span>
                      {p.note && <span class="starts__note"> {p.note}</span>}
                    </span>
                  )}
                </li>
              ))
            }
          </ul>
          <div class="starts__scale" aria-hidden="true">
            <div class="starts__track">
              <span class="starts__seg starts__seg--free" style="--w:35%;background:var(--green)"></span>
              <span class="starts__seg starts__seg--pilot" style="--w:35%;background:var(--brand)"></span>
              <span class="starts__seg starts__seg--ongoing" style="--w:100%;background:var(--coral)"></span>
            </div>
            <div class="starts__ticks">
              <span class="starts__tick"><b style="color:var(--green)">Free</b> Teardown</span>
              <span class="starts__tick"><b style="color:var(--brand)">$1,950</b> Pilot</span>
              <span class="starts__tick"><b style="color:var(--coral)">from $5,500/mo</b> Ongoing</span>
            </div>
          </div>
          <p class="starts__hint">The pilot is credited back in full when you continue.</p>
        </div>

        <!-- Trust card -->
        <div class="trustcard" data-reveal data-reveal-delay="3">
          <span class="trustcard__ico" aria-hidden="true" style="--ic:var(--plum)">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 2l6 2.5v5c0 4-2.7 6.3-6 7.5-3.3-1.2-6-3.5-6-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              <path d="M7.2 10l2 2 3.6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <p class="trustcard__text">
            A real US team, led by people and grounded in research. You see and
            approve everything before it ships.
          </p>
        </div>

      </aside>
    </div>
  </section>

  <!-- ============ REASSURANCE FOOTER BAND ============ -->
  <section class="reassure section--mist">
    <div class="container reassure__inner" data-reveal>
      <div class="reassure__copy">
        <span class="eyebrow eyebrow--star">Why it's worth the call</span>
        <p class="reassure__line">
          We build the audience you'll sell to, track the interest and intent it
          creates, and hand off at your funnel so your team can close.
        </p>
        <a href="/work/dr-caroline-leaf" class="reassure__link">
          See the results
          <span class="btn__arrow reassure__arrow" aria-hidden="true" set:html={arrow} />
        </a>
      </div>
      <div class="reassure__stat" aria-hidden="true">
        <span
          class="reassure__num"
          data-count="100"
          data-decimals="0"
          data-suffix="%"
        >100%</span>
        <span class="reassure__lab">human-led, human-gated.</span>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- Layout ---------- */
  .contact {
    padding-top: clamp(7rem, 14vh, 10rem);
    position: relative;
    overflow: hidden;
  }
  /* Soft ambient wash behind the whole section for depth */
  .contact::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(46% 40% at 88% 4%, rgba(28, 107, 74, 0.1), transparent 60%),
      radial-gradient(40% 34% at 4% 30%, rgba(230, 169, 196, 0.08), transparent 62%);
    pointer-events: none;
  }
  .contact__grid {
    display: grid;
    gap: var(--sp-8);
    align-items: start;
  }
  @media (min-width: 920px) {
    .contact__grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--sp-12);
    }
  }

  /* ---------- Left column head ---------- */
  .form-col__title {
    margin-top: var(--sp-5);
    font-size: var(--fs-h1);
  }
  .form-col__lead {
    margin-top: var(--sp-4);
    max-width: 46ch;
  }

  /* ---------- Form card ---------- */
  .formcard {
    position: relative;
    margin-top: var(--sp-6);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-card-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }
  .formcard__glow {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 60%;
    height: 80%;
    background: radial-gradient(circle, rgba(28, 107, 74, 0.14), transparent 70%);
    pointer-events: none;
  }
  .formcard__head {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding-bottom: var(--sp-5);
    margin-bottom: var(--sp-5);
    border-bottom: 1px solid var(--line);
  }
  .formcard__ico {
    flex: none;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.5),
      0 10px 20px -8px var(--ic);
  }
  .formcard__ico svg { stroke-width: 1.7; }
  .formcard__t {
    font-weight: 700;
    font-size: var(--fs-body);
    letter-spacing: -0.01em;
  }
  .formcard__s {
    margin-top: 2px;
    font-size: var(--fs-sm);
    color: var(--muted);
  }

  /* ---------- Capacity / waitlist ---------- */
  .capacity {
    position: relative;
    display: grid;
    gap: var(--sp-5);
    justify-items: start;
  }
  .capacity__p {
    font-size: var(--fs-body);
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 46ch;
  }
  .capacity__cta { margin-top: var(--sp-1); }

  /* ---------- Form ---------- */
  .lead-form {
    position: relative;
    display: grid;
    gap: var(--sp-5);
  }
  .field {
    display: grid;
    gap: var(--sp-2);
  }
  .field label {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--ink);
  }
  .field__opt {
    font-weight: 500;
    color: var(--muted);
    font-size: 0.8125rem;
  }
  .lead-form input,
  .lead-form textarea,
  .lead-form select {
    width: 100%;
    padding: 13px 15px;
    background: var(--canvas);
    border: 1px solid var(--line);
    border-radius: var(--r-input);
    font-size: var(--fs-body);
    color: var(--ink);
    transition:
      border-color var(--dur-micro) var(--ease),
      box-shadow var(--dur-micro) var(--ease),
      background var(--dur-micro) var(--ease);
  }
  .lead-form input::placeholder,
  .lead-form textarea::placeholder {
    color: var(--muted);
  }
  .lead-form input:hover,
  .lead-form textarea:hover,
  .lead-form select:hover {
    border-color: var(--line-2);
  }
  .lead-form input:focus,
  .lead-form textarea:focus,
  .lead-form select:focus {
    outline: none;
    border-color: var(--signal);
    background: var(--paper);
    box-shadow: 0 0 0 3px var(--signal-tint);
  }
  .lead-form textarea {
    resize: vertical;
    min-height: 3.5rem;
    line-height: 1.5;
  }

  /* Select with custom caret */
  .select-wrap {
    position: relative;
  }
  .select-wrap select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 42px;
    cursor: pointer;
  }
  .select-caret {
    position: absolute;
    top: 50%;
    right: 14px;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    color: var(--muted);
    pointer-events: none;
  }

  /* Honeypot: visually hidden but reachable for bots */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .lead-form__submit {
    margin-top: var(--sp-2);
    justify-self: start;
  }
  .lead-form__fine {
    font-size: var(--fs-sm);
    color: var(--muted);
    max-width: 44ch;
  }
  .lead-form__mail {
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .lead-form__mail a {
    color: var(--signal);
    font-weight: 600;
  }
  .lead-form__mail a:hover {
    color: var(--signal-hover);
  }
  /* [hidden] must win over the display rules below when JS toggles them. */
  .lead-form[hidden],
  .lead-done[hidden] {
    display: none !important;
  }
  .lead-form__submit[disabled] {
    opacity: 0.6;
    pointer-events: none;
  }
  .lead-form__status {
    font-size: var(--fs-sm);
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
  }
  /* Success state, replaces the form on submit */
  .lead-done {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
    padding: var(--sp-5);
    border-radius: var(--r-input);
    background: var(--signal-tint, rgba(28, 107, 74, 0.08));
    border: 1px solid var(--line);
  }
  .lead-done__mark {
    flex: none;
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--green, #1c6b4a);
    color: #fff;
  }
  .lead-done__t {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--ink);
    margin: 0 0 4px;
  }
  .lead-done__s {
    font-size: var(--fs-sm);
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 44ch;
  }

  /* ---------- Right column ---------- */
  .side-col {
    position: sticky;
    top: 6.5rem;
    display: grid;
    gap: var(--sp-5);
  }
  @media (max-width: 919px) {
    .side-col {
      position: static;
    }
  }

  /* Stepper card */
  .next {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    background: var(--mist);
    border: 1px solid var(--line);
    border-radius: var(--r-card-lg);
  }
  .steps {
    list-style: none;
    margin-top: var(--sp-5);
    display: grid;
    gap: var(--sp-5);
    position: relative;
  }
  /* connecting line down the icon column */
  .steps::before {
    content: "";
    position: absolute;
    left: 22px;
    top: 30px;
    bottom: 22px;
    width: 2px;
    background: linear-gradient(
      var(--coral),
      var(--brand),
      var(--green)
    );
    opacity: 0.28;
    border-radius: 2px;
  }
  .step {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
  }
  .step__ico {
    position: relative;
    flex: none;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.5),
      0 10px 20px -8px var(--ic);
  }
  .step__ico svg { stroke-width: 1.7; }
  .step__n {
    position: absolute;
    top: -7px;
    right: -7px;
    display: grid;
    place-items: center;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    border-radius: 999px;
    background: var(--paper);
    border: 1px solid var(--line);
    color: var(--ink);
    font-family: var(--font-accent);
    font-size: 0.66rem;
    font-weight: 700;
    box-shadow: 0 4px 10px -6px rgba(29, 42, 35, 0.4);
  }
  .step__body {
    padding-top: 2px;
  }
  .step__t {
    font-size: var(--fs-body);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .step__d {
    margin-top: var(--sp-1);
    font-size: var(--fs-sm);
  }

  /* Teardown preview mini-mock */
  .preview {
    position: relative;
    border-radius: var(--r-card-lg);
    padding: clamp(1rem, 2.4vw, 1.5rem);
    background:
      radial-gradient(80% 120% at 85% 8%, rgba(230, 169, 196, 0.3), transparent 60%),
      linear-gradient(150deg, var(--charcoal), var(--charcoal-2) 60%, var(--charcoal-3));
    box-shadow: var(--shadow-float);
    overflow: hidden;
  }
  .preview__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 60% at 12% 92%, rgba(79, 164, 126, 0.22), transparent 60%);
    pointer-events: none;
  }
  .preview__bar {
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
    padding-bottom: var(--sp-4);
  }
  .preview__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
  }
  .preview__url {
    margin-left: 8px;
    font-family: var(--font-accent);
    font-size: 0.7rem;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.72);
  }
