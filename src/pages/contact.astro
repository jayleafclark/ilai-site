</style>

<script>
  // Lead form: POST to Web3Forms, which emails the submission straight to us.
  // If the access key is not set yet or the request fails, fall back to a
  // pre-filled email so a visitor is never stuck. Honeypot drops bots.
  const form = document.querySelector<HTMLFormElement>("[data-lead-form]");
  if (form) {
    const statusEl = form.querySelector<HTMLElement>("[data-form-status]");
    const doneEl = document.querySelector<HTMLElement>("[data-lead-done]");
    const btn = form.querySelector<HTMLButtonElement>(".lead-form__submit");
    const lab = form.querySelector<HTMLElement>(".lead-form__submit-lab");
    const endpoint = form.getAttribute("data-endpoint") || "";
    const accessKey = form.getAttribute("data-access-key") || "";
    const val = (n: string) =>
      (form.querySelector(`[name="${n}"]`) as HTMLInputElement | null)?.value.trim() || "";

    const mailtoFallback = (d: Record<string, string>) => {
      const subject = encodeURIComponent("Ilai free teardown");
      const body = encodeURIComponent(
        `Name: ${d.name}\nEmail: ${d.email}\nBudget: ${d.budget || "Not specified"}\n\nAbout the work:\n${d.about}\n`,
      );
      window.location.href = `mailto:hello@ilaicollective.com?subject=${subject}&body=${body}`;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (val("company")) return; // honeypot tripped -> silently ignore
      const data = {
        name: val("name"),
        email: val("email"),
        about: val("about"),
        budget: val("budget"),
      };
      if (!data.name || !data.email || !data.about) {
        if (statusEl) {
          statusEl.hidden = false;
          statusEl.textContent = "Please add your name, email, and a line about your work.";
        }
        return;
      }
      const original = lab?.textContent || "Get your free teardown";
      if (btn) btn.disabled = true;
      if (lab) lab.textContent = "Sending…";
      if (statusEl) statusEl.hidden = true;

      const configured = !!endpoint && !!accessKey && !accessKey.includes("YOUR_");

      try {
        if (!configured) throw new Error("not-configured");
        const res = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            access_key: accessKey,
            subject: "New free teardown request from the Ilai site",
            from_name: data.name,
            name: data.name,
            email: data.email,
            budget: data.budget || "Not specified",
            message: data.about,
          }),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.success) throw new Error("bad-status");
        form.hidden = true;
        if (doneEl) doneEl.hidden = false;
      } catch (err) {
        if (btn) btn.disabled = false;
        if (lab) lab.textContent = original;
        if (statusEl) {
          statusEl.hidden = false;
          statusEl.textContent = "Opening your email app so you can send this to us directly.";
        }
        mailtoFallback(data);
      }
    });
  }
</script>
