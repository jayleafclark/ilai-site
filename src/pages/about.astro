---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const beliefs = [
  {
    title: "Specific beats generic",
    body: "Content that names your market, your competitors, and the one person you sell to travels. Content that could belong to any brand in your category gets scrolled past.",
    c: "var(--coral)",
    icon: `<circle cx="10" cy="10" r="6" stroke="currentColor" stroke-width="1.6"/><path d="M14.5 14.5L18 18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="10" cy="10" r="2.2" fill="currentColor"/>`,
  },
  {
    title: "The internet has enough AI slop",
    body: "Say-nothing, made-in-bulk content is everywhere now, and audiences have learned to tune it out. We make the kind a person researched, wrote, and put their name on.",
    c: "var(--plum)",
    icon: `<path d="M10 2l6 2.5v5c0 4-2.7 6.3-6 7.5-3.3-1.2-6-3.5-6-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M7.2 10l2 2 3.6-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "The first hour decides everything",
    body: "A post lives or dies on the hook and the first hour of replies. We staff those minutes and answer in real time, instead of shipping and walking away.",
    c: "var(--brand)",
    icon: `<circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.6"/><path d="M10 5.5V10l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    title: "You should be selling, not posting",
    body: "Running an audience across five platforms is a full-time job. Yours is closing the people it sends you. The posting, the replies, and the reporting are ours.",
    c: "var(--green)",
    icon: `<path d="M3.5 11L18 4l-5.5 14-2.3-5.6L3.5 11z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
];

// Anonymous team credentials (no names, no photos).
const credentials = [
  {
    t: "20+ years of operating",
    s: "Our team has spent two decades leading, building, and growing organizations, not just posting to them.",
    c: "var(--coral)",
    icon: `<path d="M10 2.5l2.2 4.7 5.1.7-3.7 3.6.9 5.1L10 14.2 5.5 16.6l.9-5.1L2.7 7.9l5.1-.7L10 2.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  },
  {
    t: "Technical and creative",
    s: "The people who build the software and the people who set the voice are on the same team, so nothing gets lost in a hand-off.",
    c: "var(--pink-ink)",
    icon: `<path d="M6.5 4.5L2.5 8.5l4 4M13.5 4.5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M11.5 3l-3 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    t: "Proven at real scale",
    s: "Our work is trusted by creators and brands whose audiences run into the millions, across every major platform.",
    c: "var(--charcoal)",
    icon: `<path d="M3 15.5L8 10l3.5 3L17 6.5M17 6.5V11M17 6.5H12.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    t: "Senior hands only",
    s: "No account managers, no hand-off to juniors. The people who plan and make the work are the ones who run your account.",
    c: "pearl",
    icon: `<path d="M10 2l6 2.5v5c0 4-2.7 6.3-6 7.5-3.3-1.2-6-3.5-6-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M7.2 10l2 2 3.6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];

const compare = [
  {
    them: "Guesses what might work and posts it",
    us: "Researches your market and audience first, then writes each piece to a target",
  },
  {
    them: "A different tone on every platform",
    us: "One voice on every platform, set with you and checked on every piece",
  },
  {
    them: "Content shipped on autopilot",
    us: "A senior person reviews and approves every piece before it goes out",
  },
  {
    them: "A monthly PDF report that lands weeks late",
    us: "A live dashboard that updates as the work runs, open to you any time",
  },
  {
    them: "Promises sales it can't control",
    us: "Reports the interest and intent it surfaces, then hands off at your funnel",
  },
];

const stats = [
  {
    value: 120, suffix: "+", label: "Original pieces a month", c: "var(--coral)",
    icon: `<path d="M4 15.5L14 5.5l3.5 3.5L7.5 19H4v-3.5z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M12.5 7l3.5 3.5" stroke="currentColor" stroke-width="1.7"/>`,
  },
  {
    value: 350, suffix: "+", label: "Posts published a month", c: "var(--brand)",
    icon: `<path d="M3.5 11L19 4l-6 15-2.5-6-7-2z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>`,
  },
  {
    value: 13, suffix: "", label: "Platforms, one voice", c: "var(--green)",
    icon: `<rect x="3" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.7"/><rect x="12.5" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.7"/><rect x="3" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.7"/><rect x="12.5" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.7"/>`,
  },
  {
    value: 20, suffix: "+", label: "Years building organizations", c: "var(--plum)",
    icon: `<circle cx="7" cy="8" r="2.8" stroke="currentColor" stroke-width="1.7"/><circle cx="14" cy="8" r="2.8" stroke="currentColor" stroke-width="1.7"/><path d="M3 17c0-2.4 1.8-4 4-4s4 1.6 4 4M11 17c0-2.4 1.8-4 4-4s4 1.6 4 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>`,
  },
];
---

<Layout
  title="About — Ilai Collective"
  description="Ilai Collective is a senior US content studio that grows the audience you sell to. Human-led and human-gated: people set the voice and approve every piece, and research and publishing software we built ourselves lets a small senior team run a full operation across every platform."
  path="/about"
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero__mesh" aria-hidden="true"></div>
    <div class="container hero__inner">
      <span class="eyebrow eyebrow--pill" data-reveal>About</span>
      <h1 class="hero__title" data-reveal data-reveal-delay="1">
        A small senior team that runs a<br />
        <span class="hl-gold">department-sized</span> content operation.
      </h1>
      <p class="lead hero__lead" data-reveal data-reveal-delay="2">
        Ilai is human-led and human-gated. People set the voice, write the angles,
        and approve everything before it ships. The software we built ourselves lets a
        senior US team run a content operation the size of a full department.
      </p>
      <div class="hero__cta" data-reveal data-reveal-delay="3">
        <a href="#people" class="btn btn--signal">Meet the team<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
        <a href="/contact" class="btn btn--ghost">Get your free teardown</a>
      </div>
    </div>
  </section>

  <!-- ============ WHAT WE BELIEVE (dark band, glass cards) ============ -->
  <section class="section section--ink beliefs-sec">
    <div class="beliefs__glow" aria-hidden="true"></div>
    <div class="container">
      <div class="beliefs__head" data-reveal>
        <span class="eyebrow eyebrow--star eyebrow--ondark">What we believe</span>
        <h2 class="beliefs__h">A few rules we hold to on <span class="hl-gold">every account.</span></h2>
        <p class="beliefs__lead">
          These decide what we make, what we turn down, and where the hours go each week.
        </p>
      </div>
      <div class="beliefs__grid">
        {beliefs.map((b, i) => (
          <article class="belief" data-reveal data-reveal-delay={String((i % 2) + 1)}>
            <span class="belief__ico" aria-hidden="true" style={`--ic:${b.c}`}>
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none" set:html={b.icon} />
            </span>
            <h3 class="belief__title">{b.title}</h3>
            <p class="belief__body">{b.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ THE PEOPLE ============ -->
  <section class="section" id="people">
    <div class="container team__grid">
      <div class="team__copy" data-reveal>
        <span class="eyebrow eyebrow--star">The team</span>
        <h2 class="team__hh">A senior team that has <span class="hl">done this before.</span></h2>
        <p class="lead team__lead">
          We keep the studio small and senior on purpose. Our team brings over 20 years of
          leading, building, and growing organizations, with the technical and the creative
          side under one roof. The people who plan and make the work are the ones who run
          your account.
        </p>
        <ul class="team__pillars">
          {credentials.map((c) => (
            <li class="team__pillar">
              <span class={`team__ico${c.c === "pearl" ? " ico--pearl" : ""}`} aria-hidden="true" style={c.c === "pearl" ? "" : `--ic:${c.c}`}>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" set:html={c.icon} />
              </span>
              <div>
                <h3 class="team__pt">{c.t}</h3>
                <p class="team__ps">{c.s}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Distinctive graphic: two strengths, one team -->
      <div class="team__viz" data-reveal data-reveal-delay="1" aria-hidden="true">
        <div class="tcv">
          <div class="tcv__cap">Two strengths, one team</div>
          <div class="tcv__nodes">
            <div class="tcv__node tcv__node--tech">
              <span class="tcv__ic">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M6.5 4.5L2.5 8.5l4 4M13.5 4.5l4 4-4 4M11.5 3l-3 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <b>Technical</b>
            </div>
            <div class="tcv__merge" aria-hidden="true">
              <span></span><span></span>
            </div>
            <div class="tcv__node tcv__node--cre">
              <span class="tcv__ic tcv__ic--pink">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M10 2.5l2.2 4.7 5.1.7-3.7 3.6.9 5.1L10 14.2 5.5 16.6l.9-5.1L2.7 7.9l5.1-.7L10 2.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
              </span>
              <b>Creative</b>
            </div>
          </div>
          <div class="tcv__out">
            <span class="tcv__outk">One senior team</span>
            <span class="tcv__outd">Both, under one roof, on every account</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CAPABILITY STAT ROW ============ -->
  <section class="stats-sec">
    <div class="container">
      <div class="statspanel" data-reveal>
        {stats.map((s) => (
          <div class="statp">
            <span class="statp__ico" aria-hidden="true" style={`--ic:${s.c}`}>
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" set:html={s.icon} />
            </span>
            <div>
              <div class="statp__num" data-count={s.value} data-decimals="0" data-suffix={s.suffix}>
                {s.value.toLocaleString("en-US") + s.suffix}
              </div>
              <div class="statp__lab">{s.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ HOW WE'RE DIFFERENT (dynamic compare) ============ -->
  <section class="section section--mist">
    <div class="container">
      <div class="cmp__head" data-reveal>
        <span class="eyebrow eyebrow--star">How we're different</span>
        <h2 class="cmp__hh">What a normal agency does, and <span class="hl">what we do instead.</span></h2>
        <p class="lead cmp__lead">
          The gap comes down to research and our own software, which let us do by hand what
          most agencies paper over with volume.
        </p>
      </div>
      <div class="cmp" data-reveal>
        <div class="cmp__headrow" aria-hidden="true">
          <span class="cmp__label cmp__label--them">A normal agency</span>
          <span class="cmp__label cmp__label--us">
            <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><path d="M10 2l1.9 4.8L17 8l-4 3.4 1.2 5L10 13.9 5.8 16.4 7 11.4 3 8l5.1-1.2L10 2z" fill="currentColor"/></svg>
            Ilai
          </span>
        </div>
        <ul class="cmp__list">
          {compare.map((row, i) => (
            <li class="cmp__row" data-reveal data-reveal-delay={String((i % 4) + 1)}>
              <div class="cmp__cell cmp__cell--them">
                <span class="cmp__mark cmp__mark--them" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <span>{row.them}</span>
              </div>
              <div class="cmp__cell cmp__cell--us">
                <span class="cmp__mark cmp__mark--us" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5l3 3 6-7" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span>{row.us}</span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ HUMAN-LED, HUMAN-GATED (manifesto band) ============ -->
  <section class="section section--ink manifesto">
    <div class="manifesto__glow" aria-hidden="true"></div>
    <div class="container">
      <div class="manifesto__inner" data-reveal>
        <span class="eyebrow eyebrow--pill manifesto__pill">Our standard</span>
        <h2 class="manifesto__title">Human-led.<br /><span class="hl-gold">Human-gated.</span></h2>
        <p class="manifesto__lead">
          Under the work sit research and publishing engines we built ourselves, the kind
          that usually take a whole department to run. They carry the volume so a small senior
          team can cover every platform without cutting corners.
        </p>
        <p class="manifesto__body">
          People stay in charge of everything that carries a name. We direct the strategy,
          set the voice, and sign off on every piece before it ships. That is how the quality
          holds at scale, and why the work sounds like you instead of like software filling space.
        </p>
        <p class="manifesto__wink">
          P.S. A person wrote every word on this site, and it passed our own no-slop filter:
          no canned openers, no em dashes doing the emotional heavy lifting, no manufactured
          this-versus-that contrasts, and zero AI slop.
        </p>
        <div class="manifesto__pills">
          <span class="mpill"><span class="mpill__dot" style="background:var(--green)"></span>People set the voice</span>
          <span class="mpill"><span class="mpill__dot" style="background:var(--brand)"></span>People sign off on everything</span>
          <span class="mpill"><span class="mpill__dot" style="background:var(--coral-soft)"></span>Software carries the volume</span>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    padding-top: clamp(8rem, 16vh, 12rem);
    padding-bottom: var(--sp-12);
    overflow: hidden;
  }
  .hero__mesh {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 78%;
    background:
      radial-gradient(40% 58% at 20% 16%, rgba(28, 107, 74, 0.16), transparent 70%),
      radial-gradient(38% 50% at 82% 10%, rgba(230, 169, 196, 0.30), transparent 72%),
      radial-gradient(30% 40% at 60% 30%, rgba(230, 169, 196, 0.14), transparent 70%);
    filter: blur(10px);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero__title {
    margin-top: var(--sp-5);
    max-width: 20ch;
    font-size: var(--fs-h1);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
  }
  .hero__lead {
    margin-top: var(--sp-5);
    max-width: 60ch;
    text-align: center;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: center;
    margin-top: var(--sp-8);
  }
  /* Mobile: primary button full-width, secondary a lighter centered pill with
     more breathing room between them. Desktop is untouched. */
  @media (max-width: 640px) {
    .hero__cta {
      flex-direction: column;
      align-items: stretch;
      gap: var(--sp-4);
    }
    .hero__cta .btn--signal {
      width: 100%;
      min-height: 50px;
      justify-content: center;
    }
    .hero__cta .btn--ghost {
      align-self: center;
      width: auto;
      min-height: 44px;
      padding: 11px 20px;
    }
  }

  /* ---------- Beliefs (dark band, glass cards) ---------- */
  .beliefs-sec {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(60% 90% at 82% 8%, rgba(201, 162, 92, 0.16), transparent 60%),
      linear-gradient(160deg, var(--charcoal-2), var(--charcoal) 55%, var(--charcoal-3));
  }
  .beliefs__glow {
    position: absolute;
    top: -30%;
    left: 8%;
    width: 60%;
    height: 80%;
    background: radial-gradient(50% 50% at 50% 50%, rgba(79, 164, 126, 0.16), transparent 70%);
    pointer-events: none;
  }
  .beliefs__head {
    position: relative;
    max-width: 46ch;
    margin-bottom: var(--sp-10);
  }
  .beliefs__h {
    margin-top: var(--sp-4);
    font-size: var(--fs-h2);
    color: #fff;
    letter-spacing: var(--tracking-tight);
  }
  .beliefs__lead {
    margin-top: var(--sp-4);
    font-size: var(--fs-lead);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.72);
  }
  .beliefs__grid {
    position: relative;
    display: grid;
    gap: var(--grid-gap);
  }
  .belief {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-radius: var(--r-card);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.14);
    transition:
      transform var(--dur-base) var(--ease),
      background var(--dur-base) var(--ease),
      border-color var(--dur-base) var(--ease);
  }
  .belief:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.09);
    border-color: rgba(255, 255, 255, 0.24);
  }
  .belief__ico {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 15px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.5),
      0 12px 24px -10px var(--ic);
  }
  .belief__ico svg { stroke-width: 1.7; }
  .belief__title {
    margin-top: var(--sp-5);
    font-size: var(--fs-h3);
    color: #fff;
  }
  .belief__body {
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.66);
  }
  @media (min-width: 760px) {
    .beliefs__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ---------- The team (anonymous credentials) ---------- */
  .team__grid {
    display: grid;
    gap: var(--sp-10);
    align-items: start;
  }
  .team__hh {
    margin-top: var(--sp-4);
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  .team__lead { margin-top: var(--sp-4); max-width: 52ch; }
  .team__pillars {
    list-style: none;
    margin-top: var(--sp-8);
    display: grid;
    gap: var(--sp-5);
  }
  .team__pillar {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
  }
  .team__ico {
    flex: none;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 13px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.5), 0 10px 20px -8px var(--ic);
  }
  .team__pt { font-size: var(--fs-h3); }
  .team__ps { margin-top: var(--sp-2); font-size: var(--fs-sm); color: var(--muted); line-height: 1.55; }

  /* Distinctive "two strengths, one team" graphic */
  .team__viz { align-self: start; }
  .tcv {
    position: relative;
    padding: clamp(1.75rem, 3vw, 2.5rem);
    border-radius: var(--r-card-lg);
    background: linear-gradient(150deg, var(--charcoal), var(--charcoal-2));
    box-shadow: var(--shadow-float);
    overflow: hidden;
  }
  .tcv::after {
    content: "";
    position: absolute; top: -30%; right: -10%;
    width: 60%; height: 120%;
    background: radial-gradient(50% 50% at 50% 40%, rgba(201, 162, 92, 0.24), transparent 70%);
    pointer-events: none;
  }
  .tcv__cap {
    position: relative; z-index: 1;
    font-family: var(--font-accent); font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--sp-5);
  }
  /* Two nodes converge toward the merge point on reveal */
  .tcv__nodes {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-5);
  }
  .tcv__node {
    flex: 1;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    padding: var(--sp-4);
    border-radius: var(--r-card);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
