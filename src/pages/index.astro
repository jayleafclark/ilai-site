<script>
  // Hero carousel.
  //  - Desktop (>640px): full carousel — auto-advance, dots, arrows, pointer swipe.
  //  - Mobile (<=640px): auto-rotating CROSSFADE through all slides, no dots/arrows/
  //    swipe UI (see the mobile branch below). Slides are stacked + crossfaded in CSS.
  const car = document.querySelector<HTMLElement>("[data-carousel]");
  const isMobile = window.matchMedia("(max-width: 640px)").matches;
  if (car && !isMobile) {
    const track = car.querySelector<HTMLElement>("[data-track]")!;
    const slides = Array.from(track.children);
    const dots = Array.from(car.querySelectorAll<HTMLButtonElement>("[data-dots] button"));
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const render = () => {
      track.style.transform = `translateX(-${i * 100}%)`;
      dots.forEach((d, k) => d.classList.toggle("is-active", k === i));
      slides.forEach((s, k) => s.classList.toggle("is-active", k === i));
    };
    const go = (n: number) => {
      i = (n + slides.length) % slides.length;
      render();
    };
    const auto = () => {
      if (!reduce) timer = setInterval(() => go(i + 1), 8000);
    };
    const restart = () => {
      if (timer) clearInterval(timer);
      auto();
    };

    car.querySelector("[data-next]")?.addEventListener("click", () => { go(i + 1); restart(); });
    car.querySelector("[data-prev]")?.addEventListener("click", () => { go(i - 1); restart(); });
    dots.forEach((d, k) => d.addEventListener("click", () => { go(k); restart(); }));
    car.addEventListener("mouseenter", () => timer && clearInterval(timer));
    car.addEventListener("mouseleave", auto);

    // Pointer swipe
    let x0: number | null = null;
    let dx = 0;
    const vp = car.querySelector<HTMLElement>(".herocar__vp")!;
    vp.addEventListener("pointerdown", (e) => {
      x0 = e.clientX; dx = 0;
      track.style.transition = "none";
      if (timer) clearInterval(timer);
    });
    window.addEventListener("pointermove", (e) => {
      if (x0 === null) return;
      dx = e.clientX - x0;
      track.style.transform = `translateX(calc(-${i * 100}% + ${dx}px))`;
    });
    window.addEventListener("pointerup", () => {
      if (x0 === null) return;
      track.style.transition = "";
      if (Math.abs(dx) > 55) go(dx < 0 ? i + 1 : i - 1);
      else render();
      x0 = null;
      restart();
    });

    render();
    auto();
  } else if (car && isMobile) {
    // Mobile: auto-rotating CROSSFADE through all slides. No dots, arrows, or swipe
    // (those stay display:none). Slides are stacked in one grid cell and crossfaded
    // via CSS opacity on .is-active — here we only advance the active class on a
    // timer. Respects prefers-reduced-motion (stays on slide 1, no motion).
    const mtrack = car.querySelector<HTMLElement>("[data-track]")!;
    const mslides = Array.from(mtrack.children);
    const mreduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let mi = 0;
    if (!mreduce && mslides.length > 1) {
      setInterval(() => {
        mi = (mi + 1) % mslides.length;
        mslides.forEach((s, k) => s.classList.toggle("is-active", k === mi));
      }, 7000);
    }
  }
</script>

