---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import PlatformStrip from "../components/PlatformStrip.astro";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const features = [
  {
    t: "Researched, not guessed",
    s: "Every piece aimed at the people you sell to.",
    icon: `<circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="9" r="2" fill="currentColor"/>`,
  },
  {
    t: "Human-led, human-gated",
    s: "People set the voice and sign off on everything.",
    icon: `<path d="M10 2l6 2.5v5c0 4-2.7 6.3-6 7.5-3.3-1.2-6-3.5-6-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M7.2 10l2 2 3.6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    t: "Everywhere, one voice",
    s: "One recording, published across up to 13 platforms.",
    icon: `<circle cx="10" cy="10" r="2.2" fill="currentColor"/><path d="M5.5 5.5a6.5 6.5 0 000 9M14.5 5.5a6.5 6.5 0 010 9M3 3a10 10 0 000 14M17 3a10 10 0 010 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>`,
  },
];

const growth = [
  { p: "Facebook", v: "+359%", pct: 100 },
  { p: "Instagram", v: "+155%", pct: 62 },
  { p: "YouTube", v: "+42%", pct: 30 },
  { p: "TikTok", v: "+39%", pct: 26 },
];

const stats = [
  {
    value: 205, suffix: "M+", label: "Impressions in 12 months",
    icon: `<path d="M3 17V9M8.5 17V4M14 17v-6M19.5 17V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    value: 90, suffix: "K+", label: "New followers",
    icon: `<circle cx="8" cy="7" r="3" stroke="currentColor" stroke-width="1.6"/><path d="M3 18a5 5 0 0110 0M15 5a3 3 0 010 6M19 18a4.5 4.5 0 00-3-4.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    value: 8, suffix: "", label: "Platforms managed",
    icon: `<rect x="3" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="12.5" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="12.5" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/>`,
  },
  {
    value: 0, prefix: "$", label: "Spent on ads",
    icon: `<circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.6"/><path d="M11 7v8M8.5 9.2c0-1.2 1.1-1.9 2.5-1.9s2.5.6 2.5 1.8-1.1 1.6-2.5 1.9-2.5.7-2.5 1.9 1.1 1.8 2.5 1.8 2.5-.7 2.5-1.9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>`,
  },
];

const services = [
  { tag: "Podcasts & video", d: "Full episode edits, clips, long-form YouTube, show notes, and SEO. Record once, get a month of content.", tone: "navy" },
  { tag: "Short-form & reels", d: "Scroll-stopping clips cut from every episode and fanned out across each platform, in your voice.", tone: "blue" },
  { tag: "Publishing & engagement", d: "Posted everywhere on schedule, with first-response community engagement in the minutes that decide reach.", tone: "navy2" },
];

const posts = [
  { slug: "one-recording-content-system", tag: "Systems", title: "Be everywhere without living online", date: "Apr 14, 2026" },
  { slug: "why-organic-reach-fell-2025", tag: "Strategy", title: "Why organic reach fell in 2025", date: "May 20, 2026" },
  { slug: "ai-slop-vs-researched-content", tag: "Craft", title: "AI slop vs researched content", date: "Jun 18, 2026" },
];
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container">
      <div class="herocar" data-carousel data-reveal>
        <div class="herocar__vp">
          <div class="herocar__track" data-track>

            <!-- Slide 1: pitch -->
            <article class="hslide">
              <div class="hslide__inner">
                <span class="eyebrow eyebrow--star eyebrow--ondark">Welcome to Ilai Collective</span>
                <h1 class="hslide__title">We make experts<br />impossible to ignore.</h1>
                <p class="hslide__lead">
                  A human-led content studio for experts and personal brands. We learn your
                  brand, your market, and your audience, then grow it. You film once, we do the rest.
                </p>
                <div class="hslide__actions">
                  <a href="/contact" class="btn btn--signal">Book a call<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
                  <a href="/work/dr-caroline-leaf" class="btn btn--ghost btn--ghost-dark">See the proof</a>
                </div>
              </div>
              <div class="hslide__visual" aria-hidden="true">
                <div class="chrome hmock">
                  <div class="chrome__bar">
                    <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
                    <span class="chrome__url">drleaf.ilaicollective.com</span>
                  </div>
                  <div class="chrome__body">
                    <div class="hmock__tiles">
                      <div class="hmock__tile"><span class="hmock__tl">Impressions, 30d</span><span class="hmock__tv">27.1M</span></div>
                      <div class="hmock__tile"><span class="hmock__tl">Engagements, 30d</span><span class="hmock__tv">1.1M</span></div>
                    </div>
                    <div class="hmock__chart">
                      {[38, 52, 46, 68, 60, 82, 74, 96].map((h) => <span style={`--h:${h}%`}></span>)}
                    </div>
                  </div>
                </div>
                <div class="herofloat">
                  <span class="herofloat__num">+204<span class="herofloat__u">%</span></span>
                  <span class="herofloat__lab">Reach, year over year</span>
                </div>
              </div>
            </article>

            <!-- Slide 2: repurpose -->
            <article class="hslide hslide--2">
              <div class="hslide__inner">
                <span class="eyebrow eyebrow--star eyebrow--ondark">One recording, everywhere</span>
                <h1 class="hslide__title">Film once.<br />Post for a month.</h1>
                <p class="hslide__lead">
                  One 60-minute recording becomes 30-plus pieces of content, adapted for every
                  platform and published for you, in a voice we build with you.
                </p>
                <div class="hslide__actions">
                  <a href="/method" class="btn btn--signal">See how it works<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
                  <a href="/what-we-do" class="btn btn--ghost btn--ghost-dark">What we do</a>
                </div>
              </div>
              <div class="hslide__visual" aria-hidden="true">
                <div class="fanout">
                  <div class="fanout__src">1 recording</div>
                  <div class="fanout__cards">
                    {["Reel", "Short", "Carousel", "Essay", "Clip", "Thread"].map((c) => <span>{c}</span>)}
                  </div>
                </div>
                <div class="herofloat">
                  <span class="herofloat__num">30<span class="herofloat__u">+</span></span>
                  <span class="herofloat__lab">pieces per recording</span>
                </div>
              </div>
            </article>

            <!-- Slide 3: proof -->
            <article class="hslide hslide--3">
              <div class="hslide__inner">
                <span class="eyebrow eyebrow--star eyebrow--ondark">Proven to spread</span>
                <h1 class="hslide__title">Proof,<br />not promises.</h1>
                <p class="hslide__lead">
                  In 12 months one client reached 205M+ impressions and gained 90,000+
                  followers, with reach up 204% year over year and nothing spent on ads.
                </p>
                <div class="hslide__actions">
                  <a href="/work/dr-caroline-leaf" class="btn btn--signal">Read the case study<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
                  <a href="/contact" class="btn btn--ghost btn--ghost-dark">Book a call</a>
                </div>
              </div>
              <div class="hslide__visual" aria-hidden="true">
                <div class="prooftiles">
                  <div class="prooftile"><span class="prooftile__n">205M+</span><span class="prooftile__l">Impressions in 12 months</span></div>
                  <div class="prooftile prooftile--coral"><span class="prooftile__n">3×</span><span class="prooftile__l">Reach & engagement, year over year</span></div>
                </div>
              </div>
            </article>

          </div>
        </div>

        <div class="herocar__nav">
          <div class="herocar__dots" data-dots>
            <button class="herocar__dot is-active" type="button" aria-label="Slide 1"></button>
            <button class="herocar__dot" type="button" aria-label="Slide 2"></button>
            <button class="herocar__dot" type="button" aria-label="Slide 3"></button>
          </div>
          <div class="herocar__arrows">
            <button class="herocar__arrow" type="button" data-prev aria-label="Previous slide">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="herocar__arrow" type="button" data-next aria-label="Next slide">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Floating feature cards -->
      <div class="herofeatures">
        {features.map((f, i) => (
          <article class="feat" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="feat__ico" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" set:html={f.icon} />
            </span>
            <div>
              <p class="feat__t">{f.t}</p>
              <p class="feat__s">{f.s}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="hero__logos" data-reveal>
        <PlatformStrip />
      </div>
    </div>
  </section>

  <!-- ============ WELCOME + CLIENT CARD ============ -->
  <section class="section welcome">
    <div class="container welcome__grid">
      <div class="welcome__copy" data-reveal>
        <span class="eyebrow eyebrow--star">Why Ilai</span>
        <h2 class="welcome__h">Content that's built,<br />not guessed.</h2>
        <p class="welcome__p">
          Most experts know content matters and have no time to be everywhere. Generic
          agencies hand back posts that sound like everyone else.
        </p>
        <p class="welcome__p">
          Ilai runs the whole operation: research, scripts, publishing, and community, in a
          voice we build with you and never hand to a machine to guess. You stay focused on
          serving and selling to the people we bring you.
        </p>
        <a href="/method" class="btn btn--blue">
          See how it works
          <span class="btn__arrow" aria-hidden="true" set:html={arrow} />
        </a>
      </div>

      <article class="clientcard card--dark" data-reveal data-reveal-delay="1">
        <div class="clientcard__top">
          <div class="clientcard__ava" aria-hidden="true">CL</div>
          <div>
            <p class="clientcard__name">One client, one year</p>
            <p class="clientcard__role">Dr. Caroline Leaf · year-over-year growth</p>
          </div>
        </div>
        <ul class="growth">
          {growth.map((g) => (
            <li class="growth__row">
              <span class="growth__p">{g.p}</span>
              <span class="growth__track"><span class="growth__fill" style={`--w:${g.pct}%`}></span></span>
              <span class="growth__v">{g.v}</span>
            </li>
          ))}
        </ul>
        <p class="clientcard__note">
          Reach and engagement roughly tripled in a year the average account went backwards.
          Zero spent on ads.
        </p>
      </article>
    </div>
  </section>

  <!-- ============ STATS PANEL ============ -->
  <section class="stats-sec">
    <div class="container">
      <div class="statspanel" data-reveal>
        {stats.map((s) => (
          <div class="statp">
            <span class="statp__ico" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none" set:html={s.icon} />
            </span>
            <div>
              <div class="statp__num" data-count={s.value} data-decimals="0" data-prefix={s.prefix ?? ""} data-suffix={s.suffix ?? ""}>
                {(s.prefix ?? "") + s.value.toLocaleString("en-US") + (s.suffix ?? "")}
              </div>
              <div class="statp__lab">{s.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="section services">
    <div class="container">
      <div class="services__head" data-reveal>
        <div>
          <span class="eyebrow eyebrow--star">What we do</span>
          <h2 class="services__h">One studio for every channel.</h2>
        </div>
        <div class="services__intro">
          <p class="muted">
            Everything it takes to build and hold an audience, run by a real US team and
            supported by serious in-house software.
          </p>
          <a href="/what-we-do" class="btn btn--ghost">
            Explore every service
            <span class="btn__arrow" aria-hidden="true" set:html={arrow} />
          </a>
        </div>
      </div>
      <div class="services__grid">
        {services.map((s, i) => (
          <article class={`svc svc--${s.tone}`} data-reveal data-reveal-delay={String(i + 1)}>
            <div class="svc__media" aria-hidden="true">
              <span class="svc__num">{`0${i + 1}`}</span>
            </div>
            <div class="svc__body">
              <h3>{s.tag}</h3>
              <p>{s.d}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ OFFER ============ -->
  <section class="section offer">
    <div class="container offer__grid">
      <article class="offercard card--navy" data-reveal>
        <span class="eyebrow eyebrow--star eyebrow--ondark">What a month looks like</span>
        <h3 class="offercard__h">120+ pieces. 350+ posts. One voice.</h3>
        <ul class="checks">
          <li>Around 4 podcast episodes, cut into ~20 reels and clips</li>
          <li>~60 short-form posts and ~12 long-form essays</li>
          <li>Published across up to 13 platforms, on schedule</li>
          <li>First-response community engagement, in your voice</li>
          <li>A live dashboard where every number is pulled automatically</li>
        </ul>
      </article>

      <aside class="startcard" data-reveal data-reveal-delay="1">
        <span class="eyebrow eyebrow--star">Start here</span>
        <h3 class="startcard__h">A free teardown, then your first month.</h3>
        <p class="muted">
          We research your brand, market, and audience and show you where the attention is,
          before you decide anything.
        </p>
        <div class="startcard__price">
          <span class="startcard__amt">$1,950</span>
          <span class="startcard__per">pilot month, fully credited</span>
        </div>
        <p class="startcard__sub">Ongoing engagements start at $5,500/mo.</p>
        <a href="/contact" class="btn btn--signal startcard__cta">
          Book a call
          <span class="btn__arrow" aria-hidden="true" set:html={arrow} />
        </a>
      </aside>
    </div>
  </section>

  <!-- ============ TESTIMONIAL / PULL ============ -->
  <section class="section pull-sec">
    <div class="container">
      <figure class="pull" data-reveal>
        <div class="pull__quote">
          <span class="pull__mark" aria-hidden="true">&ldquo;</span>
          <blockquote>
            In a year the average account's organic reach fell about 12 percent. Dr. Leaf's
            reach and engagement roughly tripled, at a size where most accounts flatten out.
          </blockquote>
          <figcaption>
            <span class="pull__who">The Dr. Caroline Leaf case study</span>
            <a href="/work/dr-caroline-leaf" class="pull__link">Read the numbers →</a>
          </figcaption>
        </div>
        <div class="pull__stat" aria-hidden="true">
          <span class="pull__num">3×</span>
          <span class="pull__lab">reach and engagement, in a shrinking year</span>
        </div>
      </figure>
    </div>
  </section>

  <!-- ============ BLOG ============ -->
  <section class="section blog-sec">
    <div class="container">
      <div class="blog__head" data-reveal>
        <div>
          <span class="eyebrow eyebrow--star">From the studio</span>
          <h2 class="blog__h">Notes on building an audience.</h2>
        </div>
        <a href="/blog" class="btn btn--ghost">
          See all posts
          <span class="btn__arrow" aria-hidden="true" set:html={arrow} />
        </a>
      </div>
      <div class="blog__grid">
        {posts.map((p, i) => (
          <a href={`/blog/${p.slug}`} class="postcard" data-reveal data-reveal-delay={String(i + 1)}>
            <div class={`postcard__thumb postcard__thumb--${i}`} aria-hidden="true">
              <span class="postcard__tag">{p.tag}</span>
            </div>
            <div class="postcard__body">
              <h3>{p.title}</h3>
              <span class="postcard__date">{p.date}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<script>
  // Hero carousel: auto-advance, dots, arrows, pointer swipe.
  const car = document.querySelector<HTMLElement>("[data-carousel]");
  if (car) {
    const track = car.querySelector<HTMLElement>("[data-track]")!;
    const slides = Array.from(track.children);
    const dots = Array.from(car.querySelectorAll<HTMLButtonElement>("[data-dots] button"));
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let i = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    const render = () => {
      track.style.transform = `translateX(-${i * 100}%)`;
      dots.forEach((d, k) => d.classList.toggle("is-active", k === i));
    };
    const go = (n: number) => {
      i = (n + slides.length) % slides.length;
      render();
    };
    const auto = () => {
      if (!reduce) timer = setInterval(() => go(i + 1), 5500);
    };
    const restart = () => {
      if (timer) clearInterval(timer);
      auto();
    };

    car.querySelector("[data-next]")?.addEventListener("click", () => { go(i + 1); restart(); });
    car.querySelector("[data-prev]")?.addEventListener("click", () => { go(i - 1); restart(); });
    dots.forEach((d, k) => d.addEventListener("click", () => { go(k); restart(); }));
    car.addEventListener("mouseenter", () => timer && clearInterval(timer));
    car.addEventListener("mouseleave", auto);

    // Pointer swipe
    let x0: number | null = null;
    let dx = 0;
    const vp = car.querySelector<HTMLElement>(".herocar__vp")!;
    vp.addEventListener("pointerdown", (e) => {
      x0 = e.clientX; dx = 0;
      track.style.transition = "none";
      if (timer) clearInterval(timer);
    });
    window.addEventListener("pointermove", (e) => {
      if (x0 === null) return;
      dx = e.clientX - x0;
      track.style.transform = `translateX(calc(-${i * 100}% + ${dx}px))`;
    });
    window.addEventListener("pointerup", () => {
      if (x0 === null) return;
      track.style.transition = "";
      if (Math.abs(dx) > 55) go(dx < 0 ? i + 1 : i - 1);
      else render();
      x0 = null;
      restart();
    });

    render();
    auto();
  }
</script>

<style>
  /* ---------- Hero ---------- */
  .hero {
    padding-top: clamp(6.5rem, 12vh, 9rem);
    padding-bottom: clamp(3.5rem, 6vw, 6rem);
  }
  /* ---- Carousel ---- */
  .herocar {
    position: relative;
  }
  .herocar__vp {
    overflow: hidden;
    border-radius: var(--r-card-lg);
    box-shadow: var(--shadow-float);
    touch-action: pan-y;
    cursor: grab;
  }
  .herocar__vp:active {
    cursor: grabbing;
  }
  .herocar__track {
    display: flex;
    transition: transform var(--dur-slow) var(--ease);
    will-change: transform;
  }
  .hslide {
    position: relative;
    min-width: 100%;
    min-height: clamp(430px, 52vw, 560px);
    display: flex;
    align-items: center;
    overflow: hidden;
    color: #fff;
    background:
      radial-gradient(80% 120% at 85% 12%, rgba(242, 104, 60, 0.42), transparent 60%),
      radial-gradient(70% 90% at 8% 92%, rgba(47, 40, 33, 0.9), transparent 65%),
      linear-gradient(135deg, var(--charcoal-2), var(--charcoal) 55%, var(--charcoal-3));
  }
  .hslide--2 {
    background:
      radial-gradient(75% 110% at 88% 15%, rgba(242, 104, 60, 0.34), transparent 60%),
      linear-gradient(135deg, var(--charcoal), var(--charcoal-2));
  }
  .hslide--3 {
    background:
      radial-gradient(85% 120% at 80% 20%, rgba(242, 104, 60, 0.5), transparent 62%),
      linear-gradient(135deg, var(--charcoal-2), var(--charcoal-3));
  }
  .hslide__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 620px;
    padding: clamp(1.75rem, 3.5vw, 2.75rem);
    padding-bottom: clamp(4.5rem, 8vw, 5.5rem);
  }
  .hslide__title {
    margin-top: var(--sp-4);
    font-size: clamp(2.2rem, 3vw, 3.1rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: var(--tracking-display);
    color: #fff;
  }
  .hslide__lead {
    margin-top: var(--sp-5);
    color: rgba(255, 255, 255, 0.82);
    font-size: var(--fs-lead);
    line-height: 1.5;
    max-width: 44ch;
  }
  .hslide__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
  .hslide__visual {
    display: none;
  }

  /* Carousel nav */
  .herocar__nav {
    position: absolute;
    top: clamp(1.5rem, 3vw, 2.25rem);
    right: clamp(1.5rem, 3vw, 2.25rem);
    z-index: 4;
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .herocar__dots {
    display: flex;
    gap: 7px;
  }
  .herocar__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border-radius: 999px;
    border: 0;
    background: rgba(255, 255, 255, 0.35);
    cursor: pointer;
    transition:
      width var(--dur-base) var(--ease),
      background var(--dur-base) var(--ease);
  }
  .herocar__dot.is-active {
    width: 22px;
    background: var(--coral);
  }
  .herocar__arrows {
    display: flex;
    gap: 8px;
  }
  .herocar__arrow {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    cursor: pointer;
