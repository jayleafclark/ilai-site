  .editor__wave span.lit { background: var(--coral); }
  /* the playhead: a thin vertical line with a dot, travelling L->R on loop */
  .editor__sel {
    position: absolute; top: 2px; bottom: 2px; left: 6%; width: 2px;
    background: var(--coral); border-radius: 2px;
    box-shadow: 0 0 8px 1px rgba(28, 107, 74, 0.55);
    animation: playhead 4.2s linear infinite;
  }
  .editor__sel::before {
    content: ""; position: absolute; top: -4px; left: 50%; transform: translateX(-50%);
    width: 8px; height: 8px; border-radius: 50%; background: var(--coral);
    box-shadow: 0 0 8px 1px rgba(28, 107, 74, 0.55);
  }
  @keyframes playhead {
    0% { left: 5%; opacity: 0; }
    6% { opacity: 1; }
    94% { opacity: 1; }
    100% { left: 95%; opacity: 0; }
  }
  .editor__clips { display: flex; gap: 8px; }
  .editor__clip { flex: 1; padding: 9px 8px; border-radius: 9px; font-size: 0.64rem; font-family: var(--font-accent); color: #fff; text-align: center; }
  .editor__clip--a { background: var(--coral); }
  .editor__clip--b { background: var(--brand); color: var(--ink); }
  .editor__clip--c { background: var(--plum); }

  /* ---- Slide 3: thoughtful comment replies ---- */
  .cmts { width: clamp(360px, 31vw, 450px); }
  .cmts__body {
    padding: var(--sp-4);
    height: 264px;
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(to bottom, transparent, #000 13%, #000 87%, transparent);
    mask-image: linear-gradient(to bottom, transparent, #000 13%, #000 87%, transparent);
  }
  .cmts__track {
    display: flex;
    flex-direction: column;
    gap: 10px;
    animation: cmtsScroll 18s linear infinite;
  }
  .cmts:hover .cmts__track { animation-play-state: paused; }
  @keyframes cmtsScroll {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }
  .cmt { position: relative; display: flex; gap: 10px; padding: 10px 12px; border-radius: 12px; background: var(--mist); border: 1px solid var(--line); }
  .cmt--reply { background: var(--pink-tint); border-color: transparent; margin-left: 20px; }
  .cmt__ava { flex: none; width: 26px; height: 26px; border-radius: 50%; background: var(--sand); }
  .cmt__ava--ilai { background: linear-gradient(140deg, var(--pink), color-mix(in srgb, var(--pink) 55%, #fff)); }
  .cmt__txt b { display: block; font-size: 0.72rem; color: var(--ink); }
  .cmt__txt span { font-size: 0.74rem; color: var(--muted); line-height: 1.35; }
  .cmt__badge { position: absolute; top: 9px; right: 11px; font-size: 0.58rem; font-family: var(--font-accent); color: var(--muted); }
  .cmt__badge--lead { color: #fff; background: var(--pink-ink); padding: 2px 8px; border-radius: 999px; }

  .herocard__lead {
    margin-top: var(--sp-5);
    color: rgba(255, 255, 255, 0.82);
    font-size: var(--fs-lead);
    line-height: 1.5;
    max-width: 46ch;
  }
  .herocard__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
  .btn--ghost-dark {
    --btn-fg: #fff;
    border-color: rgba(255, 255, 255, 0.28);
  }
  .btn--ghost-dark:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Floating feature cards */
  .herofeatures {
    position: relative;
    z-index: 2;
    margin-top: -3.5rem;
    display: grid;
    gap: var(--sp-4);
    padding: 0 clamp(0.5rem, 3vw, 2.5rem);
  }
  .feat {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    padding: var(--sp-5);
    border-radius: var(--r-card);
    background: rgba(255, 255, 255, 0.66);
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.6),
      0 18px 40px -24px rgba(29, 42, 35, 0.4);
  }
  .feat__ico {
    flex: none;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.5),
      0 10px 20px -8px var(--ic);
  }
  .feat__ico svg { stroke-width: 1.7; }
  .feat__t {
    font-weight: 700;
    font-size: var(--fs-body);
    letter-spacing: -0.01em;
  }
  .feat__s {
    margin-top: 3px;
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  @media (min-width: 800px) {
    .herofeatures {
      grid-template-columns: repeat(3, 1fr);
      margin-top: -4.5rem;
    }
  }
  .hero__logos {
    margin-top: var(--sp-6);
    padding-top: clamp(1.5rem, 3vw, 2.5rem);
  }

  /* ---------- Welcome + client card ---------- */
  .welcome__grid {
    display: grid;
    gap: var(--sp-8);
    align-items: center;
  }
  .welcome__h {
    margin-top: var(--sp-4);
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
  }
  .welcome__p {
    margin-top: var(--sp-4);
    color: var(--ink-2);
    max-width: 48ch;
  }
  .welcome__copy .btn {
    margin-top: var(--sp-6);
  }
  .clientcard {
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-radius: var(--r-card-lg);
    background: linear-gradient(155deg, var(--slate), var(--slate-2));
  }
  .clientcard__top {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }
  .clientcard__ava {
    flex: none;
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: var(--gold);
    color: var(--charcoal);
  }
  .clientcard__name {
    color: #fff;
    font-weight: 700;
  }
  .clientcard__role {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.6);
  }
  .growth {
    list-style: none;
    margin: var(--sp-6) 0;
    display: grid;
    gap: var(--sp-4);
  }
  .growth__row {
    display: grid;
    grid-template-columns: 5.5em 1fr auto;
    align-items: center;
    gap: var(--sp-3);
  }
  .growth__p {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.85);
  }
  .growth__track {
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    overflow: hidden;
  }
  .growth__fill {
    display: block;
    height: 100%;
    width: 0;
    border-radius: 999px;
    transition: width 1s var(--ease);
  }
  .clientcard.is-visible .growth__fill {
    width: var(--w);
  }
  .growth__v {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: #fff;
  }
  .clientcard__note {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.62);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--on-dark-soft);
  }
  @media (min-width: 900px) {
    .welcome__grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--sp-12);
    }
  }

  /* ---------- Stats panel ---------- */
  .stats-sec {
    padding-bottom: var(--section-y);
  }
  .statspanel {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
    padding: clamp(1.75rem, 4vw, 3rem);
    background: var(--mist);
    border-radius: var(--r-card-lg);
  }
  .statp {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .statp__ico {
    flex: none;
    display: grid;
    place-items: center;
    width: 50px;
    height: 50px;
    border-radius: 15px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.5),
      0 10px 20px -8px var(--ic);
  }
  .statp__num {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--navy);
  }
  .statp__lab {
    margin-top: 4px;
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  @media (min-width: 860px) {
    .statspanel {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ---------- Services ---------- */
  .services__head {
    display: grid;
    gap: var(--sp-5);
    margin-bottom: var(--sp-10);
  }
  .services__h {
    margin-top: var(--sp-4);
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  .services__intro {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-5);
  }
  .services__intro p {
    font-size: var(--fs-lead);
  }
  .services__grid {
    display: grid;
    gap: var(--grid-gap);
  }
  .svc {
    border-radius: var(--r-card-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
  }
  .svc__media {
    position: relative;
    min-height: 172px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-5);
    overflow: hidden;
  }
  .svc--forest .svc__media { background: linear-gradient(150deg, var(--coral), var(--coral-hover)); }
  .svc--charcoal .svc__media { background: linear-gradient(150deg, var(--slate), var(--slate-2)); }
  .svc--pink .svc__media { background: linear-gradient(150deg, var(--pink-ink), var(--pink)); }
  .svc__num {
    position: absolute;
    top: var(--sp-4);
    left: var(--sp-5);
    font-family: var(--font-accent);
    font-weight: 600;
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: -0.03em;
  }
  /* Podcast waveform */
  .viz-wave {
    display: flex;
    align-items: center;
    gap: 4px;
    height: 70px;
  }
  .viz-wave span {
    width: 4px;
    height: var(--h);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
    animation: wave 1.4s var(--ease) infinite alternate;
  }
  .viz-wave span:nth-child(2n) { animation-delay: 0.2s; opacity: 0.7; }
  .viz-wave span:nth-child(3n) { animation-delay: 0.4s; opacity: 0.85; }
  @keyframes wave { to { transform: scaleY(0.55); } }
  /* Reel card */
  .viz-reel {
    width: 96px;
    height: 118px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px;
  }
  .viz-reel__play {
    position: relative;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #fff;
    color: var(--coral);
    animation: vizReelPlay 2.4s var(--ease) infinite;
  }
  .viz-reel__play::after {
    content: "";
    position: absolute; inset: 0; border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.8);
    animation: vizReelRipple 2.4s var(--ease-out) infinite;
  }
  @keyframes vizReelPlay { 0%, 62%, 100% { transform: scale(1); } 72% { transform: scale(0.86); } 82% { transform: scale(1.06); } }
  @keyframes vizReelRipple { 0%, 62% { opacity: 0; transform: scale(1); } 72% { opacity: 0.9; } 100% { opacity: 0; transform: scale(1.9); } }
  .viz-reel__bar,
  .viz-reel__cap {
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.28);
    overflow: hidden;
  }
  /* progress fill sweeps the track */
  .viz-reel__bar::before {
    content: "";
    display: block; height: 100%; width: 100%; border-radius: 999px;
    background: #fff; transform-origin: left; transform: scaleX(0.1);
    animation: vizReelFill 3.4s linear infinite;
  }
  @keyframes vizReelFill { 0% { transform: scaleX(0.05); } 96% { transform: scaleX(1); } 100% { transform: scaleX(0.05); } }
  .viz-reel__cap { width: 66%; background: rgba(255, 255, 255, 0.5); }
  /* Publish grid — cells publish across the grid in a rolling sequence */
  .viz-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
    width: 116px;
  }
  .viz-grid span {
    aspect-ratio: 1;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.28);
    animation: vizGridCell 3s var(--ease) infinite;
  }
  .viz-grid span:nth-child(1) { animation-delay: 0s; }
  .viz-grid span:nth-child(2) { animation-delay: 0.25s; }
  .viz-grid span:nth-child(3) { animation-delay: 0.5s; }
  .viz-grid span:nth-child(4) { animation-delay: 0.75s; }
  .viz-grid span:nth-child(5) { animation-delay: 1s; }
  .viz-grid span:nth-child(6) { animation-delay: 1.25s; }
  @keyframes vizGridCell {
    0%, 70%, 100% { background: rgba(255, 255, 255, 0.18); transform: scale(0.94); }
    12% { background: #fff; transform: scale(1); }
    40% { background: rgba(230, 169, 196, 0.6); }
  }
  /* Research chart — live rolling data */
  .viz-chart { display: flex; align-items: flex-end; gap: 6px; height: 78px; }
  .viz-chart span {
    width: 13px; height: var(--h); border-radius: 4px 4px 2px 2px;
    background: rgba(255, 255, 255, 0.88); transform-origin: bottom;
    animation: vizchart 1.9s var(--ease) infinite alternate;
  }
  .viz-chart span:nth-child(1) { animation-delay: -1.5s; }
  .viz-chart span:nth-child(2) { animation-delay: -1.1s; }
  .viz-chart span:nth-child(3) { animation-delay: -0.7s; }
  .viz-chart span:nth-child(4) { animation-delay: -0.3s; }
  .viz-chart span:nth-child(5) { animation-delay: 0s; }
  @keyframes vizchart { from { transform: scaleY(0.4); } to { transform: scaleY(1); } }
  /* Writing / quote doc — a line types itself out */
  .viz-doc {
    position: relative; width: 128px; display: flex; flex-direction: column; gap: 9px;
    padding: 30px 16px 16px; border-radius: 12px;
    background: rgba(255, 255, 255, 0.12); border: 1px solid rgba(255, 255, 255, 0.28);
  }
  .viz-doc__q {
    position: absolute; top: 2px; left: 12px; font-family: var(--font-display);
    font-size: 2.6rem; line-height: 1; color: rgba(255, 255, 255, 0.85);
  }
  .viz-doc span { height: 6px; border-radius: 999px; background: rgba(255, 255, 255, 0.55); }
  .viz-doc span:nth-child(2) { width: 100%; }
  .viz-doc span:nth-child(3) { width: 84%; }
  .viz-doc__s {
    width: 58%; transform-origin: left;
    animation: vizType 3.6s steps(24) infinite;
  }
  @keyframes vizType { 0% { transform: scaleX(0); } 55% { transform: scaleX(1); } 92% { transform: scaleX(1); } 100% { transform: scaleX(0); } }
  /* Brand swatches — pop in sequence */
  .viz-swatch { display: flex; flex-direction: column; align-items: center; gap: 14px; }
  .viz-swatch__aa {
    font-family: var(--font-display); font-weight: 600; font-size: 2.6rem; line-height: 1;
    letter-spacing: -0.03em; color: #fff;
  }
  .viz-swatch__row { display: flex; gap: 8px; }
  .viz-swatch__row i {
    width: 24px; height: 24px; border-radius: 8px;
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.4);
    animation: vizSwatch 2.8s var(--ease) infinite;
  }
  .viz-swatch__row i:nth-child(1) { background: var(--pink); animation-delay: 0s; }
  .viz-swatch__row i:nth-child(2) { background: #fff; animation-delay: 0.2s; }
  .viz-swatch__row i:nth-child(3) { background: var(--coral-soft); animation-delay: 0.4s; }
  .viz-swatch__row i:nth-child(4) { background: var(--charcoal); animation-delay: 0.6s; }
  @keyframes vizSwatch { 0%, 70%, 100% { transform: translateY(0) scale(1); } 20% { transform: translateY(-5px) scale(1.12); } }
  @media (prefers-reduced-motion: reduce) {
    .viz-wave span, .viz-grid span, .viz-chart span, .viz-reel__play,
    .viz-reel__play::after, .viz-reel__bar::before, .viz-doc__s, .viz-swatch__row i { animation: none; }
  }
  .svc__body {
    background: var(--paper);
    border: 1px solid var(--line);
    border-top: 0;
    border-radius: 0 0 var(--r-card-lg) var(--r-card-lg);
    padding: var(--sp-6);
    flex: 1;
  }
  .svc__body h3 {
    font-size: var(--fs-h3);
  }
  .svc__body p {
    margin-top: var(--sp-3);
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  @media (min-width: 720px) {
    .services__head {
      grid-template-columns: 1fr 1fr;
      align-items: end;
    }
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ---------- How it works ---------- */
  .hiw__top {
    display: grid;
    gap: var(--sp-8);
    align-items: center;
    margin-bottom: var(--sp-10);
  }
  .hiw__head {
    max-width: 46ch;
  }
  .hiw__h {
    margin-top: var(--sp-4);
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  /* Right-side animated graphic: one recording fans into many posts */
  .hiw__viz { justify-self: stretch; }
  .hiwviz {
    position: relative;
    padding: var(--sp-6);
    border-radius: var(--r-card-lg);
    background: linear-gradient(150deg, var(--charcoal), var(--charcoal-2));
    box-shadow: var(--shadow-float);
    overflow: hidden;
  }
  .hiwviz::after {
    content: "";
    position: absolute;
    top: -30%; right: -10%;
    width: 60%; height: 120%;
    background: radial-gradient(50% 50% at 50% 40%, rgba(201, 162, 92, 0.26), transparent 70%);
    pointer-events: none;
  }
  .hiwviz__src {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 8px 15px;
    border-radius: var(--r-pill);
    background: var(--coral);
    color: #fff;
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: 0.82rem;
  }
  .hiwviz__pulse {
    position: relative;
    width: 9px; height: 9px; border-radius: 50%; background: #fff;
  }
  .hiwviz__pulse::after {
    content: "";
    position: absolute; inset: -5px; border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.7);
    animation: hiwPulse 2.2s var(--ease-out) infinite;
  }
  @keyframes hiwPulse {
    0% { opacity: 0.9; transform: scale(0.7); }
    100% { opacity: 0; transform: scale(2); }
  }
  .hiwviz__flow {
    position: relative; z-index: 1;
    height: 22px; margin: 6px 0 var(--sp-4) 12px;
    border-left: 2px dashed rgba(255, 255, 255, 0.22);
    width: 2px;
  }
  .hiwviz__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
  }
  .hiwviz__cell {
    aspect-ratio: 1;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.16);
    animation: hiwCell 3.6s var(--ease) infinite;
    animation-delay: var(--d);
  }
  @keyframes hiwCell {
    0%, 100% { background: rgba(255, 255, 255, 0.1); transform: scale(0.9); }
    18% { background: var(--coral); transform: scale(1); }
    45% { background: rgba(230, 169, 196, 0.55); }
    70% { background: rgba(255, 255, 255, 0.14); }
  }
  .hiwviz__foot {
    position: relative; z-index: 1;
    display: flex; align-items: center; gap: 9px;
    margin-top: var(--sp-5); padding-top: var(--sp-4);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.8rem; color: rgba(255, 255, 255, 0.7);
  }
  .hiwviz__dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--coral);
    box-shadow: 0 0 0 4px rgba(28, 107, 74, 0.3);
  }
  @media (min-width: 900px) {
    .hiw__top {
      grid-template-columns: 1fr 0.9fr;
      gap: var(--sp-12);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hiwviz__pulse::after, .hiwviz__cell { animation: none; }
  }
  .hiw__head .lead {
    margin-top: var(--sp-4);
  }
  .hiw__steps {
    list-style: none;
    display: grid;
    gap: var(--sp-5);
    counter-reset: step;
  }
  .hiw__step {
    padding-top: var(--sp-5);
    border-top: 2px solid var(--line-2);
  }
