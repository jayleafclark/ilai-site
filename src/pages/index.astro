---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import PlatformStrip from "../components/PlatformStrip.astro";
import { getCollection } from "astro:content";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const fmtDate = (d) => d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const features = [
  {
    t: "Researched, not guessed",
    s: "Every piece aimed at the people you sell to.",
    c: "var(--coral)", bg: "var(--coral-tint)",
    icon: `<circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="9" r="2" fill="currentColor"/>`,
  },
  {
    t: "Human-led, human-gated",
    s: "People set the voice and sign off on everything.",
    c: "var(--pink-ink)", bg: "var(--pink-tint)",
    icon: `<path d="M10 2l6 2.5v5c0 4-2.7 6.3-6 7.5-3.3-1.2-6-3.5-6-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M7.2 10l2 2 3.6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    t: "Everywhere, one voice",
    s: "One recording, published across up to 13 platforms.",
    c: "var(--charcoal)", bg: "var(--green-tint)",
    icon: `<circle cx="10" cy="10" r="2.2" fill="currentColor"/><path d="M5.5 5.5a6.5 6.5 0 000 9M14.5 5.5a6.5 6.5 0 010 9M3 3a10 10 0 000 14M17 3a10 10 0 010 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>`,
  },
];

const output = [
  { p: "Short-form posts", v: "~60", pct: 100, c: "var(--coral)" },
  { p: "Reels & clips", v: "~20", pct: 52, c: "var(--pearl)" },
  { p: "Long-form essays", v: "~12", pct: 34, c: "var(--pink)" },
  { p: "Podcast episodes", v: "~4", pct: 16, c: "var(--green)" },
];

const stats = [
  {
    value: 120, suffix: "+", label: "Original pieces a month", c: "var(--coral)", bg: "var(--coral-tint)",
    icon: `<path d="M4 15.5L14 5.5l3.5 3.5L7.5 19H4v-3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M12.5 7l3.5 3.5" stroke="currentColor" stroke-width="1.6"/>`,
  },
  {
    value: 350, suffix: "+", label: "Posts published a month", c: "var(--brand)", bg: "var(--brand-tint)",
    icon: `<path d="M3.5 11L19 4l-6 15-2.5-6-7-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
  {
    value: 13, suffix: "+", label: "Platforms, one voice", c: "pearl", bg: "var(--green-tint)",
    icon: `<rect x="3" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="12.5" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="12.5" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/>`,
  },
  {
    value: 8, suffix: "", label: "Engagement-engine platforms", c: "var(--charcoal)", bg: "var(--plum-tint)",
    icon: `<path d="M4 5.5h16v9H10l-4 3.5v-3.5H4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
];

const services = [
  { tag: "Research & strategy", d: "We learn your audience, your competitors, and which formats are earning engagement in your niche right now, then aim every piece before we make it.", tone: "forest", viz: "chart",
    m: "Aimed at the people you sell to.",
    icon: `<circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.6"/><path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>` },
  { tag: "Podcasts, video & scripts", d: "We write the scripts and shot lists, you record once, and we edit the full episode with dynamic motion graphics and sound design.", tone: "charcoal", viz: "wave",
    m: "We script it, you record once.",
    icon: `<rect x="4" y="7" width="12" height="8.5" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M16 10l3-2v6l-3-2" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>` },
  { tag: "Short-form & reels", d: "Every episode cut into vertical clips with hooks and captions, fanned out across each platform in your voice.", tone: "pink", viz: "reel",
    m: "Vertical clips, hooked and captioned.",
    icon: `<rect x="6.5" y="3" width="9" height="16" rx="2.4" stroke="currentColor" stroke-width="1.6"/><path d="M9.7 11l3-1.8v3.6l-3-1.8z" fill="currentColor"/>` },
  { tag: "Writing at scale", d: "Quote cards, carousels, long-form articles, and newsletters, all written in the voice we document with you.", tone: "charcoal", viz: "doc",
    m: "Carousels, essays, newsletters, your voice.",
    icon: `<path d="M5 3.5h6.5L16 8v9.5a1 1 0 01-1 1H5a1 1 0 01-1-1v-13a1 1 0 011-1z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M11 3.5V8h4.5M7 11.5h6M7 14.5h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>` },
  { tag: "Brand & on-brand templates", d: "Templates matched to your exact typography and color, so 350 posts a month still look unmistakably yours.", tone: "forest", viz: "swatch",
    m: "Every post unmistakably yours.",
    icon: `<circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.6"/><circle cx="7" cy="8" r="1.3" fill="currentColor"/><circle cx="12.5" cy="7.2" r="1.3" fill="currentColor"/><circle cx="13.6" cy="12" r="1.3" fill="currentColor"/>` },
  { tag: "Publishing & engagement", d: "A bespoke posting schedule built for your stage, plus first-response community engagement in the minutes that decide reach.", tone: "pink", viz: "grid",
    m: "Published on schedule, replies in minutes.",
    icon: `<path d="M4 5.5h12v8H8l-3 2.5v-2.5H4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>` },
];

const hiw = [
  { k: "Decode", d: "Your audience, competitors, and what you sell." },
  { k: "Define", d: "Your voice, your look, your content system." },
  { k: "Direct", d: "We write the scripts, you film, you approve." },
  { k: "Distribute", d: "Publish everywhere, engage in your voice." },
  { k: "Measure", d: "A live dashboard where you watch it work." },
];

// HOW-IT-WORKS grid — the 15 named pieces one recording fans out into.
// Weighted so short-form video dominates, tailing into written long-form.
const hiwPieces = [
  { label: "Reel",       icon: `<rect x="4.5" y="3" width="11" height="14" rx="2.4" stroke="currentColor" stroke-width="1.5"/><path d="M8.5 7.4l4 2.6-4 2.6z" fill="currentColor"/>` },
  { label: "Reel",       icon: `<rect x="4.5" y="3" width="11" height="14" rx="2.4" stroke="currentColor" stroke-width="1.5"/><path d="M8.5 7.4l4 2.6-4 2.6z" fill="currentColor"/>` },
  { label: "Short",      icon: `<rect x="6" y="2.5" width="8" height="15" rx="2.2" stroke="currentColor" stroke-width="1.5"/><path d="M8.6 10l2.8-1.7v3.4L8.6 10z" fill="currentColor"/>` },
  { label: "Clip",       icon: `<rect x="3" y="5.5" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M17 8l2.2-1.3v6.6L17 12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>` },
  { label: "Clip",       icon: `<rect x="3" y="5.5" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M17 8l2.2-1.3v6.6L17 12" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>` },
  { label: "Video",      icon: `<circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8.2 6.8l5 3.2-5 3.2z" fill="currentColor"/>` },
  { label: "Tweet",      icon: `<path d="M4 5.5h12M4 9h12M4 12.5h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>` },
  { label: "Thread",     icon: `<circle cx="6" cy="5.5" r="1.7" stroke="currentColor" stroke-width="1.4"/><circle cx="6" cy="14.5" r="1.7" stroke="currentColor" stroke-width="1.4"/><path d="M6 7.2v5.6" stroke="currentColor" stroke-width="1.4"/><path d="M8 5.5h8M8 14.5h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>` },
  { label: "Quote",      icon: `<path d="M8 12H4.5V8.5C4.5 6.6 6 5.5 8 5.5M15.5 12H12V8.5c0-1.9 1.5-3 3.5-3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>` },
  { label: "Carousel",   icon: `<rect x="6" y="4.5" width="8" height="11" rx="1.6" stroke="currentColor" stroke-width="1.5"/><path d="M3.5 6.5v7M16.5 6.5v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>` },
  { label: "Post",       icon: `<rect x="4" y="4" width="12" height="12" rx="2.4" stroke="currentColor" stroke-width="1.5"/><circle cx="10" cy="10" r="2.6" stroke="currentColor" stroke-width="1.5"/>` },
  { label: "Story",      icon: `<circle cx="10" cy="10" r="6.5" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2.4 2.2"/><circle cx="10" cy="10" r="2.4" fill="currentColor"/>` },
  { label: "Newsletter", icon: `<rect x="3.5" y="5" width="13" height="10" rx="1.8" stroke="currentColor" stroke-width="1.5"/><path d="M4 6l6 4.5L16 6" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>` },
  { label: "Article",    icon: `<rect x="4" y="3.5" width="12" height="13" rx="1.8" stroke="currentColor" stroke-width="1.5"/><path d="M6.5 7h7M6.5 10h7M6.5 13h4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>` },
  { label: "Blog",       icon: `<path d="M4 4.5h8.5L16 8v7.5a1 1 0 01-1 1H5a1 1 0 01-1-1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M12 4.5V8h4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>` },
];

// Latest 3 real blog posts, with their real covers
const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3)
  .map((p) => ({
    slug: p.slug,
    tag: p.data.tags?.[0] ?? "Journal",
    title: p.data.title,
    date: fmtDate(p.data.pubDate),
    cover: p.data.cover,
  }));

// Hero slide 1 — content calendar (dots per day, colored by platform)
const dotPalette = ["var(--coral)", "var(--brand)", "var(--green)", "var(--plum)", "var(--pink)"];
const calDays = [1, 0, 2, 1, 3, 0, 1, 2, 0, 1, 3, 1, 0, 2, 1, 2, 0, 3, 1, 0, 2, 1, 0, 2, 1, 3, 1, 0];
// Hero slide 2 — editor waveform bar heights
const wave = [30, 55, 40, 70, 48, 82, 60, 38, 66, 52, 78, 44, 90, 58, 34, 72, 50, 64, 42, 86, 56, 30, 68, 46];
// Hero slide 3 — engagement feed (auto-scrolls through the thread)
const comments = [
  { who: "@jenna_m", txt: "Does this actually help with anxiety?" },
  { reply: true, who: "Replied in your voice", txt: "Great question. Here's what the research shows, and where to start.", badge: "2 min" },
  { who: "@marktrains", txt: "How do I work with you?", lead: true },
  { who: "@sophie.k", txt: "Saving this to try this week." },
  { reply: true, who: "Replied in your voice", txt: "Love that. Start with the first step and tell me how it goes.", badge: "1 min" },
  { who: "@dan_wole", txt: "Is there something for total beginners?" },
];
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container hero__wrap">
      <div class="herocar" data-carousel data-reveal>
        <div class="herocar__vp">
          <div class="herocar__track" data-track>

            <!-- Slide 1: volume + everywhere -->
            <article class="hslide is-active">
              <div class="hslide__inner">
                <span class="eyebrow eyebrow--star eyebrow--ondark">The content studio for experts</span>
                <h1 class="hslide__title">350+ posts a month.<br />Everywhere your audience is.</h1>
                <p class="hslide__lead">
                  One recording becomes 120+ original pieces and 350+ posts a month, published
                  across up to 13 platforms in one voice. Researched and made by real people.
                  Zero AI slop.
                </p>
                <div class="hslide__actions">
                  <a href="/contact" class="btn btn--pink">Book a call<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
                  <a href="/what-we-do" class="btn btn--ghost btn--ghost-dark">What we do</a>
                </div>
              </div>
              <div class="hslide__visual" aria-hidden="true">
                <div class="chrome cal glass">
                  <div class="chrome__bar">
                    <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
                    <span class="chrome__url">Content calendar · this month</span>
                  </div>
                  <div class="cal__body">
                    <div class="cal__week">
                      {["M", "T", "W", "T", "F", "S", "S"].map((d) => <span class="cal__dow">{d}</span>)}
                    </div>
                    <div class="cal__grid">
                      {calDays.map((n, i) => (
                        <span class={`cal__day cal__day--${i + 1}`}>
                          <span class="cal__num">{i + 1}</span>
                          <span class="cal__dots">
                            {Array.from({ length: n }).map((_, k) => (
                              <i style={`background:${dotPalette[(i + k) % dotPalette.length]}`}></i>
                            ))}
                          </span>
                          {[3, 12, 18, 24].includes(i + 1) && (
                            <i
                              class="cal__post"
                              style={`background:${dotPalette[(i + 1) % dotPalette.length]}`}
                            ></i>
                          )}
                        </span>
                      ))}
                      <span class="cal__cursor" aria-hidden="true">
                        <svg viewBox="0 0 12 12" width="12" height="12">
                          <path d="M1 1 L1 10 L4 7.5 L6 11 L7.5 10 L5.5 6.7 L9.5 6.7 Z"></path>
                        </svg>
                      </span>
                    </div>
                  </div>
                </div>
                <div class="herofloat glass--light">
                  <span class="herofloat__num">350<span class="herofloat__u">+</span></span>
                  <span class="herofloat__lab">posts scheduled</span>
                </div>
              </div>
            </article>

            <!-- Slide 2: podcasts + scripts + clipping -->
            <article class="hslide hslide--2">
              <div class="hslide__inner">
                <span class="eyebrow eyebrow--star eyebrow--ondark">Podcasts &amp; video</span>
                <h1 class="hslide__title">One recording.<br />Up to 50 clips.</h1>
                <p class="hslide__lead">
                  We write the scripts and you record once. Then we cut that long-form into
                  up to 50 vertical clips, captioned for every feed, so your voice keeps
                  showing up all month.
                </p>
                <div class="hslide__actions">
                  <a href="/method" class="btn btn--pink">See how it works<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
                  <a href="/what-we-do" class="btn btn--ghost btn--ghost-dark">What we do</a>
                </div>
              </div>
              <div class="hslide__visual" aria-hidden="true">
                <div class="chrome editor glass">
                  <div class="chrome__bar">
                    <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
                    <span class="chrome__url">ilai studio · editor</span>
                  </div>
                  <div class="editor__body">
                    <div class="editor__preview">
                      <span class="editor__play"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M5 3.5l7 4.5-7 4.5z"/></svg></span>
                      <span class="editor__tag">Episode 12 · full edit</span>
                    </div>
                    <div class="editor__wave">
                      {wave.map((h, i) => (
                        <span style={`--h:${h}%; --i:${i}`}></span>
                      ))}
                      <span class="editor__sel"></span>
                      <span class="editor__head"></span>
                    </div>
                    <div class="editor__clips">
                      <span class="editor__clip editor__clip--a">Clip 01</span>
                      <span class="editor__clip editor__clip--b">Clip 02</span>
                      <span class="editor__clip editor__clip--c">Clip 03</span>
                    </div>
                  </div>
                </div>
                <div class="herofloat glass--light">
                  <span class="herofloat__num">50<span class="herofloat__u"></span></span>
                  <span class="herofloat__lab">clips per recording</span>
                </div>
              </div>
            </article>

            <!-- Slide 3: engagement -->
            <article class="hslide hslide--3">
              <div class="hslide__inner">
                <span class="eyebrow eyebrow--star eyebrow--ondark">Engagement engine</span>
                <h1 class="hslide__title">We reply before<br />the algorithm cools.</h1>
                <p class="hslide__lead">
                  The first few minutes decide whether a post travels. A real team answers your
                  community in your voice and flags the leads worth your time.
                </p>
                <div class="hslide__actions">
                  <a href="/contact" class="btn btn--pink">Book a call<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
                  <a href="/work/dr-caroline-leaf" class="btn btn--ghost btn--ghost-dark">See the proof</a>
                </div>
              </div>
              <div class="hslide__visual" aria-hidden="true">
                <div class="chrome cmts glass">
                  <div class="chrome__bar">
                    <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
                    <span class="chrome__url">Engagement · in your voice</span>
                  </div>
                  <div class="cmts__body">
                    <div class="cmts__thread">
                      <div class="cmt cmt--ctx">
                        <span class="cmt__ava"></span>
                        <div class="cmt__txt"><b>@sophie.k</b><span>Saving this to try this week.</span></div>
                      </div>

                      <div class="cmt cmt--active">
                        <span class="cmt__ava"></span>
                        <div class="cmt__txt"><b>@marktrains</b><span>How do I work with you?</span></div>
                        <span class="cmt__badge cmt__badge--lead">Lead flagged</span>
                      </div>

                      <div class="cmt cmt--reply cmt--answer">
                        <span class="cmt__ava cmt__ava--ilai"></span>
                        <div class="cmt__txt">
                          <b>Replied in your voice</b>
                          <span class="cmt__typing" aria-hidden="true"><i></i><i></i><i></i></span>
                          <span class="cmt__reply-txt">Happy to help. Here's how to start.</span>
                        </div>
                        <span class="cmt__badge">1 min</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </article>

            <!-- Slide 4: newsletters + long-form -->
            <article class="hslide hslide--4">
              <div class="hslide__inner">
                <span class="eyebrow eyebrow--star eyebrow--ondark">Newsletters &amp; essays</span>
                <h1 class="hslide__title">Your best ideas,<br />made to keep.</h1>
                <p class="hslide__lead">
                  We turn your thinking into newsletters and essays people save, forward, and
                  subscribe to. It is how followers become a list you own.
                </p>
                <div class="hslide__actions">
                  <a href="/contact" class="btn btn--pink">Book a call<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
                  <a href="/what-we-do" class="btn btn--ghost btn--ghost-dark">What we do</a>
                </div>
              </div>
              <div class="hslide__visual" aria-hidden="true">
                <div class="chrome news glass">
                  <div class="chrome__bar">
                    <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
                    <span class="chrome__url">Substack · your newsletter</span>
                  </div>
                  <div class="news__body">
                    <span class="news__kicker">This week's essay</span>
                    <span class="news__title">The one idea your audience keeps coming back for</span>
                    <span class="news__lines">
                      <i></i><i></i><i style="width:82%"></i><i style="width:64%"></i>
                    </span>
                    <span class="news__sub">
                      <span class="news__sub-label news__sub-label--idle">Subscribe</span>
                      <span class="news__sub-label news__sub-label--done">
                        <svg class="news__check" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8.5l3.2 3.2L13 5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>Subscribed
                      </span>
                    </span>
                  </div>
                </div>
                <div class="herofloat glass--light">
                  <span class="herofloat__num">12<span class="herofloat__u">+</span></span>
                  <span class="herofloat__lab">essays a month</span>
                </div>
              </div>
            </article>

          </div>
        </div>

        <div class="herocar__nav">
          <div class="herocar__dots" data-dots>
            <button class="herocar__dot is-active" type="button" aria-label="Slide 1"></button>
            <button class="herocar__dot" type="button" aria-label="Slide 2"></button>
            <button class="herocar__dot" type="button" aria-label="Slide 3"></button>
            <button class="herocar__dot" type="button" aria-label="Slide 4"></button>
          </div>
          <div class="herocar__arrows">
            <button class="herocar__arrow" type="button" data-prev aria-label="Previous slide">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="herocar__arrow" type="button" data-next aria-label="Next slide">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Floating feature cards -->
      <div class="herofeatures">
        {features.map((f, i) => (
          <article class="feat" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="feat__ico" aria-hidden="true" style={`--ic:${f.c}`}>
              <svg width="21" height="21" viewBox="0 0 20 20" fill="none" set:html={f.icon} />
            </span>
            <div>
              <p class="feat__t">{f.t}</p>
              <p class="feat__s">{f.s}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="hero__logos" data-reveal>
        <PlatformStrip />
      </div>
    </div>
  </section>

  <!-- ============ WELCOME + CLIENT CARD ============ -->
  <section class="section welcome">
    <div class="container welcome__grid">
      <div class="welcome__copy" data-reveal>
