---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";

const platforms = [
  "YouTube",
  "Instagram",
  "TikTok",
  "Substack",
  "Facebook",
  "Threads",
  "X",
  "Bluesky",
  "LinkedIn",
];

const approach = [
  {
    title: "Decode your market",
    body: "We study your audience, your competitors, and what actually performs in your niche, then aim every piece at the people you sell to.",
  },
  {
    title: "Make original content",
    body: "Podcasts, reels, essays, and posts written in a voice we build with you. Researched and specific, never generic and never machine-guessed.",
  },
  {
    title: "Distribute everywhere",
    body: "One recording becomes a month of content, published across up to 13 platforms under one voice, with a live engagement engine.",
  },
];

const bars = [
  { p: "Instagram", v: "935K", pct: 100 },
  { p: "Facebook", v: "524K", pct: 62 },
  { p: "YouTube", v: "262K", pct: 34 },
  { p: "Threads", v: "203K", pct: 26 },
  { p: "TikTok", v: "20K", pct: 12 },
];

const stats = [
  { value: 205, suffix: "M+", label: "Impressions in 12 months" },
  { value: 7.9, decimals: 1, suffix: "M+", label: "Engagements earned" },
  { value: 90, suffix: "K+", label: "New followers" },
  { value: 228, suffix: "", label: "Posts every month" },
];

const expertise = [
  { n: "01", k: "Podcast production", d: "Full episode edits, clips, reels, long-form video, show notes, and SEO." },
  { n: "02", k: "Multi-platform publishing", d: "One idea, adapted and posted across up to 13 platforms under one voice." },
  { n: "03", k: "Audience research", d: "Your market, your competitors, and the people you actually sell to." },
  { n: "04", k: "Engagement engine", d: "First-response community engagement in the minutes that decide reach." },
];

const ArrowChip = `<svg width="18" height="18" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow eyebrow--star" data-reveal>Welcome to Ilai Collective</span>
      <h1 class="hero__title" data-reveal data-reveal-delay="1">
        We grow the audience
        <span class="hero__chip" aria-hidden="true" set:html={ArrowChip} />
        <span class="hero__grey">you'll sell to.</span>
      </h1>
      <p class="hero__lead" data-reveal data-reveal-delay="2">
        A human-led content studio for experts and personal brands. We learn your brand,
        your market, and your audience, then make original content that grows it. You film
        once. We make you impossible to ignore.
      </p>

      <!-- HERO CARD ROW -->
      <div class="herocards" data-reveal data-reveal-delay="3">
        <!-- Left: dark pitch card -->
        <article class="herocards__pitch card--dark">
          <span class="eyebrow eyebrow--star eyebrow--ondark">About the studio</span>
          <h2 class="herocards__h">
            Human-led.<br /><span class="herocards__hmuted">Human-gated.</span>
          </h2>
          <p class="herocards__p">
            A real US team sets your voice, writes your angles, and signs off on every piece.
            Sophisticated in-house software does the heavy lifting. People make every call.
          </p>
          <div class="herocards__actions">
            <a href="/contact" class="btn btn--signal">
              Book a call
              <span class="btn__arrow" aria-hidden="true" set:html={ArrowChip} />
            </a>
            <a href="/what-we-do" class="btn btn--ghost btn--ghost-dark">What we do</a>
          </div>
          <div class="herocards__mini">
            <div class="herocards__miniicon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M3 14l4-5 3 3 4-6 3 4" stroke="var(--amber)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div>
              <p class="herocards__minititle">One reel reached 543K</p>
              <p class="herocards__minisub">61K likes, 3.4K comments. No ad spend.</p>
            </div>
          </div>
        </article>

        <!-- Right: dashboard visual + floating metric cards -->
        <div class="herocards__visual">
          <div class="chrome herostage__mock">
            <div class="chrome__bar">
              <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
              <span class="chrome__url">drleaf.ilaicollective.com</span>
              <span class="herostage__live">Live</span>
            </div>
            <div class="chrome__body">
              <div class="hmock__tiles">
                <div class="hmock__tile">
                  <span class="hmock__tl">Impressions, 30d</span>
                  <span class="hmock__tv">27.1M</span>
                  <span class="hmock__tu">+18% MoM</span>
                </div>
                <div class="hmock__tile">
                  <span class="hmock__tl">Engagements, 30d</span>
                  <span class="hmock__tv">1.1M</span>
                  <span class="hmock__tu">+22% MoM</span>
                </div>
              </div>
              <div class="hmock__chart" aria-hidden="true">
                {[38, 52, 46, 68, 60, 82, 74, 96].map((h) => (
                  <span style={`--h:${h}%`}></span>
                ))}
              </div>
            </div>
          </div>
          <div class="herofloat herofloat--a">
            <span class="herofloat__num">+204<span class="herofloat__u">%</span></span>
            <span class="herofloat__lab">Reach, year over year</span>
            <span class="herofloat__note">↑ Compounding, not paid</span>
          </div>
          <div class="herofloat herofloat--b">
            <span class="herofloat__num">205M+</span>
            <span class="herofloat__lab">Impressions this year</span>
            <span class="herofloat__note">↑ Across 8 platforms</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Logo strip -->
    <div class="container">
      <p class="logostrip__label">We create, publish, and grow audiences across</p>
      <ul class="logostrip">
        {platforms.map((p) => <li class="logostrip__item">{p}</li>)}
      </ul>
    </div>
  </section>

  <!-- ============ APPROACH ============ -->
  <section class="section approach">
    <div class="container">
      <div class="approach__head" data-reveal>
        <span class="eyebrow eyebrow--star">Our approach</span>
        <h2 class="twotone">
          Human-led.<br /><span class="twotone__muted">Built on research.</span>
        </h2>
        <p class="lead center">
          We don't just make content. We build a system, backed by real research, so every
          post is aimed at the people you sell to.
        </p>
      </div>
      <div class="approach__grid">
        {approach.map((a, i) => (
          <article class="card card--hover appcard" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="appcard__n">{`0${i + 1}`}</span>
            <h3>{a.title}</h3>
            <p class="muted">{a.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ BENTO ============ -->
  <section class="section bento-sec">
    <div class="container">
      <div class="bento">
        <article class="card card--dark bento__a" data-reveal>
          <span class="eyebrow eyebrow--star eyebrow--ondark">One voice</span>
          <h3>Everywhere, on brand, on schedule</h3>
          <p class="herocards__p">
            One recording, adapted for each platform and posted for you. No copy-paste, no
            off-brand slip-ups.
          </p>
          <div class="toggle" aria-hidden="true">
            <span class="toggle__knob"></span>
            <span class="toggle__label">Autopilot posting: never on</span>
          </div>
        </article>

        <article class="card card--blue bento__b" data-reveal data-reveal-delay="1">
          <span class="eyebrow eyebrow--star eyebrow--ondark">The math</span>
          <p class="bento__big">1 <span class="bento__arrow">→</span> 30+</p>
          <p class="herocards__p">One 60-minute recording becomes 30-plus pieces of content across the month.</p>
        </article>

        <article class="card bento__c" data-reveal data-reveal-delay="2">
          <div class="bento__chead">
            <span class="bento__cnum" data-count="2" data-decimals="0" data-suffix="M">2M</span>
            <span class="eyebrow">Total following, 8 platforms</span>
          </div>
          <ul class="dotbars">
            {bars.map((b) => (
              <li class="dotbar">
                <span class="dotbar__p">{b.p}</span>
                <span class="dotbar__track"><span class="dotbar__fill" style={`--w:${b.pct}%`}></span></span>
                <span class="dotbar__v">{b.v}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="stats">
    <div class="container">
      <div class="stats__grid" data-reveal>
        {stats.map((s) => (
          <div class="stats__item">
            <div class="stats__num" data-count={s.value} data-decimals={s.decimals ?? 0} data-suffix={s.suffix ?? ""}>
              {s.value.toLocaleString("en-US", { minimumFractionDigits: s.decimals ?? 0, maximumFractionDigits: s.decimals ?? 0 }) + (s.suffix ?? "")}
            </div>
            <div class="stats__lab">{s.label}</div>
          </div>
        ))}
      </div>
      <p class="stats__src">
        12-month results for Dr. Caroline Leaf, managed by Ilai. <a href="/work/dr-caroline-leaf">See the full case study →</a>
      </p>
    </div>
  </section>

  <!-- ============ EXPERTISE (numbered, dark) ============ -->
  <section class="section expertise section--ink">
    <div class="container">
      <div class="expertise__head" data-reveal>
        <span class="eyebrow eyebrow--star eyebrow--ondark">What we do</span>
        <h2 class="twotone">
          One studio for your<br /><span class="twotone__muted">entire content operation.</span>
        </h2>
      </div>
      <div class="expertise__grid">
        {expertise.map((e, i) => (
          <div class="exp" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="exp__n">{e.n}</span>
            <h3 class="exp__k">{e.k}</h3>
            <p class="exp__d">{e.d}</p>
          </div>
        ))}
      </div>
      <div class="expertise__foot" data-reveal>
        <a href="/what-we-do" class="btn btn--signal">
          Explore every service
          <span class="btn__arrow" aria-hidden="true" set:html={ArrowChip} />
        </a>
      </div>
    </div>
  </section>

  <!-- ============ CASE STUDY TEASER ============ -->
  <section class="section casestudy">
    <div class="container">
      <article class="casestudy__box" data-reveal>
        <div class="casestudy__copy">
          <span class="eyebrow eyebrow--pill casestudy__pill">Case study</span>
          <h2 class="casestudy__title">Dr. Caroline Leaf</h2>
          <p class="lead">
            A neuroscientist and author with a serious message and no time to be everywhere.
            In 12 months her reach and engagement roughly tripled, in a year most accounts
            went backwards.
          </p>
          <ul class="casestudy__list">
            <li><strong>+204%</strong> reach, year over year</li>
            <li><strong>+210%</strong> engagement, year over year</li>
            <li><strong>8 platforms</strong> managed, zero on ads</li>
          </ul>
          <a href="/work/dr-caroline-leaf" class="btn btn--dark">
            Read the full story
            <span class="btn__arrow" aria-hidden="true" set:html={ArrowChip} />
          </a>
        </div>
        <div class="casestudy__panel" aria-hidden="true">
          <span class="casestudy__mlabel">Impressions, this year</span>
          <span class="casestudy__mval">205M+</span>
          <span class="casestudy__mnote">Industry average fell about 12%. She tripled.</span>
        </div>
      </article>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    padding-top: clamp(7.5rem, 15vh, 11rem);
    padding-bottom: var(--sp-12);
  }
  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero__title {
    margin-top: var(--sp-5);
    font-size: var(--fs-display);
    font-weight: 800;
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-display);
    max-width: 15ch;
  }
  .hero__grey {
    color: var(--muted);
  }
  .hero__chip {
    display: inline-grid;
    place-items: center;
    width: clamp(2.6rem, 4vw, 3.6rem);
    height: clamp(2.6rem, 4vw, 3.6rem);
    vertical-align: middle;
    margin: 0 0.2em;
    border-radius: 16px;
    background: var(--amber);
    color: var(--amber-ink);
    transform: rotate(-4deg);
    box-shadow: var(--shadow-card);
  }
  .hero__lead {
    margin-top: var(--sp-5);
    font-size: var(--fs-lead);
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 58ch;
  }

  /* Hero card row */
  .herocards {
    width: 100%;
    margin-top: var(--sp-10);
    display: grid;
    gap: var(--sp-5);
    text-align: left;
  }
  .herocards__pitch {
    padding: clamp(1.75rem, 3vw, 2.75rem);
    border-radius: var(--r-card-lg);
    display: flex;
    flex-direction: column;
  }
  .herocards__h {
    margin-top: var(--sp-4);
    font-size: clamp(1.9rem, 3vw, 2.6rem);
    font-weight: 800;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
    color: #fff;
  }
  .herocards__hmuted {
    color: rgba(255, 255, 255, 0.4);
  }
  .herocards__p {
    margin-top: var(--sp-4);
    color: var(--on-dark);
    font-size: var(--fs-sm);
    line-height: 1.6;
    max-width: 42ch;
  }
  .herocards__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
  .btn--ghost-dark {
    --btn-fg: #fff;
    border-color: rgba(255, 255, 255, 0.24);
  }
  .btn--ghost-dark:hover {
    background: rgba(255, 255, 255, 0.08);
  }
  .herocards__mini {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-top: auto;
    padding-top: var(--sp-6);
  }
  .herocards__miniicon {
    flex: none;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--on-dark-soft);
  }
  .herocards__minititle {
    color: #fff;
    font-weight: 600;
    font-size: var(--fs-sm);
  }
  .herocards__minisub {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
  }

  .herocards__visual {
    position: relative;
    border-radius: var(--r-card-lg);
    background:
      radial-gradient(120% 90% at 80% 10%, rgba(47, 107, 255, 0.14), transparent 60%),
      radial-gradient(120% 90% at 10% 90%, rgba(245, 179, 51, 0.18), transparent 60%),
      var(--sand);
    border: 1px solid var(--line);
    padding: clamp(1.25rem, 3vw, 2.5rem);
    display: grid;
    place-items: center;
    min-height: 340px;
  }
  .herostage__mock {
    width: 100%;
    max-width: 420px;
  }
  .herostage__live {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-accent);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue);
  }
  .herostage__live::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--blue);
    animation: pulse 2.4s var(--ease) infinite;
  }
  @keyframes pulse {
    70%, 100% { box-shadow: 0 0 0 7px rgba(47, 107, 255, 0); }
    0% { box-shadow: 0 0 0 0 rgba(47, 107, 255, 0.5); }
  }
  .hmock__tiles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-3);
  }
  .hmock__tile {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--sp-4);
    background: var(--mist);
    border: 1px solid var(--line);
    border-radius: 14px;
  }
  .hmock__tl { font-size: 0.72rem; color: var(--muted); }
  .hmock__tv { font-family: var(--font-accent); font-weight: 700; font-size: 1.4rem; letter-spacing: -0.02em; }
  .hmock__tu { font-size: 0.72rem; font-weight: 600; color: var(--blue); }
  .hmock__chart {
    display: flex;
    align-items: flex-end;
    gap: 7px;
    height: 84px;
    margin-top: var(--sp-3);
    padding: var(--sp-4);
    background: var(--mist);
    border: 1px solid var(--line);
    border-radius: 14px;
  }
  .hmock__chart span {
    flex: 1;
    height: var(--h);
    border-radius: 5px 5px 3px 3px;
    background: linear-gradient(180deg, var(--blue), #7aa0ff);
    opacity: 0.9;
  }
  .hmock__chart span:last-child { background: linear-gradient(180deg, var(--amber), #ffd27a); opacity: 1; }

  .herofloat {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 14px 18px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: var(--shadow-float);
  }
  .herofloat--a { top: 8%; right: -12px; animation: float 6s var(--ease) infinite alternate; }
  .herofloat--b { bottom: 8%; left: -12px; animation: float 6s var(--ease) 1.2s infinite alternate; }
  .herofloat__num { font-family: var(--font-accent); font-weight: 700; font-size: 1.5rem; letter-spacing: -0.03em; }
  .herofloat__u { color: var(--amber); }
  .herofloat__lab { font-size: 0.76rem; color: var(--muted); }
  .herofloat__note { font-size: 0.72rem; font-weight: 600; color: var(--blue); margin-top: 2px; }
  @keyframes float { to { transform: translateY(-9px); } }
  @media (prefers-reduced-motion: reduce) {
    .herofloat, .herostage__live::before { animation: none; }
  }

  @media (min-width: 940px) {
    .herocards {
      grid-template-columns: 1fr 1.05fr;
      gap: var(--sp-6);
      margin-top: var(--sp-12);
    }
  }
  @media (max-width: 560px) {
    .herofloat--a { right: 0; top: 2%; }
    .herofloat--b { left: 0; bottom: 2%; }
    .herofloat__num { font-size: 1.2rem; }
  }

  /* ---------- Logo strip ---------- */
  .logostrip__label {
    margin-top: var(--sp-12);
    text-align: center;
    font-family: var(--font-accent);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--muted);
  }
  .logostrip {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--sp-4) var(--sp-8);
    margin-top: var(--sp-5);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--line);
  }
  .logostrip__item {
    font-family: var(--font-accent);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--ink);
    opacity: 0.42;
    transition: opacity var(--dur-base) var(--ease);
  }
  .logostrip__item:hover { opacity: 0.9; }

  /* ---------- Approach ---------- */
  .approach__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-4);
  }
  .twotone {
    font-size: var(--fs-h2);
    font-weight: 800;
    letter-spacing: var(--tracking-tight);
    line-height: 1.05;
  }
  .twotone__muted { color: var(--muted); }
  .approach__grid {
    margin-top: var(--sp-10);
    display: grid;
    gap: var(--sp-5);
  }
  .appcard { display: flex; flex-direction: column; gap: var(--sp-3); }
  .appcard__n {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: var(--amber-ink);
    background: var(--amber-tint);
    width: 40px; height: 40px;
    display: grid; place-items: center;
    border-radius: 12px;
  }
  .appcard p { font-size: var(--fs-sm); }
  @media (min-width: 820px) {
    .approach__grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ---------- Bento ---------- */
  .bento {
    display: grid;
    gap: var(--sp-5);
  }
  .bento .card { display: flex; flex-direction: column; }
  .bento__big {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: clamp(3rem, 6vw, 4.5rem);
    letter-spacing: -0.04em;
    line-height: 1;
    margin: var(--sp-4) 0;
    color: #fff;
  }
  .bento__arrow { opacity: 0.6; }
  .bento .eyebrow { margin-bottom: var(--sp-3); }
  .bento h3 { font-size: var(--fs-h3); }
  .toggle {
    display: flex; align-items: center; gap: 10px;
    margin-top: auto; padding-top: var(--sp-5);
  }
  .toggle__knob {
    position: relative; width: 40px; height: 23px; border-radius: 999px;
    background: rgba(255,255,255,0.16); flex: none;
  }
  .toggle__knob::after {
    content: ""; position: absolute; top: 3px; left: 3px;
    width: 17px; height: 17px; border-radius: 50%; background: #fff;
  }
  .toggle__label { font-size: 0.82rem; color: rgba(255,255,255,0.6); }
  .bento__chead { display: flex; flex-direction: column; gap: 4px; margin-bottom: var(--sp-5); }
  .bento__cnum {
    font-family: var(--font-accent); font-weight: 700;
    font-size: clamp(2.4rem, 5vw, 3.2rem); letter-spacing: -0.03em; line-height: 1;
  }
  .dotbars { list-style: none; display: grid; gap: var(--sp-3); }
  .dotbar { display: grid; grid-template-columns: 5.5em 1fr auto; align-items: center; gap: var(--sp-3); }
  .dotbar__p { font-size: 0.82rem; color: var(--ink-2); }
  .dotbar__track { height: 8px; border-radius: 999px; background: var(--sand); overflow: hidden; }
  .dotbar__fill {
    display: block; height: 100%; width: var(--w);
    border-radius: 999px;
    background: linear-gradient(90deg, var(--blue), #6f95ff);
  }
