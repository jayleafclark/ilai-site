---
import Layout from "../../layouts/Layout.astro";
import CTASection from "../../components/CTASection.astro";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

// ---- Headline numbers (12 months) ----
const headline = [
  { value: 205, suffix: "M+", label: "Impressions in 12 months" },
  { value: 7.9, decimals: 1, suffix: "M+", label: "Engagements earned" },
  { value: 90, suffix: "K+", label: "New followers gained" },
  { value: 10.4, decimals: 1, suffix: "M+", label: "Video views" },
];

// ---- Year-over-year headline bars ----
const yoyBars = [
  {
    label: "Reach",
    pct: 204,
    note: "How many screens her content reached, this year against last.",
  },
  {
    label: "Engagement",
    pct: 210,
    note: "Likes, comments, shares, and saves, this year against last.",
  },
];

// ---- Per-platform YoY chips ----
const yoyChips = [
  { platform: "Facebook", metric: "reach", value: 359 },
  { platform: "Facebook", metric: "engagement", value: 549 },
  { platform: "Instagram", metric: "reach", value: 155 },
  { platform: "YouTube", metric: "views", value: 42 },
  { platform: "TikTok", metric: "followers", value: 39 },
];

// ---- Platform standing cards ----
const platforms = [
  {
    name: "Facebook",
    glyph: "facebook",
    stat: 523,
    suffix: "K",
    statLabel: "followers",
    lines: ["Up 28K this year", "76M impressions this year", "Reach up 359% year over year"],
  },
  {
    name: "Instagram",
    glyph: "instagram",
    stat: 932,
    suffix: "K",
    statLabel: "followers",
    lines: ["Up 46K this year", "129M impressions this year", "Her biggest single audience"],
    feature: true,
  },
  {
    name: "YouTube",
    glyph: "youtube",
    stat: 1.26,
    decimals: 2,
    suffix: "M",
    statLabel: "views",
    lines: ["100K watch hours", "11K new subscribers", "4.1% click-through rate"],
  },
  {
    name: "TikTok",
    glyph: "tiktok",
    stat: 39,
    prefix: "+",
    suffix: "%",
    statLabel: "follower growth",
    lines: ["Fastest-growing of her platforms", "Built from a standing start", "Followers up 39% year over year"],
  },
  {
    name: "X · Threads · Bluesky · Substack",
    glyph: "quartet",
    stat: 4,
    suffix: "",
    statLabel: "more platforms",
    lines: ["Her voice, adapted for each feed", "Written and published by people", "One idea, shaped for where it lands"],
  },
];

// ---- Why it worked ----
const reasons = [
  {
    k: "Researched, not guessed",
    d: "Every piece is grounded in her market, her audience of women 35 to 50, and what they actually respond to. Specific beats generic on every platform.",
    c: "var(--pink)",
    icon: `<circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="9" r="2" fill="currentColor"/>`,
  },
  {
    k: "A person signs off on everything",
    d: "A US team wrote her angles and signed off on every post before it went live. The software cleared the busywork so people kept judgment on the work that carried her name.",
    c: "var(--green)",
    icon: `<path d="M10 2l6 2.5v5c0 4-2.7 6.3-6 7.5-3.3-1.2-6-3.5-6-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M7.2 10l2 2 3.6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    k: "Everywhere, one voice",
    d: "One idea, adapted for eight platforms and posted in a single voice we built with her and hold to on every feed.",
    c: "var(--brand)",
    icon: `<circle cx="10" cy="10" r="2.2" fill="currentColor"/><path d="M5.5 5.5a6.5 6.5 0 000 9M14.5 5.5a6.5 6.5 0 010 9M3 3a10 10 0 000 14M17 3a10 10 0 010 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>`,
  },
  {
    k: "The first minutes decide",
    d: "An engagement engine answers her community in her voice in the first minutes, the window that decides whether a post travels or stalls.",
    c: "var(--plum)",
    icon: `<circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/><path d="M10 5.5V10l3 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
];

// ---- Growth chart data (indexed, last year = 100) ----
// Her line climbs to ~305; the industry line drifts down to ~86.
const herPts = [100, 118, 142, 160, 188, 214, 236, 258, 276, 292, 305];
const indPts = [100, 99, 97, 96, 94, 93, 91, 90, 89, 87, 86];
const W = 620;
const H = 260;
const PAD = 10;
const n = herPts.length;
const maxY = 320;
const xAt = (i: number) => PAD + (i / (n - 1)) * (W - PAD * 2);
const yAt = (v: number) => H - PAD - (v / maxY) * (H - PAD * 2);
const toPath = (pts: number[]) =>
  pts.map((v, i) => `${i === 0 ? "M" : "L"}${xAt(i).toFixed(1)} ${yAt(v).toFixed(1)}`).join(" ");
const herPath = toPath(herPts);
const indPath = toPath(indPts);
const herArea = `${herPath} L${xAt(n - 1).toFixed(1)} ${H - PAD} L${xAt(0).toFixed(1)} ${H - PAD} Z`;
const herLen = 1400; // approx path length for draw animation
const indLen = 1400;
---

<Layout
  title="Dr. Caroline Leaf: Ilai Collective case study"
  description="In 12 months Ilai grew Dr. Caroline Leaf to 205M+ impressions, 7.9M+ engagements, and 90K+ new followers across 8 platforms with zero ad spend. Reach up 204%, engagement up 210%, in a year the average account went backwards."
  path="/work/dr-caroline-leaf"
>
  <!-- ============ HERO ============ -->
  <section class="ds-hero">
    <div class="ds-hero__mesh" aria-hidden="true"></div>
    <div class="container ds-hero__inner">
      <div class="ds-hero__copy">
        <span class="eyebrow eyebrow--pill ds-pill" data-reveal>Case study</span>
        <h1 class="ds-hero__title" data-reveal data-reveal-delay="1">
          Dr. Caroline Leaf
        </h1>
        <p class="ds-hero__role" data-reveal data-reveal-delay="1">
          Neuroscientist, mental-health author, and podcast host.
        </p>
        <p class="ds-hero__lead" data-reveal data-reveal-delay="2">
          In 12 months her reach and engagement roughly tripled. In the same year most
          accounts went backwards. Ilai runs her entire content operation across eight
          platforms, with <span class="ds-hero__accent">zero spent on ads.</span>
        </p>
        <div class="ds-hero__actions" data-reveal data-reveal-delay="3">
          <a href="/contact" class="btn btn--pink">
            Get your free teardown<span class="btn__arrow" aria-hidden="true" set:html={arrow} />
          </a>
          <a href="/method" class="btn btn--ghost">See the method</a>
        </div>
        <div class="ds-hero__meta" data-reveal data-reveal-delay="3">
          <span class="ds-hero__metaitem">8 platforms</span>
          <span class="ds-hero__mdot" aria-hidden="true"></span>
          <span class="ds-hero__metaitem">12 months</span>
          <span class="ds-hero__mdot" aria-hidden="true"></span>
          <span class="ds-hero__metaitem">$0 on ads</span>
        </div>
      </div>

      <!-- Portrait: /work/dr-caroline-leaf.jpg -->
      <div class="ds-hero__portraitwrap" data-reveal data-reveal-delay="2">
        <figure class="ds-portrait">
          <span class="ds-portrait__ring" aria-hidden="true"></span>
          <img
            src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/work/dr-caroline-leaf.jpg`}
            alt="Dr. Caroline Leaf"
            class="ds-portrait__img"
            loading="eager"
            width="640"
            height="800"
            onerror="this.style.display='none'"
          />
          <div class="ds-portrait__fallback" aria-hidden="true">
            <span class="ds-portrait__mono">CL</span>
          </div>
        </figure>

        <!-- Floating stat chip over the photo -->
        <div class="ds-float" aria-hidden="true">
          <span class="ds-float__spark">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 12l3.5-4 2.5 2.5L13 4" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 4h-3M13 4v3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <div>
            <span class="ds-float__num">+210%</span>
            <span class="ds-float__lab">Engagement, year over year</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ HEADLINE NUMBERS BAND ============ -->
  <section class="ds-band">
    <div class="container">
      <div class="ds-band__grid">
        {
          headline.map((s, i) => (
            <div class="ds-stat" data-reveal data-reveal-delay={String((i % 4) + 1)}>
              <div
                class="ds-stat__num"
                data-count={s.value}
                data-decimals={s.decimals ?? 0}
                data-prefix={s.prefix ?? ""}
                data-suffix={s.suffix ?? ""}
              >
                {(s.prefix ?? "") + (s.decimals ? s.value.toFixed(s.decimals) : "0") + (s.suffix ?? "")}
              </div>
              <div class="ds-stat__label">{s.label}</div>
            </div>
          ))
        }
      </div>
      <p class="ds-band__source" data-reveal>
        Totals for the last 12 months, across Facebook, Instagram, YouTube, TikTok, X,
        Threads, Bluesky, and Substack. No paid promotion.
      </p>
    </div>
  </section>

  <!-- ============ YEAR OVER YEAR ============ -->
  <section class="section section--mist ds-yoy">
    <div class="container">
      <div class="ds-sechead" data-reveal>
        <span class="eyebrow eyebrow--dot ds-dot">Year over year</span>
        <h2 class="ds-sechead__title">She moved the opposite way from the industry.</h2>
        <p class="lead ds-sechead__lead">
          The cleanest like-for-like comparison, this year against last. Reach up 204%,
          engagement up 210%.
        </p>
      </div>

      <div class="ds-bars" data-reveal data-reveal-delay="1">
        {
          yoyBars.map((b) => (
            <div class="ds-bar">
              <div class="ds-bar__head">
                <span class="ds-bar__label">{b.label}</span>
                <span
                  class="ds-bar__pct"
                  data-count={b.pct}
                  data-prefix="+"
                  data-suffix="%"
                >+{b.pct}%</span>
              </div>
              <div class="ds-bar__track" role="img" aria-label={`${b.label} up ${b.pct}% year over year`}>
                <div class="ds-bar__base">
                  <span class="ds-bar__basetag">Last year</span>
                </div>
                <div class="ds-bar__fill" style={`--grow:${b.pct}`}>
                  <span class="ds-bar__filltag">This year</span>
                </div>
              </div>
              <p class="ds-bar__note muted">{b.note}</p>
            </div>
          ))
        }
      </div>

      <div class="ds-yoy__lower">
        <div class="ds-chips" data-reveal data-reveal-delay="2">
          <p class="ds-chips__title">Where the growth came from, by platform</p>
          <div class="ds-chips__grid">
            {
              yoyChips.map((c, i) => (
                <div class="ds-chip" style={`--d:${i * 80}ms`}>
                  <span class="ds-chip__val" data-count={c.value} data-prefix="+" data-suffix="%">+{c.value}%</span>
                  <span class="ds-chip__meta">
                    <strong>{c.platform}</strong> {c.metric}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============ THE CHALLENGE ============ -->
  <section class="section">
    <div class="container ds-challenge">
      <div class="ds-challenge__head" data-reveal>
        <span class="eyebrow eyebrow--dot ds-dot">The challenge</span>
        <h2 class="ds-challenge__title">
          A serious expert, eight platforms, and no time to be everywhere.
        </h2>
        <p class="lead ds-challenge__lead">
          Dr. Leaf reaches an audience that skews women 35 to 50 who come to her for careful,
          researched work on the mind. That audience is spread across eight platforms, each
          with its own format, rhythm, and voice. Showing up on all of them, every day, in her
          voice, is a second full-time job.
        </p>
        <p class="ds-challenge__answer">
          Generic agencies solve this with sameness: the same clip cut nine ways, captions that
          could belong to anyone. Ilai took on the whole operation instead, run on our Signal
          Method. We study her market, write in a voice we built with her, publish across all
          eight platforms, and answer her community in the minutes that matter, with people
          directing every call.
        </p>
      </div>

      <!-- Visual: her long-form fans out to eight platforms -->
      <div class="ds-fan" data-reveal data-reveal-delay="1" aria-hidden="true">
        <div class="ds-fan__card">
          <span class="ds-fan__src">
            <span class="ds-fan__srcic">
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><rect x="2.5" y="5" width="11" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 8.5L18 6v8l-4.5-2.5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
            </span>
            <span>
              <b>Her long-form</b>
              <i>turned into a month of content</i>
            </span>
          </span>
          <span class="ds-fan__pipe"></span>
          <div class="ds-fan__grid">
            {["Facebook","Instagram","YouTube","TikTok","X","Threads","Bluesky","Substack"].map((p, k) => (
              <span class="ds-fan__chip" style={`--d:${k * 90}ms`}>{p}</span>
            ))}
          </div>
          <div class="ds-fan__foot">
            <span class="ds-fan__dot"></span>
            One voice, eight feeds, published by people
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GROWTH CHART: DOWN vs UP ============ -->
  <section class="section section--mist">
    <div class="container">
      <div class="ds-sechead" data-reveal>
        <span class="eyebrow eyebrow--dot ds-dot">The divergence</span>
        <h2 class="ds-sechead__title">The field went down. She went up.</h2>
        <p class="lead ds-sechead__lead">
          Both lines start at the same point twelve months ago. One follows the industry
          average. The other is Dr. Leaf.
        </p>
      </div>

      <figure class="ds-graph" data-reveal data-reveal-delay="1">
        <div class="ds-graph__legend">
          <span class="ds-graph__key ds-graph__key--her">
            <span class="ds-graph__swatch"></span>Dr. Caroline Leaf
          </span>
          <span class="ds-graph__key ds-graph__key--ind">
            <span class="ds-graph__swatch"></span>Industry average
          </span>
        </div>
        <div class="ds-graph__plot">
          <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" role="img" aria-label="Dr. Leaf's reach roughly tripled over twelve months while the industry average declined">
            <defs>
              <linearGradient id="dsHerFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="var(--brand)" stop-opacity="0.38" />
                <stop offset="0.55" stop-color="var(--pink)" stop-opacity="0.16" />
                <stop offset="1" stop-color="var(--pink)" stop-opacity="0" />
              </linearGradient>
            </defs>
            <!-- gridlines -->
            {[0.25, 0.5, 0.75].map((g) => (
              <line x1={PAD} x2={W - PAD} y1={PAD + g * (H - PAD * 2)} y2={PAD + g * (H - PAD * 2)} stroke="var(--line-2)" stroke-width="1" stroke-dasharray="3 5" />
            ))}
            <path class="ds-graph__area" d={herArea} fill="url(#dsHerFill)" />
            <path class="ds-graph__ind" d={indPath} fill="none" stroke="var(--ink-2)" stroke-width="2.75" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="5 6" style={`--len:${indLen}`} />
            <path class="ds-graph__her" d={herPath} fill="none" stroke="var(--brand)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" style={`--len:${herLen}`} />
            <circle class="ds-graph__enddot" cx={xAt(n - 1)} cy={yAt(herPts[n - 1])} r="6" fill="var(--pink-ink)" />
          </svg>
          <span class="ds-graph__endtag ds-graph__endtag--her">+204% reach</span>
          <span class="ds-graph__endtag ds-graph__endtag--ind">-12% average</span>
          <span class="ds-graph__starttag">Same start · 12 months ago</span>
        </div>
        <figcaption class="ds-graph__cap muted">
          Reach indexed to 100 twelve months ago. Industry line reflects the 2025 average
          organic decline of roughly 12%.
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ PLATFORM BY PLATFORM ============ -->
  <section class="section">
    <div class="container">
      <div class="ds-sechead" data-reveal>
        <span class="eyebrow eyebrow--dot ds-dot">Platform by platform</span>
        <h2 class="ds-sechead__title">Where each audience stands now.</h2>
        <p class="lead ds-sechead__lead">
          Current standing across the eight platforms Ilai runs, all grown organically.
        </p>
      </div>

      <div class="ds-platforms">
        {
          platforms.map((p, i) => (
            <article
              class={`ds-pcard${p.feature ? " ds-pcard--feature" : ""}`}
              data-reveal
              data-reveal-delay={String((i % 3) + 1)}
            >
              <div class="ds-pcard__top">
                <span class="ds-pcard__glyph" aria-hidden="true">
                  {p.glyph === "facebook" && (
                    <svg viewBox="0 0 24 24" fill="none" width="22" height="22">
                      <path d="M14 8.5V7c0-.83.67-1.5 1.5-1.5H17M14 8.5H11.5M14 8.5V19M14 8.5H16.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" />
                    </svg>
                  )}
                  {p.glyph === "instagram" && (
                    <svg viewBox="0 0 24 24" fill="none" width="22" height="22">
                      <rect x="4" y="4" width="16" height="16" rx="5" stroke="currentColor" stroke-width="1.6" />
                      <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.6" />
                      <circle cx="16.5" cy="7.5" r="1.1" fill="currentColor" />
                    </svg>
                  )}
                  {p.glyph === "youtube" && (
                    <svg viewBox="0 0 24 24" fill="none" width="22" height="22">
                      <rect x="3" y="6" width="18" height="12" rx="3.5" stroke="currentColor" stroke-width="1.6" />
                      <path d="M10.5 9.5l4 2.5-4 2.5v-5z" fill="currentColor" />
                    </svg>
                  )}
                  {p.glyph === "tiktok" && (
                    <svg viewBox="0 0 24 24" fill="none" width="22" height="22">
                      <path d="M13 4v10.5a3.5 3.5 0 11-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                      <path d="M13 4c.5 2.5 2 4 4.5 4.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  )}
                  {p.glyph === "quartet" && (
                    <svg viewBox="0 0 24 24" fill="none" width="22" height="22">
                      <circle cx="8" cy="8" r="2.4" stroke="currentColor" stroke-width="1.6" />
                      <circle cx="16" cy="8" r="2.4" stroke="currentColor" stroke-width="1.6" />
                      <circle cx="8" cy="16" r="2.4" stroke="currentColor" stroke-width="1.6" />
                      <circle cx="16" cy="16" r="2.4" stroke="currentColor" stroke-width="1.6" />
                    </svg>
                  )}
                </span>
                <h3 class="ds-pcard__name">{p.name}</h3>
              </div>
              <div class="ds-pcard__stat">
                <span
                  class="ds-pcard__num"
                  data-count={p.stat}
                  data-decimals={p.decimals ?? 0}
                  data-prefix={p.prefix ?? ""}
                  data-suffix={p.suffix ?? ""}
                >
                  {(p.prefix ?? "") + (p.decimals ? p.stat.toFixed(p.decimals) : p.stat) + (p.suffix ?? "")}
                </span>
                <span class="ds-pcard__statlabel">{p.statLabel}</span>
              </div>
              <ul class="ds-pcard__lines">
                {p.lines.map((l) => <li>{l}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ WHY IT WORKED ============ -->
  <section class="section section--mist">
    <div class="container">
      <div class="ds-sechead" data-reveal>
        <span class="eyebrow eyebrow--dot ds-dot">Why it worked</span>
        <h2 class="ds-sechead__title">What actually drove the growth.</h2>
        <p class="lead ds-sechead__lead">
          The growth is not luck. It comes from four commitments baked into the Signal Method.
        </p>
      </div>
      <div class="ds-reasons">
        {
          reasons.map((r, i) => (
            <article class="ds-reason" data-reveal data-reveal-delay={String((i % 2) + 1)}>
              <span class="ds-reason__ico" style={`--ic:${r.c}`} aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 20 20" fill="none" set:html={r.icon} />
              </span>
              <div class="ds-reason__body">
                <span class="ds-reason__n">{String(i + 1).padStart(2, "0")}</span>
                <h3 class="ds-reason__k">{r.k}</h3>
                <p class="ds-reason__d muted">{r.d}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ INDUSTRY CONTEXT PULL-QUOTE (dark) ============ -->
  <section class="section ds-context-wrap">
    <div class="container">
      <div class="ds-context" data-reveal>
        <div class="ds-context__glow" aria-hidden="true"></div>
        <div class="ds-context__main">
          <span class="eyebrow eyebrow--pill ds-pill ds-context__pill">The context</span>
          <p class="ds-context__quote">
            Across the industry in 2025, the average account&rsquo;s reach fell about
            <span class="ds-context__hl">12%</span> and engagement dropped close to
            <span class="ds-context__hl">28%</span>. The typical Facebook page now reaches
            only 1 to 2% of its own followers. Against that, Dr. Leaf&rsquo;s reach and
            engagement roughly <span class="ds-context__hl">tripled</span>.
          </p>
          <p class="ds-context__foot">
            She grew at a size where most accounts flatten out, in a year the whole field
            shrank.
          </p>
        </div>
        <div class="ds-context__panel" aria-hidden="true">
          <div class="ds-ctx-row">
            <span class="ds-ctx-row__lab">Industry reach</span>
            <span class="ds-ctx-bar ds-ctx-bar--down"><span class="ds-ctx-bar__fill" style="--w:14%"></span></span>
            <span class="ds-ctx-row__v ds-ctx-row__v--down">-12%</span>
          </div>
          <div class="ds-ctx-row">
            <span class="ds-ctx-row__lab">Industry eng.</span>
            <span class="ds-ctx-bar ds-ctx-bar--down"><span class="ds-ctx-bar__fill" style="--w:9%"></span></span>
            <span class="ds-ctx-row__v ds-ctx-row__v--down">-28%</span>
          </div>
          <div class="ds-ctx-div"></div>
