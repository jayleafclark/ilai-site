    background: var(--coral-tint);
    color: var(--coral-ink);
  }

  /* ---- Mobile accordion (<=760px). Each service is a <details>; the summary is
     the tappable row (number + title), the body reveals paragraph + checklist.
     Desktop (>=760px) neutralises all of this below so the layout is unchanged. */
  .wwd-acc { display: block; }
  .wwd-acc__summary {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    min-height: 52px;
    padding: var(--sp-3) 0;
    list-style: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .wwd-acc__summary::-webkit-details-marker { display: none; }
  .wwd-acc__summary:focus-visible {
    outline: 2px solid var(--coral);
    outline-offset: 4px;
    border-radius: 8px;
  }
  /* On mobile the head (icon) is hidden to keep rows compact; the number leads. */
  .wwd-acc .wwd-svc__head { display: none; }
  .wwd-acc__summary .wwd-svc__title {
    flex: 1;
    margin-top: 0;
    max-width: none;
    font-size: clamp(1.15rem, 4.6vw, 1.4rem);
    line-height: 1.2;
    text-wrap: balance;
  }
  /* Number chip in front of the title on mobile */
  .wwd-acc__summary::before {
    content: attr(data-n);
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: var(--coral);
    flex: none;
    align-self: flex-start;
    margin-top: 3px;
  }
  .wwd-acc__chev {
    flex: none;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: var(--coral);
    background: var(--coral-tint);
    transition: transform var(--dur-base, 0.25s) var(--ease);
  }
  .wwd-acc[open] .wwd-acc__chev { transform: rotate(180deg); }
  .wwd-acc__body { padding-bottom: var(--sp-2); }
  .wwd-acc__body .wwd-svc__body { margin-top: 0; }

  /* Go two-column at tablet (760) so the viz sits beside the copy instead of
     leaving big side-voids in the full-width shell; widen the gap on desktop. */
  @media (min-width: 760px) {
    .wwd-svc__grid {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--sp-8);
      align-items: center;
    }
    .wwd-svc--alt .wwd-svc__copy { order: 2; }

    /* --- Desktop bypass: dissolve the accordion so the original stacked copy
       layout (head, title, body, checklist) renders exactly as before, always
       expanded and non-interactive. --- */
    .wwd-acc { display: block; }              /* stays the grid column */
    .wwd-acc__summary,
    .wwd-acc__body { display: contents; }     /* children flow as before */
    .wwd-acc .wwd-svc__head { display: flex; }
    .wwd-acc__summary { cursor: default; min-height: 0; padding: 0; }
    .wwd-acc__summary::before { content: none; }
    .wwd-acc__chev { display: none; }
    /* Restore the original title styling (font size/line-height come from the
       global h2 rule — revert the mobile overrides so desktop is untouched). */
    .wwd-acc__summary .wwd-svc__title {
      margin-top: var(--sp-5);
      max-width: 18ch;
      font-size: revert;
      line-height: revert;
      text-wrap: revert;
