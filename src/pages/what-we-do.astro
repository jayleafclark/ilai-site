</style>

<script>
  // Mobile accordion controller for the ten service blocks.
  // - Desktop (>=760px): every <details> is forced open and stays open, so the
  //   CSS `display:contents` bypass renders the original side-by-side layout.
  // - Mobile (<=760px): blocks start collapsed; opening one closes the others
  //   (single-open, nice-to-have) and hash links (#service-03) open + scroll.
  (() => {
    const accs = Array.from(
      document.querySelectorAll<HTMLDetailsElement>(".wwd-svc .wwd-acc"),
    );
    if (!accs.length) return;
    const desktop = window.matchMedia("(min-width: 760px)");

    const syncToViewport = () => {
      if (desktop.matches) {
        // Force-open on desktop; the layout is driven entirely by CSS.
        accs.forEach((d) => {
          d.open = true;
        });
      } else {
        // Mobile: open the first service by default so the pattern is obvious
        // and the section leads with real content; collapse the rest.
        accs.forEach((d, i) => {
          d.open = i === 0;
        });
      }
    };

    // Single-open behaviour on mobile only.
    accs.forEach((d) => {
      d.addEventListener("toggle", () => {
        if (desktop.matches || !d.open) return;
        accs.forEach((o) => {
          if (o !== d) o.open = false;
        });
      });
    });

    // Open the targeted service when arriving via #service-NN (any viewport).
    const openFromHash = () => {
      const id = location.hash.replace("#", "");
      if (!id) return;
      const section = document.getElementById(id);
      const d = section && section.querySelector<HTMLDetailsElement>(".wwd-acc");
      if (d && !desktop.matches) {
        d.open = true;
        d.querySelector<HTMLElement>(".wwd-acc__summary")?.scrollIntoView({
          block: "start",
          behavior: "smooth",
        });
      }
    };

    syncToViewport();
    if (desktop.addEventListener) {
      desktop.addEventListener("change", syncToViewport);
    } else {
      // Safari <14 fallback
      desktop.addListener(syncToViewport);
    }
    window.addEventListener("hashchange", openFromHash);
    openFromHash();
  })();
</script>
