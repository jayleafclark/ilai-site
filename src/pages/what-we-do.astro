  }
  @media (min-width: 1000px) {
    .wwd-svc__grid { gap: var(--sp-12); }
  }

  /* ---- Viz shell (colored / slate / white / dark variety) ---- */
  .wwd-viz {
    position: relative;
    min-height: 300px;
    display: flex;
    align-items: center;
