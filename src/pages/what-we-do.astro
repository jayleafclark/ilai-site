---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";
import PlatformStrip from "../components/PlatformStrip.astro";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

// Capability stat band (premium gradient icons, varied colors)
const stats = [
  {
    value: 120, suffix: "+", label: "Original pieces a month", c: "var(--coral)",
    icon: `<path d="M4 15.5L14 5.5l3.5 3.5L7.5 19H4v-3.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M12.5 7l3.5 3.5" stroke="currentColor" stroke-width="1.6"/>`,
  },
  {
    value: 350, suffix: "+", label: "Posts published a month", c: "var(--brand)",
    icon: `<path d="M3.5 11L19 4l-6 15-2.5-6-7-2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
  {
    value: 13, suffix: "+", label: "Platforms, one voice", c: "var(--green)",
    icon: `<rect x="3" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="12.5" y="3" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="3" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/><rect x="12.5" y="12.5" width="6.5" height="6.5" rx="1.6" stroke="currentColor" stroke-width="1.6"/>`,
  },
  {
    value: 8, suffix: "", label: "Engagement-engine platforms", c: "var(--plum)",
    icon: `<path d="M4 5.5h16v9H10l-4 3.5v-3.5H4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>`,
  },
];

// Eight services. tone drives the card surface (colored / slate / white variety).
// viz drives the unique mini mockup rendered in the media panel.
const services = [
  {
    n: "01",
    eyebrow: "Podcast production & scripts",
    title: "We write it, you record, we finish it.",
    body: "Before the camera rolls we write the episode scripts and shot lists so you always know what to say. Then you sit for one recording and we go to work: a clean long-form edit with filler and false starts cut, studio-grade sound design, dynamic motion graphics, burned-in captions, show notes, chapters, and six to twelve vertical clips hand-cut to carry the show across every feed all month. It is a lot of expert work. That is the point of hiring a studio.",
    bullets: [
      "Episode scripts and shot lists written before you film",
      "Full episode edit: filler removed, studio sound design, motion graphics, captions",
      "Long-form YouTube cut plus a standalone audio version",
      "Show notes, SEO title and description, chapter and ad-break timestamps",
      "Six to twelve vertical reels and clips cut from every episode",
    ],
    c: "var(--coral)", tone: "dark", viz: "wave",
    icon: `<path d="M10 2.5a3 3 0 013 3v5a3 3 0 11-6 0v-5a3 3 0 013-3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M4.5 9.5v.6a5.5 5.5 0 0011 0v-.6M10 15.6V18M7 18h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    n: "02",
    eyebrow: "Short-form & reels",
    title: "Scroll-stopping clips, in your voice",
    body: "Every episode is mined for its sharpest moments and cut into vertical clips built to travel. Each one gets a hook, captions, and a rhythm tuned to the platform it lands on, so the same idea earns attention on TikTok, Reels, and Shorts alike.",
    bullets: [
      "Six to twelve reels cut from every recording",
      "Hook, captions, and pacing tuned per platform",
      "Cut in your voice, never generic filler",
      "Fanned out across every short-form feed",
    ],
    c: "var(--plum)", tone: "terra", viz: "reel",
    icon: `<rect x="3.5" y="3.5" width="13" height="13" rx="3" stroke="currentColor" stroke-width="1.6"/><path d="M8.5 7.2l4 2.8-4 2.8z" fill="currentColor"/>`,
  },
  {
    n: "03",
    eyebrow: "Multi-platform publishing",
    title: "One idea, adapted for up to 13 platforms",
    body: "A post that lands on Instagram falls flat on LinkedIn. We take one idea and rewrite it for each platform's format, length, and audience, then publish it on a schedule built for your stage. Whether you are starting from zero followers or already have an audience, the cadence is tuned to one thing: finding you engagement. You show up daily on every channel without touching a scheduler.",
    bullets: [
      "YouTube, Instagram, TikTok, X, Threads, Bluesky, Facebook, LinkedIn, Substack, and Pinterest",
      "Format, caption, and hook rewritten per platform, never copy-pasted",
      "A bespoke posting schedule built for your stage, from zero followers to established",
      "One documented voice across every account, tuned toward engagement",
    ],
    c: "var(--brand)", tone: "slate", viz: "scheduler",
    icon: `<rect x="3" y="4.5" width="14" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M3 8h14M6.5 3v3M13.5 3v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    n: "04",
    eyebrow: "Audience, market & competitor research",
    title: "We aim every piece before we make it",
    body: "Before we make anything, we learn your world: who you sell to, what your competitors publish, and which hooks, formats, and topics are actually earning engagement in your niche right now. Then every script and caption is pointed at a real audience instead of guessed at. It starts with a free teardown, so you see the work before you commit a dollar.",
    bullets: [
      "A map of your audience: who they are, what they want, where they spend time",
      "A read on your competitors and the gaps they leave open",
      "The hooks, formats, and topics already proven to travel in your niche",
      "A free teardown before you commit a dollar",
    ],
    c: "var(--green)", tone: "white", viz: "chart",
    icon: `<circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.6"/><path d="M13.5 13.5L17.5 17.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M6.5 9.5l1.7 1.7L12 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    n: "05",
    eyebrow: "Brand, voice & templates",
    title: "A voice we document and a look that's unmistakably yours",
    body: "We learn how you actually sound and write it down, so every line reads like you on your best day. Then we build the look around it: on-brand templates matched to your exact typography and color, quote cards, carousel frames, thumbnails, content categories, and a hook library your whole feed pulls from. It holds up across 350 posts a month.",
    bullets: [
      "A documented voice guide, built with you and signed off by you",
      "On-brand templates matched to your exact typography and color",
      "Quote cards, carousel frames, and thumbnail systems that always look like you",
      "Named content categories and a growing hook library every post draws from",
    ],
    c: "var(--brand)", tone: "white", viz: "brand",
    icon: `<path d="M4 16l6-11 6 11M6.5 12h7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    n: "06",
    eyebrow: "Engagement engine",
    title: "The first minutes that decide if a post travels",
    body: "The first replies to a post shape how far it spreads. We answer your community in your voice across 8 platforms in those opening minutes, so momentum builds instead of stalling. Along the way we surface the intent signals hiding in your comments and DMs.",
    bullets: [
      "First-response replies in your voice across 8 platforms",
      "People replying in the opening minutes, when a post is still moving",
      "Buying-intent signals pulled from comments and DMs",
      "A community that reads as tended by a person, because it is",
    ],
    c: "var(--coral)", tone: "dark", viz: "alerts",
    icon: `<path d="M10 3a6 6 0 016 6v3l1.5 3H2.5L4 12V9a6 6 0 016-6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 16.5a2 2 0 004 0" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    n: "07",
    eyebrow: "SEO & GEO content",
    title: "Found by Google, cited by AI assistants",
    body: "We write keyword-researched articles built to rank, then add the layer that gets you quoted by AI. On-page SEO, structured data, and an llms.txt file mean the major assistants can find, read, and cite you when someone asks about your field.",
    bullets: [
      "Keyword-researched articles aimed at real search demand",
      "On-page SEO plus structured data for rich results",
      "An llms.txt file so assistants can read and cite your pages",
      "Found on Google and cited when someone asks about your field",
    ],
    c: "var(--green)", tone: "white", viz: "search",
    icon: `<circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.6"/><path d="M12.8 12.8L17.5 17.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    n: "08",
    eyebrow: "Newsletter & long-form essays",
    title: "Your best ideas, made to keep",
    body: "Some ideas deserve more than a caption. We turn your strongest thinking into Substack and newsletter essays a reader saves, forwards, and comes back to. It is the format that builds the deepest trust with the audience you are growing.",
    bullets: [
      "Long-form essays for Substack and your newsletter",
      "Built from the ideas already proving out in your short-form",
      "Written in your documented voice, edited to publish-ready",
      "The channel that turns followers into a subscriber list you own",
    ],
    c: "var(--plum)", tone: "terra", viz: "essay",
    icon: `<path d="M5 3.5h7l3 3v10a1 1 0 01-1 1H5a1 1 0 01-1-1v-12a1 1 0 011-1z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M7 9h6M7 12h6M7 15h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    n: "09",
    eyebrow: "Live analytics dashboard",
    title: "Watch it work in real time",
    body: "You get a branded portal where every number is pulled straight from the platform APIs and refreshed on the hour. No screenshots, no monthly slide deck, no waiting on a report. Open it whenever you want and see exactly what is moving.",
    bullets: [
      "A branded portal on your own subdomain",
      "Every metric pulled straight from the platform APIs",
      "Refreshed on the hour, never typed in by hand",
      "One view across every platform we run for you",
    ],
    c: "var(--brand)", tone: "dashboard", viz: "dashboard",
    icon: `<rect x="3" y="4" width="14" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M6.5 12.5v-2M10 12.5v-4M13.5 12.5v-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
  {
    n: "10",
    eyebrow: "Earned media & podcast guesting",
    title: "Booked on the shows your audience already trusts",
    body: "Beyond your own channels, we pitch and place you as a guest on podcasts and in press your buyers already follow. Hosts rank topic relevance over follower count, so guesting is one of the fastest ways to borrow an established audience and earn real links back to you. We build the target list, write the pitches in your voice, prep your talking points, and repurpose every appearance into clips and posts for your own feeds.",
    bullets: [
      "A target list of podcasts and outlets your audience already trusts",
      "Pitches written and sent in your voice",
      "Talking points and prep so every appearance lands",
      "Each appearance repurposed into clips and posts for your feeds",
    ],
    c: "var(--coral)", tone: "dark", viz: "wave",
    icon: `<path d="M10 2.5a3 3 0 013 3v5a3 3 0 11-6 0v-5a3 3 0 013-3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M4.5 9.5v.6a5.5 5.5 0 0011 0v-.6M10 15.6V18M7 18h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>`,
  },
];

const pricing = [
  {
    k: "Free teardown",
    v: "$0",
    d: "A read on your brand, market, and audience. Yours to keep whether or not we work together.",
  },
  {
    k: "Pilot month",
    v: "$1,950",
    d: "One month to watch the operation run on your account. Fully credited toward your first engagement.",
  },
  {
    k: "Engagements",
    v: "from $5,500/mo",
    d: "The full studio: research, production, publishing across up to 13 platforms, engagement, and your live dashboard.",
  },
];
---

<Layout
  title="What we do — Ilai Collective"
  description="Ilai Collective runs your entire content operation: podcast production, short-form and reels, publishing across up to 13 platforms, audience and competitor research, brand and voice, community engagement, SEO and GEO articles, newsletters, and a live analytics dashboard. Human-led, research-driven. Starts with a free teardown."
  path="/what-we-do"
>
  <!-- ============ HERO ============ -->
  <section class="wwd-hero">
    <div class="container">
      <div class="wwd-herocard" data-reveal>
        <div class="wwd-herocard__glow" aria-hidden="true"></div>
        <div class="wwd-herocard__inner">
          <span class="eyebrow eyebrow--star eyebrow--ondark">What we do</span>
          <h1 class="wwd-herocard__title">
            One studio for your entire<br /><span class="hl-gold">content operation.</span>
          </h1>
          <p class="wwd-herocard__lead">
            Ten services, one studio. We learn your audience and your voice, then turn one
            recording into 120+ original pieces a month, published across up to 13 platforms
            and measured on a dashboard you can watch live. People direct, judge, and sign off
            on every piece. Sophisticated software and engines just let us move fast.
          </p>
          <div class="wwd-herocard__actions">
            <a href="/contact" class="btn btn--pink">
              Book a call<span class="btn__arrow" aria-hidden="true" set:html={arrow} />
            </a>
            <a href="#services" class="btn btn--ghost btn--ghost-dark">See every service</a>
          </div>
        </div>
        <div class="wwd-herocard__visual" aria-hidden="true">
          <div class="chrome wwd-hmock">
            <div class="chrome__bar">
              <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
              <span class="chrome__url">one recording · fanned out</span>
            </div>
            <div class="chrome__body">
              <div class="wwd-hmock__src">
                <span class="wwd-hmock__srcdot"></span>
                <span class="wwd-hmock__srctx">1 recording</span>
              </div>
              <div class="wwd-hmock__grid">
                {["a","b","c","a","c","b","b","a","c","b","a","c"].map((t) => (
                  <span class={`wwd-hmock__cell wwd-hmock__cell--${t}`}></span>
                ))}
              </div>
              <div class="wwd-hmock__foot">
                <span class="wwd-hmock__pill">Scheduled</span>
                <span class="wwd-hmock__note">350+ posts / month</span>
              </div>
            </div>
          </div>
          <div class="wwd-herofloat glass--light">
            <span class="wwd-herofloat__num">30<span class="wwd-herofloat__u">+</span></span>
            <span class="wwd-herofloat__lab">pieces per recording</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CAPABILITY STAT BAND ============ -->
  <section class="wwd-statsec">
    <div class="container">
      <div class="wwd-statpanel" data-reveal>
        {stats.map((s) => (
          <div class="wwd-statp">
            <span class="wwd-statp__ico" aria-hidden="true" style={`--ic:${s.c}`}>
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none" set:html={s.icon} />
            </span>
            <div>
              <div class="wwd-statp__num" data-count={s.value} data-decimals="0" data-suffix={s.suffix}>
                {s.value.toLocaleString("en-US") + s.suffix}
              </div>
              <div class="wwd-statp__lab">{s.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SERVICE INDEX STRIP ============ -->
  <section class="wwd-index" id="services">
    <div class="container">
      <ol class="wwd-index__list" data-reveal>
        {services.map((s) => (
          <li class="wwd-index__item">
            <a href={`#service-${s.n}`}>
              <span class="wwd-index__n">{s.n}</span>
              <span class="wwd-index__k">{s.eyebrow}</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ============ SERVICES (one detailed block each) ============ -->
  {services.map((s, i) => (
    <section
      class={`section wwd-svc ${i % 2 === 1 ? "section--mist" : ""}`}
      id={`service-${s.n}`}
    >
      <div class="container wwd-svc__grid">
        <div class="wwd-svc__copy" data-reveal>
          <div class="wwd-svc__head">
            <span class="wwd-svc__ico" aria-hidden="true" style={`--ic:${s.c}`}>
              <svg width="21" height="21" viewBox="0 0 20 20" fill="none" set:html={s.icon} />
            </span>
            <div class="wwd-svc__headtx">
              <span class="wwd-svc__n">{s.n}</span>
              <span class="eyebrow eyebrow--dot">{s.eyebrow}</span>
            </div>
          </div>
          <h2 class="wwd-svc__title">{s.title}</h2>
          <p class="lead wwd-svc__body">{s.body}</p>
          <ul class="wwd-svc__list">
            {s.bullets.map((b) => (
              <li>
                <span class="wwd-svc__check" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2.5 7.5L6 11L11.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="wwd-svc__aside" data-reveal data-reveal-delay="1">
          <div class={`wwd-viz wwd-viz--${s.tone}`}>
            <span class="wwd-viz__tag">{`0${i + 1}`.slice(-2)}</span>

            {s.viz === "wave" && (
              <div class="wwd-vwave">
                {[12,26,44,30,58,38,66,48,32,54,26,42,18,50,30,60,40,24].map((h) => (
                  <span style={`--h:${h}px`}></span>
                ))}
              </div>
            )}

            {s.viz === "reel" && (
              <div class="wwd-vreel">
                <span class="wwd-vreel__phone">
                  <span class="wwd-vreel__play">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M5 3.5l7 4.5-7 4.5z"/></svg>
                  </span>
                  <span class="wwd-vreel__cap"></span>
                  <span class="wwd-vreel__cap wwd-vreel__cap--s"></span>
                  <span class="wwd-vreel__prog"><i></i></span>
                </span>
                <span class="wwd-vreel__side">
                  <span></span><span></span><span></span>
                </span>
              </div>
            )}

            {s.viz === "scheduler" && (
              <div class="wwd-vsched">
                <div class="wwd-vsched__cols">
                  {["Mon","Tue","Wed","Thu","Fri"].map((d) => <span>{d}</span>)}
                </div>
                <div class="wwd-vsched__grid">
                  {["a","b","","c","a","","c","a","b","b","","c","a","c","b","","b","a","c",""].map((t) => (
                    <span class={t ? `wwd-vsched__cell wwd-vsched__cell--${t}` : "wwd-vsched__cell is-empty"}></span>
                  ))}
                </div>
              </div>
            )}

            {s.viz === "chart" && (
              <div class="wwd-vchart">
                <div class="wwd-vchart__bars">
                  {[{p:88,c:"var(--coral)"},{p:64,c:"var(--brand)"},{p:100,c:"var(--green)"},{p:48,c:"var(--plum)"}].map((b) => (
                    <span class="wwd-bar"><i style={`--w:${b.p}%;background:${b.c}`}></i></span>
                  ))}
                </div>
                <div class="wwd-vchart__legend">
                  <span>Audience</span><span>Competitors</span><span>Proven hooks</span><span>Gaps</span>
                </div>
              </div>
            )}

            {s.viz === "brand" && (
              <div class="wwd-vbrand">
                <div class="wwd-vbrand__swatches">
                  {["var(--coral)","var(--charcoal)","var(--brand)","var(--green)","var(--plum)"].map((c) => (
                    <span style={`background:${c}`}></span>
                  ))}
                </div>
                <div class="wwd-vbrand__type">
                  <span class="wwd-vbrand__aa">Aa</span>
                  <div class="wwd-vbrand__lines">
                    <span></span><span></span><span class="wwd-vbrand__lines--s"></span>
                  </div>
                </div>
              </div>
            )}

            {s.viz === "alerts" && (
              <div class="wwd-valerts">
                <div class="wwd-valert"><span class="wwd-valert__dot" style="background:var(--green)"></span><div><b>Replied to a comment</b><span>Instagram · 2 min</span></div></div>
                <div class="wwd-valert"><span class="wwd-valert__dot" style="background:var(--brand)"></span><div><b>First-response sent</b><span>TikTok · in your voice</span></div></div>
                <div class="wwd-valert"><span class="wwd-valert__dot" style="background:var(--plum)"></span><div><b>Intent signal flagged</b><span>from a DM · sent to you</span></div></div>
              </div>
            )}

            {s.viz === "search" && (
              <div class="wwd-vsearch">
                <div class="wwd-vsearch__bar">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="4.5" stroke="currentColor" stroke-width="1.5"/><path d="M10.5 10.5L14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  <span class="wwd-vsearch__q"></span>
                </div>
                <div class="wwd-vsearch__result">
                  <span class="wwd-vsearch__badge">Cited</span>
                  <span class="wwd-vsearch__title"></span>
                  <span class="wwd-vsearch__url"></span>
                  <span class="wwd-vsearch__snip"></span>
                  <span class="wwd-vsearch__snip wwd-vsearch__snip--s"></span>
                </div>
              </div>
            )}

            {s.viz === "essay" && (
              <div class="wwd-vessay">
                <span class="wwd-vessay__kicker">The newsletter</span>
                <span class="wwd-vessay__h"></span>
                <span class="wwd-vessay__h wwd-vessay__h--s"></span>
                <div class="wwd-vessay__body">
                  <span></span><span></span><span></span><span class="wwd-vessay__body--s"></span>
                </div>
                <div class="wwd-vessay__foot">
                  <span class="wwd-vessay__save">Saved</span>
                  <span class="wwd-vessay__meta">6 min read</span>
                </div>
              </div>
            )}

            {s.viz === "dashboard" && (
              <div class="wwd-vdash">
                <div class="wwd-vdash__bar">
                  <span class="chrome__dot"></span><span class="chrome__dot"></span><span class="chrome__dot"></span>
                  <span class="wwd-vdash__url">yourbrand.ilaicollective.com</span>
                </div>
                <div class="wwd-vdash__body">
                  <div class="wwd-vdash__stats">
                    <div class="wwd-vdash__stat">
                      <span class="wwd-vdash__lbl">Posts this month</span>
                      <span class="wwd-vdash__num"><span data-count="350" data-suffix="+" data-decimals="0">0</span></span>
                    </div>
                    <div class="wwd-vdash__stat">
                      <span class="wwd-vdash__lbl">Platforms live</span>
                      <span class="wwd-vdash__num"><span data-count="13" data-decimals="0">0</span></span>
                    </div>
                  </div>
                  <div class="wwd-vdash__chart">
                    {[38,52,44,67,59,81,73,96].map((h) => <span style={`height:${h}%`}></span>)}
                  </div>
