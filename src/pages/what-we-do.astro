    border-radius: var(--r-card-lg);
  }
  .wwd-statp {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .wwd-statp__ico {
    flex: none;
    display: grid;
    place-items: center;
    width: 50px;
    height: 50px;
    border-radius: 15px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.5), 0 10px 20px -8px var(--ic);
  }
  .wwd-statp__num {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
