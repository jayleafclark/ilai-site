    box-shadow: var(--shadow-card);
  }
  .wwd-viz__tag {
    position: absolute;
    top: var(--sp-5);
    left: var(--sp-6);
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    z-index: 2;
  }
  .wwd-viz--dark {
    background:
      radial-gradient(80% 110% at 82% 12%, rgba(201, 162, 92, 0.28), transparent 60%),
      linear-gradient(150deg, var(--charcoal), var(--charcoal-2));
  }
  .wwd-viz--dark .wwd-viz__tag { color: rgba(255, 255, 255, 0.55); }
  .wwd-viz--slate {
    background: linear-gradient(150deg, var(--slate), var(--slate-2));
  }
  .wwd-viz--slate .wwd-viz__tag { color: rgba(255, 255, 255, 0.5); }
  .wwd-viz--terra {
    background: linear-gradient(150deg, var(--plum), color-mix(in srgb, var(--plum) 70%, #fff));
  }
  .wwd-viz--terra .wwd-viz__tag { color: rgba(255, 255, 255, 0.7); }
  .wwd-viz--white {
    background: var(--paper);
    border: 1px solid var(--line);
  }
  .wwd-viz--white .wwd-viz__tag { color: var(--line-2); }
  .wwd-viz--dashboard {
    background: linear-gradient(150deg, var(--mist), var(--sand));
  }
  .wwd-viz--dashboard .wwd-viz__tag { color: rgba(29, 42, 35, 0.24); }

  /* Podcast waveform */
  .wwd-vwave {
    display: flex;
    align-items: center;
    gap: 5px;
    height: 120px;
  }
  .wwd-vwave span {
    width: 5px;
    height: var(--h);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    transform-origin: center;
    animation: wwd-wave 1.6s var(--ease) infinite;
  }
  /* Five phase buckets so neighbouring bars never bottom out together — reads as
     live audio levels moving under a playhead, not a uniform pulse. */
  .wwd-vwave span:nth-child(5n)   { animation-delay: -0.2s; opacity: 0.75; }
  .wwd-vwave span:nth-child(5n+1) { animation-delay: -0.6s; opacity: 0.9;  }
  .wwd-vwave span:nth-child(5n+2) { animation-delay: -1.0s; opacity: 0.8;  }
  .wwd-vwave span:nth-child(5n+3) { animation-delay: -1.4s; opacity: 0.95; }
  .wwd-vwave span:nth-child(5n+4) { animation-delay: -0.8s; opacity: 0.7;  }
  @keyframes wwd-wave {
    0%, 100% { transform: scaleY(1); }
    50%      { transform: scaleY(0.4); }
  }

  /* Earned media / guesting: outlet rows whose status flips Pitched -> Booked on reveal */
  .wwd-vguest { width: 100%; max-width: 300px; display: grid; gap: 10px; }
  .wwd-vguest__row {
    display: flex; align-items: center; gap: 11px;
    padding: 11px 13px; border-radius: 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    opacity: 0;
    transform: translateX(12px);
    transition: opacity var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
  }
  .is-visible .wwd-vguest__row { opacity: 1; transform: none; }
  .wwd-vguest__row:nth-child(1) { transition-delay: 80ms; }
  .wwd-vguest__row:nth-child(2) { transition-delay: 200ms; }
  .wwd-vguest__row:nth-child(3) { transition-delay: 320ms; }
  .wwd-vguest__badge {
    flex: none; display: grid; place-items: center;
    width: 30px; height: 30px; border-radius: 9px;
    color: #fff;
    background: linear-gradient(140deg, var(--g), color-mix(in srgb, var(--g) 55%, #ffffff));
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.5);
  }
  .wwd-vguest__txt { flex: 1; min-width: 0; display: grid; gap: 1px; }
  .wwd-vguest__txt b {
    font-size: 0.78rem; font-weight: 600; color: #fff;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .wwd-vguest__txt span { font-size: 0.66rem; color: rgba(255, 255, 255, 0.55); }
  .wwd-vguest__status { flex: none; position: relative; display: grid; }
  /* Pitched and Booked share the same cell; Booked cross-fades in on reveal */
  .wwd-vguest__pitched,
  .wwd-vguest__booked {
    grid-area: 1 / 1;
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 9px; border-radius: 999px;
    font-family: var(--font-accent); font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    transition: opacity var(--dur-base) var(--ease);
  }
  .wwd-vguest__pitched {
    background: rgba(255, 255, 255, 0.12); color: rgba(255, 255, 255, 0.72);
    opacity: 1;
  }
  .wwd-vguest__booked {
    background: color-mix(in srgb, var(--green) 30%, transparent);
    color: color-mix(in srgb, var(--green) 55%, #ffffff);
    opacity: 0;
  }
  .is-visible .wwd-vguest__pitched { opacity: 0; }
  .is-visible .wwd-vguest__booked { opacity: 1; }
  /* status flips a beat after its row has landed */
  .wwd-vguest__row:nth-child(1) .wwd-vguest__pitched,
  .wwd-vguest__row:nth-child(1) .wwd-vguest__booked { transition-delay: 700ms; }
  .wwd-vguest__row:nth-child(2) .wwd-vguest__pitched,
  .wwd-vguest__row:nth-child(2) .wwd-vguest__booked { transition-delay: 950ms; }
  .wwd-vguest__row:nth-child(3) .wwd-vguest__pitched,
  .wwd-vguest__row:nth-child(3) .wwd-vguest__booked { transition-delay: 1200ms; }

  /* Reel card */
  .wwd-vreel { display: flex; align-items: center; gap: var(--sp-4); }
  .wwd-vreel__phone {
    position: relative;
    width: 120px;
    height: 210px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.34);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
    padding: 14px;
  }
  .wwd-vreel__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -60%);
    display: grid; place-items: center;
    width: 42px; height: 42px;
    border-radius: 50%;
    background: #fff;
    color: var(--plum);
    box-shadow: 0 8px 20px -8px rgba(0,0,0,0.4);
  }
  .wwd-vreel__cap {
    width: 100%; height: 7px; border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
  }
  .wwd-vreel__cap--s { width: 62%; align-self: flex-start; }
  .wwd-vreel__prog {
    width: 100%; height: 4px; border-radius: 999px;
    background: rgba(255, 255, 255, 0.28);
    overflow: hidden;
  }
  .wwd-vreel__prog i {
    display: block; height: 100%; width: 40%; border-radius: 999px;
    background: #fff;
    animation: wwd-prog 3.5s var(--ease) infinite;
  }
  @keyframes wwd-prog { 0% { width: 8%; } 100% { width: 96%; } }
  .wwd-vreel__side {
    display: flex; flex-direction: column; gap: 10px;
  }
  .wwd-vreel__side span {
    width: 34px; height: 34px; border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  /* Scheduler grid */
  .wwd-vsched { width: 100%; max-width: 300px; }
  .wwd-vsched__cols {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px;
    margin-bottom: 10px;
  }
  .wwd-vsched__cols span {
    text-align: center;
    font-family: var(--font-accent);
    font-size: 0.62rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }
  .wwd-vsched__grid {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px;
  }
  /* One-shot fill on reveal: cells scale + fade in across the week, then settle and stay. */
  .wwd-vsched__cell {
    aspect-ratio: 1; border-radius: 7px;
    display: grid; place-items: center;
    color: rgba(255, 255, 255, 0.92);
    opacity: 0;
    transform: scale(0.6);
    transition: opacity var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
  }
  .is-visible .wwd-vsched__cell { opacity: 1; transform: none; }
  .is-visible .wwd-vsched__cell.is-empty { opacity: 1; }
  /* stagger left-to-right, top-to-bottom (reading order) */
  .wwd-vsched__cell:nth-child(1) { transition-delay: 40ms; }
  .wwd-vsched__cell:nth-child(2) { transition-delay: 90ms; }
  .wwd-vsched__cell:nth-child(3) { transition-delay: 140ms; }
  .wwd-vsched__cell:nth-child(4) { transition-delay: 190ms; }
  .wwd-vsched__cell:nth-child(5) { transition-delay: 240ms; }
  .wwd-vsched__cell:nth-child(6) { transition-delay: 290ms; }
  .wwd-vsched__cell:nth-child(7) { transition-delay: 340ms; }
  .wwd-vsched__cell:nth-child(8) { transition-delay: 390ms; }
  .wwd-vsched__cell:nth-child(9) { transition-delay: 440ms; }
  .wwd-vsched__cell:nth-child(10) { transition-delay: 490ms; }
  .wwd-vsched__cell:nth-child(11) { transition-delay: 540ms; }
  .wwd-vsched__cell:nth-child(12) { transition-delay: 590ms; }
  .wwd-vsched__cell:nth-child(13) { transition-delay: 640ms; }
  .wwd-vsched__cell:nth-child(14) { transition-delay: 690ms; }
  .wwd-vsched__cell:nth-child(15) { transition-delay: 740ms; }
  .wwd-vsched__cell:nth-child(16) { transition-delay: 790ms; }
  .wwd-vsched__cell:nth-child(17) { transition-delay: 840ms; }
  .wwd-vsched__cell:nth-child(18) { transition-delay: 890ms; }
  .wwd-vsched__cell:nth-child(19) { transition-delay: 940ms; }
  .wwd-vsched__cell:nth-child(20) { transition-delay: 990ms; }
  .wwd-vsched__cell svg { opacity: 0.9; }
  .wwd-vsched__cell--a { background: color-mix(in srgb, var(--green) 62%, white); }
  .wwd-vsched__cell--b { background: color-mix(in srgb, var(--brand) 66%, white); }
  .wwd-vsched__cell--c { background: color-mix(in srgb, var(--coral) 56%, white); }
  .wwd-vsched__cell.is-empty {
    background: rgba(255, 255, 255, 0.07);
    border: 1px dashed rgba(255, 255, 255, 0.16);
  }

  /* Research chart (bars animate on reveal) */
  .wwd-vchart { width: 100%; max-width: 300px; }
  .wwd-vchart__bars {
    display: grid; gap: 14px;
  }
  .wwd-bar {
    display: block; height: 12px; border-radius: 999px;
    background: var(--mist);
    overflow: hidden;
  }
  .wwd-bar i {
    display: block; height: 100%; width: 0; border-radius: 999px;
    transition: width 1s var(--ease);
  }
  .is-visible .wwd-bar i { width: var(--w); }
  .wwd-vchart__legend {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 6px 14px; margin-top: 16px;
  }
  .wwd-vchart__legend span {
    font-size: 0.72rem; color: var(--muted);
  }

  /* Brand board: swatches snap into a locked row, type + template lines "fill in" on reveal */
  .wwd-vbrand { width: 100%; max-width: 300px; display: grid; gap: 18px; }
  .wwd-vbrand__swatches {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px;
  }
  .wwd-vbrand__swatches span {
    aspect-ratio: 1; border-radius: 10px;
    box-shadow: inset 0 1px 1px rgba(255,255,255,0.4);
    opacity: 0;
    transform: translateY(10px) scale(0.85);
    transition: opacity var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
  }
  .is-visible .wwd-vbrand__swatches span { opacity: 1; transform: none; }
  .wwd-vbrand__swatches span:nth-child(1) { transition-delay: 60ms; }
  .wwd-vbrand__swatches span:nth-child(2) { transition-delay: 120ms; }
  .wwd-vbrand__swatches span:nth-child(3) { transition-delay: 180ms; }
  .wwd-vbrand__swatches span:nth-child(4) { transition-delay: 240ms; }
  .wwd-vbrand__swatches span:nth-child(5) { transition-delay: 300ms; }
  .wwd-vbrand__type {
    display: flex; align-items: center; gap: 16px;
    padding: 16px; border-radius: 14px;
    background: var(--mist);
  }
  .wwd-vbrand__aa {
    font-family: var(--font-display); font-weight: 600; font-size: 2.6rem;
    line-height: 1; letter-spacing: -0.03em; color: var(--ink);
    opacity: 0;
    transform: scale(0.7);
    transition: opacity var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
    transition-delay: 340ms;
  }
  .is-visible .wwd-vbrand__aa { opacity: 1; transform: none; }
  .wwd-vbrand__lines { flex: 1; display: grid; gap: 8px; }
  .wwd-vbrand__lines span {
    height: 8px; border-radius: 999px; background: var(--line-2);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.6s var(--ease);
  }
  .is-visible .wwd-vbrand__lines span { transform: scaleX(1); }
  .wwd-vbrand__lines span:nth-child(1) { transition-delay: 420ms; }
  .wwd-vbrand__lines span:nth-child(2) { transition-delay: 520ms; }
  .wwd-vbrand__lines span:nth-child(3) { transition-delay: 620ms; }
  .wwd-vbrand__lines--s { width: 60%; }

  /* Engagement alerts */
  .wwd-valerts { width: 100%; max-width: 300px; display: grid; gap: 10px; }
  .wwd-valert {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 14px; border-radius: 14px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 8px 20px -12px rgba(10, 26, 20, 0.5);
    animation: wwd-alertcycle 5.4s var(--ease) infinite;
  }
  .wwd-valert:nth-child(1) { animation-delay: 0s; }
  .wwd-valert:nth-child(2) { animation-delay: 0.5s; }
  .wwd-valert:nth-child(3) { animation-delay: 1s; }
  @keyframes wwd-alertcycle {
    0% { opacity: 0; transform: translateX(14px); }
    9% { opacity: 1; transform: none; }
    86% { opacity: 1; transform: none; }
    97% { opacity: 0; transform: translateX(-8px); }
    100% { opacity: 0; }
  }
  .wwd-valert__dot { flex: none; width: 9px; height: 9px; border-radius: 50%; animation: wwd-dotblink 2.4s steps(1, end) infinite; }
  /* Steady "live/unread" indicator that blinks once per cycle, not a throb. */
  @keyframes wwd-dotblink { 0%, 86%, 100% { opacity: 1; } 90%, 96% { opacity: 0.25; } }
  .wwd-valert b { display: block; font-size: 0.82rem; color: var(--ink); font-weight: 600; }
  .wwd-valert span { font-size: 0.72rem; color: var(--muted); }

  /* SEO / GEO search snippet */
  .wwd-vsearch { width: 100%; max-width: 300px; display: grid; gap: 16px; }
  .wwd-vsearch__bar {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 14px; border-radius: 999px;
    background: var(--mist); color: var(--muted);
  }
  .wwd-vsearch__q {
    flex: 1; height: 8px; border-radius: 999px;
    background: var(--coral-soft); transform-origin: left;
    animation: wwd-type 3.8s steps(22) infinite;
  }
  @keyframes wwd-type { 0% { transform: scaleX(0.04); } 55% { transform: scaleX(1); } 92% { transform: scaleX(1); } 100% { transform: scaleX(0.04); } }
  .wwd-vsearch__result {
    display: grid; gap: 8px;
    padding: 16px; border-radius: 14px;
    background: var(--paper);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
  }
  .wwd-vsearch__badge {
    justify-self: start;
    padding: 3px 9px; border-radius: 999px;
    background: var(--green-tint); color: var(--coral-ink);
    font-family: var(--font-accent); font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    animation: wwd-badgeconfirm 6s var(--ease) infinite;
  }
  /* A status confirmation LANDING once per cycle: a brief press-in, then a ring
     flashes out and it rests — like a result just being confirmed/saved. */
  @keyframes wwd-badgeconfirm {
    0%, 70%, 100% { transform: scale(1);    box-shadow: 0 0 0 0 transparent; }
    78%           { transform: scale(0.94); box-shadow: 0 0 0 0 var(--green-tint); }
    86%           { transform: scale(1.05); box-shadow: 0 0 0 4px var(--green-tint); }
    93%           { transform: scale(1);    box-shadow: 0 0 0 9px transparent; }
  }
  @keyframes wwd-saveconfirm {
    0%, 74%, 100% { transform: scale(1);    box-shadow: 0 0 0 0 transparent; }
    82%           { transform: scale(0.94); box-shadow: 0 0 0 0 var(--plum-tint); }
    90%           { transform: scale(1.05); box-shadow: 0 0 0 4px var(--plum-tint); }
    97%           { transform: scale(1);    box-shadow: 0 0 0 9px transparent; }
  }
  .wwd-vsearch__title { height: 11px; width: 82%; border-radius: 999px; background: var(--coral); opacity: 0.85; }
  .wwd-vsearch__url { height: 7px; width: 46%; border-radius: 999px; background: var(--green); opacity: 0.6; }
  .wwd-vsearch__snip { height: 7px; width: 100%; border-radius: 999px; background: var(--line-2); }
  .wwd-vsearch__snip--s { width: 68%; }

  /* Essay / newsletter */
  .wwd-vessay {
    width: 100%; max-width: 280px;
    display: grid; gap: 10px;
    padding: 20px; border-radius: 16px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 14px 34px -20px rgba(10, 26, 20, 0.5);
  }
  .wwd-vessay__kicker {
    font-family: var(--font-accent); font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--plum);
  }
  .wwd-vessay__h { height: 13px; border-radius: 999px; background: var(--ink); opacity: 0.85; }
  .wwd-vessay__h--s { width: 64%; }
  .wwd-vessay__body { display: grid; gap: 7px; margin-top: 6px; }
  .wwd-vessay__body span { height: 7px; border-radius: 999px; background: var(--line-2); }
  .wwd-vessay__body--s { width: 74%; }
  .wwd-vessay__foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 8px; padding-top: 12px; border-top: 1px solid var(--line);
  }
  .wwd-vessay__save {
    padding: 3px 10px; border-radius: 999px;
    background: var(--plum-tint); color: var(--plum);
    font-family: var(--font-accent); font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    animation: wwd-saveconfirm 7s var(--ease) infinite;
  }
  .wwd-vessay__meta { font-size: 0.72rem; color: var(--muted); }

  /* Dashboard mock */
  .wwd-vdash {
    width: 100%; max-width: 340px;
    border-radius: 14px; overflow: hidden;
    background: var(--paper);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-float);
  }
  .wwd-vdash__bar {
    display: flex; align-items: center; gap: 7px;
    padding: 10px 14px;
    background: var(--mist);
    border-bottom: 1px solid var(--line);
  }
  .wwd-vdash__url {
    margin-left: 8px;
    font-family: var(--font-accent); font-size: 0.66rem;
    color: var(--muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .wwd-vdash__body { padding: 18px; display: grid; gap: 16px; }
  .wwd-vdash__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .wwd-vdash__lbl {
    font-family: var(--font-accent); font-size: 0.6rem;
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted);
  }
  .wwd-vdash__num {
    display: block; margin-top: 4px;
    font-family: var(--font-accent); font-weight: 700;
    font-size: 1.7rem; letter-spacing: -0.03em; line-height: 1;
    color: var(--ink); font-variant-numeric: tabular-nums;
  }
  .wwd-vdash__chart {
    display: flex; align-items: flex-end; gap: 6px; height: 72px;
  }
  .wwd-vdash__chart span {
    flex: 1; border-radius: 4px 4px 2px 2px;
    background: linear-gradient(180deg, var(--coral), var(--coral-soft));
    transform: scaleY(0.5); transform-origin: bottom;
    transition: transform 0.7s var(--ease);
  }
  /* once revealed, the chart keeps ticking like live data */
  .is-visible .wwd-vdash__chart span { animation: wwd-dashlive 2.6s var(--ease) infinite alternate; }
  @keyframes wwd-dashlive { from { transform: scaleY(0.5); } to { transform: scaleY(1); } }
  .wwd-vdash__chart span:nth-child(1) { animation-delay: -2.2s; }
  .wwd-vdash__chart span:nth-child(2) { animation-delay: -1.9s; }
  .wwd-vdash__chart span:nth-child(3) { animation-delay: -1.6s; }
  .wwd-vdash__chart span:nth-child(4) { animation-delay: -1.3s; }
  .wwd-vdash__chart span:nth-child(5) { animation-delay: -1s; }
  .wwd-vdash__chart span:nth-child(6) { animation-delay: -0.7s; }
  .wwd-vdash__chart span:nth-child(7) { animation-delay: -0.4s; }
  .wwd-vdash__chart span:nth-child(8) { animation-delay: -0.1s; background: linear-gradient(180deg, var(--charcoal-3), var(--coral)); }
  .wwd-vdash__foot {
    display: flex; align-items: center; gap: 10px;
    padding-top: 12px; border-top: 1px solid var(--line);
  }
  .wwd-vdash__live {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border-radius: 999px;
    background: var(--coral-tint); color: var(--coral-ink);
