    display: grid;
    gap: var(--sp-8);
    align-items: center;
  }
  .wwd-svc__head {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .wwd-svc__ico {
    flex: none;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.5), 0 10px 20px -8px var(--ic);
  }
  .wwd-svc__ico svg { stroke-width: 1.6; }
  .wwd-svc__headtx { display: flex; align-items: center; gap: var(--sp-3); }
  .wwd-svc__n {
    font-family: var(--font-accent);
    font-size: var(--fs-h3);
    font-weight: 700;
    color: var(--coral);
