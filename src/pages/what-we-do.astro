    background: rgba(255, 255, 255, 0.1);
  }
  /* Hero mock: 1 recording -> many */
  .wwd-hmock {
    max-width: 420px;
    margin-inline: auto;
  }
  .wwd-hmock__src {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: var(--r-pill);
    background: var(--coral);
    color: #fff;
  }
  .wwd-hmock__srcdot {
    width: 8px; height: 8px; border-radius: 50%; background: #fff;
    box-shadow: 0 0 0 4px rgba(255,255,255,0.28);
  }
  .wwd-hmock__srctx {
    font-family: var(--font-accent); font-weight: 700; font-size: 0.8rem;
  }
  .wwd-hmock__grid {
    margin-top: var(--sp-4);
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 7px;
  }
  .wwd-hmock__cell {
    aspect-ratio: 1;
    border-radius: 8px;
    opacity: 0;
    transform: scale(0.7);
    transition: opacity var(--dur-base) var(--ease), transform var(--dur-base) var(--ease);
  }
  .is-visible .wwd-hmock__cell { opacity: 1; transform: none; }
  .wwd-hmock__cell--a { background: color-mix(in srgb, var(--green) 60%, white); }
  .wwd-hmock__cell--b { background: color-mix(in srgb, var(--brand) 62%, white); }
  .wwd-hmock__cell--c { background: color-mix(in srgb, var(--plum) 55%, white); }
  .wwd-hmock__cell:nth-child(1) { transition-delay: 60ms; }
  .wwd-hmock__cell:nth-child(2) { transition-delay: 100ms; }
  .wwd-hmock__cell:nth-child(3) { transition-delay: 140ms; }
  .wwd-hmock__cell:nth-child(4) { transition-delay: 180ms; }
  .wwd-hmock__cell:nth-child(5) { transition-delay: 220ms; }
  .wwd-hmock__cell:nth-child(6) { transition-delay: 260ms; }
  .wwd-hmock__cell:nth-child(7) { transition-delay: 300ms; }
  .wwd-hmock__cell:nth-child(8) { transition-delay: 340ms; }
  .wwd-hmock__cell:nth-child(9) { transition-delay: 380ms; }
  .wwd-hmock__cell:nth-child(10) { transition-delay: 420ms; }
  .wwd-hmock__cell:nth-child(11) { transition-delay: 460ms; }
  .wwd-hmock__cell:nth-child(12) { transition-delay: 500ms; }
