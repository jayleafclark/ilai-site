  }
  .wwd-hmock__note { font-size: var(--fs-sm); color: var(--muted); }
  .wwd-herofloat {
    position: absolute;
    left: -20px;
    bottom: -18px;
    display: flex; flex-direction: column; gap: 2px;
    padding: 14px 18px;
    border-radius: 16px;
    animation: wwd-herotick 7s var(--ease) infinite;
  }
  .wwd-herofloat__num {
    font-family: var(--font-accent); font-weight: 700; font-size: 1.6rem;
    letter-spacing: -0.03em; color: var(--ink);
  }
  .wwd-herofloat__u { color: var(--coral); }
  .wwd-herofloat__lab { font-size: 0.74rem; color: var(--muted); }
  /* Chip holds still, then gives one discrete "counted" nudge each cycle, as if
     another piece was just logged to the tally. Not a float. */
  @keyframes wwd-herotick {
    0%, 82%   { transform: translateY(0) scale(1); }
    88%       { transform: translateY(-3px) scale(1.015); }
    94%, 100% { transform: translateY(0) scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wwd-herofloat { animation: none; }
    .wwd-hmock__cell { opacity: 1; transform: none; }
  }
  @media (min-width: 940px) {
    .wwd-herocard {
      grid-template-columns: 1.05fr 0.95fr;
      gap: var(--sp-12);
    }
