---
import Layout from "../layouts/Layout.astro";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<Layout title="Page not found · Ilai Collective" description="That page doesn't exist. Head back to Ilai Collective." path="/404">
  <section class="nf">
    <div class="container nf__inner">
      <span class="eyebrow eyebrow--pill">404</span>
      <h1 class="nf__title">This page went <span class="hl">off-script.</span></h1>
      <p class="lead nf__lead">
        The page you're after doesn't exist or has moved. Everything else is one click away.
      </p>
      <div class="nf__actions">
        <a href="/" class="btn btn--signal">Back to home<span class="btn__arrow" aria-hidden="true" set:html={arrow} /></a>
        <a href="/what-we-do" class="btn btn--ghost">What we do</a>
        <a href="/blog" class="btn btn--ghost">Read the blog</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .nf {
    min-height: 68vh;
    display: grid;
    place-items: center;
    padding-top: clamp(8rem, 16vh, 11rem);
    padding-bottom: var(--section-y);
  }
  .nf__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .nf__title {
    margin-top: var(--sp-5);
    font-size: var(--fs-h1);
    max-width: 18ch;
  }
  .nf__lead {
    margin-top: var(--sp-5);
    max-width: 46ch;
  }
  .nf__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-3);
    margin-top: var(--sp-8);
  }
</style>
