---
import Layout from "../../layouts/Layout.astro";
import CTASection from "../../components/CTASection.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });

const readingTime = (body: string) => {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 220));
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title="Blog · Ilai Collective"
  description="Notes on building an audience worth selling to. Practical writing on content systems, organic reach, and researched, human-led content from Ilai Collective."
  path="/blog"
>
  <!-- ============ HERO ============ -->
  <section class="bloghero">
    <div class="bloghero__mesh" aria-hidden="true"></div>
    <div class="container bloghero__inner">
      <span class="eyebrow eyebrow--pill" data-reveal>Blog</span>
      <h1 class="bloghero__title display" data-reveal data-reveal-delay="1">
        Notes on building an audience<br />worth <span class="bloghero__accent"
          >selling to.</span
        >
      </h1>
      <p class="lead bloghero__lead" data-reveal data-reveal-delay="2">
        Practical writing on content systems, organic reach, and the difference
        between researched content and filler. No hacks, no theory you can't use
        by Monday.
      </p>
    </div>
  </section>

  <!-- ============ POST GRID ============ -->
  <section class="section bloglist">
    <div class="container">
      <div class="grid grid-3 bloglist__grid">
        {
          posts.map((post, i) => (
            <a
              href={`/blog/${post.slug}`}
              class="card card--hover postcard"
              data-reveal
              data-reveal-delay={String((i % 3) + 1)}
            >
              {post.data.cover && (
                <span class="postcard__cover">
                  <img src={`${base}${post.data.cover}?v=3`} alt="" loading="lazy" width="1200" height="630" />
                </span>
              )}
              {post.data.tags?.[0] && (
                <span class="postcard__chip">{post.data.tags[0]}</span>
              )}
              <h2 class="postcard__title">{post.data.title}</h2>
              <p class="postcard__desc muted">{post.data.description}</p>
              <div class="postcard__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {fmtDate(post.data.pubDate)}
                </time>
                <span class="postcard__dot" aria-hidden="true">·</span>
                <span>{readingTime(post.body)} min read</span>
                <span class="postcard__arrow" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path
                      d="M3 11L11 3M11 3H5M11 3V9"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  /* ---------- Hero ---------- */
  .bloghero {
    position: relative;
    padding-top: clamp(8rem, 16vh, 12rem);
    padding-bottom: var(--sp-6);
    overflow: hidden;
  }
  .bloghero__mesh {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 70%;
    background:
      radial-gradient(40% 58% at 20% 16%, rgba(28, 107, 74, 0.16), transparent 70%),
      radial-gradient(36% 48% at 82% 10%, rgba(230, 169, 196, 0.28), transparent 72%);
    filter: blur(8px);
    animation: drift 22s var(--ease) infinite alternate;
    pointer-events: none;
  }
  @keyframes drift { to { transform: translate3d(0, 20px, 0) scale(1.05); } }
  @media (prefers-reduced-motion: reduce) { .bloghero__mesh { animation: none; } }
  .bloghero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .bloghero__title {
    margin-top: var(--sp-5);
    max-width: 20ch;
  }
  .bloghero__accent {
    color: var(--signal);
  }
  .bloghero__lead {
    margin-top: var(--sp-5);
    max-width: 58ch;
    text-align: center;
  }

  /* ---------- List ---------- */
  .bloglist {
    padding-top: var(--sp-10);
  }
  .bloglist__grid {
    align-items: stretch;
  }
  /* Tablet: the shared .grid-3 goes 3-up at 720px and cramps the cards
     (titles wrap 5-8 lines, meta wraps). Use 2-up until desktop. */
  @media (min-width: 561px) and (max-width: 899px) {
    .bloglist__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .postcard {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }
  .postcard__cover {
    display: block;
    margin: calc(-1 * var(--sp-6)) calc(-1 * var(--sp-6)) var(--sp-5);
    aspect-ratio: 1200 / 630;
    overflow: hidden;
    background: var(--mist);
    border-bottom: 1px solid var(--line);
  }
  .postcard__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--dur-slow) var(--ease);
  }
  .postcard:hover .postcard__cover img {
    transform: scale(1.04);
  }
  .postcard__chip {
    align-self: flex-start;
    font-family: var(--font-accent);
    font-size: var(--fs-eyebrow);
    font-weight: 500;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--signal-ink);
    background: var(--signal-tint);
    padding: 5px 11px;
    border-radius: var(--r-pill);
  }
  .postcard__title {
    margin-top: var(--sp-4);
    font-size: var(--fs-h3);
  }
  .postcard__desc {
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    line-height: 1.55;
  }
  .postcard__meta {
    margin-top: auto;
    padding-top: var(--sp-5);
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-accent);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .postcard__dot {
    color: var(--line-2);
  }
  .postcard__arrow {
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    margin-left: auto;
    border-radius: 50%;
    color: var(--signal);
    background: var(--signal-tint);
    transition: transform var(--dur-base) var(--ease);
  }
  .postcard:hover .postcard__arrow {
    transform: translate(3px, -3px);
  }

  /* ============================================================
     MOBILE (<=560px) — clean single column, comfy spacing.
     Desktop grid/layout untouched.
     ============================================================ */
  @media (max-width: 560px) {
    .bloghero {
      padding-top: clamp(6.5rem, 22vw, 9rem);
    }
    .bloghero__title {
      /* Rein the fluid display size in a touch on phones so the
         3-line headline sits calmer above the lead. */
      font-size: clamp(2.5rem, 12vw, 3.25rem);
    }
    .bloghero__lead {
      margin-top: var(--sp-4);
    }
    .bloglist {
      padding-top: var(--sp-8);
    }
    /* Comfortable gap between full-width stacked cards without wasting a
       whole screen between each. */
    .bloglist__grid {
      gap: var(--sp-5);
    }

    /* --- Compact, scannable cards ---
       Tighten the card padding and internal rhythm so each card reads at a
       glance and the index isn't ~1.3 screens per post. Covers are becoming
       clean, text-free art, so one title + category + description is all the
       card carries. */
    .postcard {
      padding: var(--sp-5);
    }
    /* Reasonable cover height — a banded strip, not a full 16:9-ish block.
       Full-bleed to the (now smaller) card padding. */
    .postcard__cover {
      margin: calc(-1 * var(--sp-5)) calc(-1 * var(--sp-5)) var(--sp-4);
      aspect-ratio: 16 / 8;
    }
    .postcard__title {
      margin-top: var(--sp-3);
      font-size: 1.35rem;
      line-height: 1.2;
    }
    .postcard__desc {
      margin-top: var(--sp-2);
      /* Keep the description to a scannable preview instead of a full block. */
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .postcard__meta {
      padding-top: var(--sp-4);
    }
    /* Tap target: the whole card is the link, but keep the arrow
       comfortably large. */
    .postcard__arrow {
      width: 34px;
      height: 34px;
    }
  }
</style>
