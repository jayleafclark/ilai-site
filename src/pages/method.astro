---
import Layout from "../layouts/Layout.astro";
import CTASection from "../components/CTASection.astro";

const arrow = `<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const flow = [
  { k: "Decode", d: "Learn your world" },
  { k: "Define", d: "Build the system" },
  { k: "Direct", d: "Script, film, approve" },
  { k: "Distribute", d: "Publish everywhere" },
  { k: "Measure", d: "Watch it work" },
];

const steps = [
  {
    n: "01",
    name: "Decode",
    accent: "var(--coral)",
    promise: "We learn your world before you pay us a cent.",
    body: "Every engagement opens with research. We study the people you actually sell to, the competitors already winning their attention, and the offer you're trying to grow. Then we hand you a free teardown of your brand, your market, and your audience, so you can see our thinking before you commit.",
    get: [
      "Free brand, market, and audience teardown",
      "Competitor and category breakdown",
      "The gaps and angles worth owning",
    ],
    you: ["Answer a short intake", "Read the teardown", "Decide with real evidence"],
    outcome: "You start with a map of where the attention already is.",
    art: "decode",
  },
  {
    n: "02",
    name: "Define",
    accent: "var(--brand)",
    promise: "We build the system your content runs on.",
    body: "With the research in hand, we build the system that keeps every post looking and sounding like you, even at 350 a month. Your voice is documented, and your look is fixed with type, color, and reusable templates. We map the content categories you will own and build a set of proven opening lines drawn from posts already working in your niche.",
    get: [
      "Documented voice guide",
      "Visual system: type, color, templates",
      "Content categories and a niche-tuned set of opening lines",
    ],
    you: ["Share your references", "React to the first drafts", "Sign off on the system"],
    outcome: "One system that keeps every piece looking and sounding like you.",
    art: "define",
  },
  {
    n: "03",
    name: "Direct",
    accent: "var(--green)",
    promise: "We write it. You bring the expertise. Nothing ships without your yes.",
    body: "Ilai writes the scripts, shot lists, captions, and copy, so you know exactly what to say on camera. Every piece comes back to you for approval, and nothing goes public until a human on your side signs off. The gate is yours, always.",
    get: [
      "Scripts, shot lists, captions, and copy",
      "A shoot plan for your recording sessions",
      "An approval gate on every single piece",
    ],
    you: ["Record your episodes", "Review each piece", "Approve, or send it back"],
    outcome: "A full month of content, all in your voice.",
    art: "direct",
  },
  {
    n: "04",
    name: "Distribute",
    accent: "var(--plum)",
    promise: "One approval becomes a presence on every platform.",
    body: "Once you approve, we publish 350+ posts a month across up to 13 platforms, all in one voice, on a schedule built for how each place rewards content. Then we turn on the engagement engine: real replies to your community in the first minutes after a post lands, while that early response still decides whether it travels.",
    get: [
      "Publishing across your platforms",
      "One voice, on schedule, per platform",
      "First-response community engagement",
    ],
    you: ["Nothing", "Stay focused on your work", "Answer the leads we flag"],
    outcome: "You are everywhere, without living online.",
    art: "distribute",
  },
  {
    n: "05",
    name: "Measure",
    accent: "var(--coral)",
    promise: "A live dashboard, and a clean hand-off at your funnel.",
    body: "You watch everything on a branded dashboard where every metric is pulled straight from the platforms and refreshed on its own. We report the interest and intent we surface, flag the accounts leaning in, and hand off at your funnel. The attention arrives at your door; you close it.",
    get: [
      "A live, branded, auto-refreshed dashboard",
      "Interest and intent signals, reported plainly",
      "A clean hand-off at your funnel",
    ],
    you: ["Open the dashboard", "See what is landing", "Take the warm leads"],
    outcome: "Every number in one place, refreshed on its own.",
    art: "measure",
  },
];

const why = [
  {
    t: "Researched, not guessed",
    s: "Every angle is grounded in your market, your competitors, and what your audience actually responds to. You see the research before the work begins.",
    c: "var(--coral)",
    icon: `<circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 13.5L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="9" r="2" fill="currentColor"/>`,
  },
  {
    t: "People make every call",
    s: "A real US team writes your angles and makes every call. Nothing ships until a person on your side approves it. Software carries the load; judgment stays human.",
    c: "var(--green)",
    icon: `<path d="M10 2l6 2.5v5c0 4-2.7 6.3-6 7.5-3.3-1.2-6-3.5-6-7.5v-5L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M7.2 10l2 2 3.6-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  },
  {
    t: "You bring the expertise; we do the rest",
    s: "We create 350+ posts a month across up to 13 platforms, in your voice. You focus on the work; we keep you visible.",
    c: "var(--brand)",
    icon: `<rect x="2.5" y="5" width="11" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M13.5 8.5L18 6v8l-4.5-2.5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  },
];
---

<Layout
  title="How it works · Ilai Collective"
  description="How Ilai works: a repeatable system that learns your audience and voice, then creates, publishes, and engages everywhere. Decode, Define, Direct, Distribute, Measure. Research-led, human-gated, tracked on a live dashboard."
  path="/method"
>
  <!-- ============ HERO ============ -->
  <section class="mhero">
    <div class="container mhero__wrap">
      <div class="herocard" data-reveal>
        <div class="herocard__glow" aria-hidden="true"></div>
        <div class="herocard__body">
          <span class="eyebrow eyebrow--star eyebrow--ondark">How it works</span>
          <h1 class="herocard__title">
            How we put you on every platform,<br />in your <span class="herocard__accent">voice.</span>
          </h1>
          <p class="herocard__lead">
            Here is exactly how we work. Five steps that run the same way for every client,
            every month: learn your audience and what's working in your niche, build the system
            and voice, script and edit, publish across up to 13 platforms, and track it all on a
            live dashboard.
          </p>
          <div class="herocard__actions">
            <a href="/contact" class="btn btn--pink">
              Get your free teardown<span class="btn__arrow" aria-hidden="true" set:html={arrow} />
            </a>
            <a href="/work/dr-caroline-leaf" class="btn btn--ghost btn--ghost-dark">See the proof</a>
          </div>
        </div>

        <!-- Animated 5-node flow -->
        <ol class="flowviz" data-reveal data-reveal-delay="1" aria-label="The five steps of the Signal Method">
          <span class="flowviz__line" aria-hidden="true"><span class="flowviz__prog"></span></span>
          {flow.map((f, i) => (
            <li class={`flowviz__node${i === 0 ? " is-active" : ""}`} style={`--i:${i}`}>
              <a class="flowviz__pill" href={`#step-0${i + 1}`}>
                <span class="flowviz__num">{`0${i + 1}`}</span>
                <span class="flowviz__k">{f.k}</span>
                <span class="flowviz__d">{f.d}</span>
              </a>
            </li>
          ))}
        </ol>
      </div>

      <!-- Floating quick-stats -->
      <div class="herostats">
        {[
          { v: 5, s: "", l: "steps, one system", c: "var(--coral)" },
          { v: 350, s: "+", l: "posts a month", c: "var(--brand)" },
          { v: 13, s: "+", l: "platforms, one voice", c: "var(--green)" },
          { v: 100, s: "%", l: "human-gated", c: "var(--plum)" },
        ].map((s, i) => (
          <div class="herostat" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="herostat__num" style={`--ic:${s.c}`} data-count={s.v} data-suffix={s.s}>{s.v}{s.s}</span>
            <span class="herostat__lab">{s.l}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ STEPS ============ -->
  {
    steps.map((s, i) => {
      const flip = i % 2 === 1;
      const ink = i === 2; // Direct = the human-gate emphasis block (deep forest)
      const sectionClass = ink
        ? "section section--ink step"
        : flip
          ? "section section--mist step"
          : "section step";
      return (
        <section class={sectionClass} id={`step-0${i + 1}`} style={`--st:${s.accent}`}>
          <div class="container">
            <div class={`step__row${flip ? " step__row--flip" : ""}`}>
              <details class="step__text step__acc" data-reveal open={i === 0}>
                <summary class="step__accsummary">
                  <span class="step__head">
                    <span class="step__n" style={`--ac:${s.accent}`}>{s.n}</span>
                    <span class="step__rule" aria-hidden="true"></span>
                    <span class="step__of">Step {s.n} of 05</span>
                  </span>
                  <span class="step__accname">
                    <span class="step__name">{s.name}</span>
                    <span class="step__accchev" style={`--ac:${s.accent}`} aria-hidden="true">
                      <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </span>
                </summary>
                <div class="step__accbody">
                <p class="step__promise">{s.promise}</p>
                <p class="step__body">{s.body}</p>

                <div class="step__cols">
                  <div class="step__col">
                    <span class="step__coltag" style={`--ac:${s.accent}`}>What you get</span>
                    <ul class="step__list">
                      {s.get.map((o) => (
                        <li class="step__item">
                          <span class="step__tick" style={`--ac:${s.accent}`} aria-hidden="true">
                            <svg width="12" height="12" viewBox="0 0 14 14" fill="none">
                              <path d="M2.5 7.5L5.5 10.5L11.5 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                          </span>
                          <span>{o}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="step__col">
                    <span class="step__coltag step__coltag--muted">What you do</span>
                    <ul class="step__list">
                      {s.you.map((o) => (
                        <li class="step__item step__item--you">
                          <span class="step__dot" aria-hidden="true"></span>
                          <span>{o}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <p class="step__outcome" style={`--ac:${s.accent}`}>
                  <span class="step__outlabel">Outcome</span>
                  {s.outcome}
                </p>
                </div>
              </details>

              <div class="step__visual" data-reveal data-reveal-delay="1" aria-hidden="true">
                <div class={`stepcard${ink ? " stepcard--ink" : ""}`} style={`--ac:${s.accent}`}>
                  <div class="stepcard__bar">
                    <span class="stepcard__d"></span><span class="stepcard__d"></span><span class="stepcard__d"></span>
                    <span class="stepcard__url">{s.name.toLowerCase()} · ilai studio</span>
                  </div>
                  <div class="stepcard__core">

                    {s.art === "decode" && (
                      <div class="viz viz--decode">
                        <div class="dcd__top">
                          <span class="dcd__title">Audience teardown</span>
                          <span class="dcd__chip">Free</span>
                        </div>
                        <div class="dcd__seg">
                          {[
                            { l: "Warm buyers", w: 88 },
                            { l: "Researching", w: 64 },
                            { l: "Curious", w: 46 },
                            { l: "Off-target", w: 22 },
                          ].map((r, k) => (
                            <div class="dcd__row">
                              <span class="dcd__rl">{r.l}</span>
                              <span class="dcd__track"><span class="dcd__fill" style={`--w:${r.w}%;--d:${k * 120}ms`}></span></span>
                            </div>
                          ))}
                        </div>
                        <div class="dcd__scanwrap">
                          <span class="dcd__scanlab">Competitor scan</span>
                          <ul class="dcd__list">
                            <li style="--i:0"><span class="dcd__ldot" style="background:var(--coral)"></span>Owns the how-to angle</li>
                            <li style="--i:1"><span class="dcd__ldot" style="background:var(--brand)"></span>Weak on proof and stories</li>
                            <li style="--i:2"><span class="dcd__ldot" style="background:var(--green)"></span>Gap: your point of view</li>
                          </ul>
                          <span class="dcd__scan"></span>
                        </div>
                      </div>
                    )}

                    {s.art === "define" && (
                      <div class="viz viz--define">
                        <div class="def__grid">
                          <div class="def__panel def__swatches">
                            <span class="def__ptag">Palette</span>
                            <div class="def__row">
                              <span class="def__sw" style="background:var(--coral)"></span>
                              <span class="def__sw" style="background:var(--charcoal)"></span>
                              <span class="def__sw" style="background:var(--brand)"></span>
                              <span class="def__sw" style="background:var(--green)"></span>
                            </div>
                          </div>
                          <div class="def__panel def__type">
                            <span class="def__ptag">Type</span>
                            <span class="def__aa">Aa</span>
                            <span class="def__lines"><span style="--w:92%"></span><span style="--w:70%"></span></span>
                          </div>
                        </div>
                        <div class="def__chips">
                          <span class="def__ctag">Categories</span>
                          <div class="def__chiprow">
                            {["Myths", "How-to", "Proof", "Story", "Hot take"].map((c, k) => (
                              <span class="def__chip" style={`--d:${k * 90}ms`}>{c}</span>
                            ))}
                          </div>
                        </div>
                        <div class="def__hooks">
                          <span class="def__ctag">Opening lines</span>
                          <div class="def__hookrow"><span class="def__hnum">01</span><span class="def__hbar" style="--w:80%"></span></div>
                          <div class="def__hookrow"><span class="def__hnum">02</span><span class="def__hbar" style="--w:62%"></span></div>
                          <div class="def__hookrow"><span class="def__hnum">03</span><span class="def__hbar" style="--w:74%"></span></div>
                        </div>
                      </div>
                    )}

                    {s.art === "direct" && (
                      <div class="viz viz--direct">
                        <div class="dir__split">
                          <div class="dir__lane"><span class="dir__lanel">We write</span><span class="dir__lanev">Scripts</span></div>
                          <span class="dir__arrow"><svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M1 5h13M14 5l-3.5-3.5M14 5l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                          <div class="dir__lane"><span class="dir__lanel">You</span><span class="dir__lanev">Bring the expertise</span></div>
                          <span class="dir__arrow"><svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M1 5h13M14 5l-3.5-3.5M14 5l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                          <div class="dir__lane dir__lane--gate"><span class="dir__lanel">You approve</span><span class="dir__lanev">The gate</span></div>
                        </div>
                        <div class="dir__doc">
                          <span class="dir__doctitle">Reel script · draft</span>
                          <span class="dir__line" style="--w:88%"></span>
                          <span class="dir__line" style="--w:64%"></span>
                          <span class="dir__line" style="--w:78%"></span>
                          <span class="dir__line" style="--w:52%"></span>
                          <div class="dir__stamp">
                            <span class="dir__stampic">
                              <svg width="16" height="16" viewBox="0 0 18 18" fill="none"><path d="M3.5 9.5L7.5 13.5L14.5 4.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </span>
                            Approved by you
                          </div>
                        </div>
                      </div>
                    )}

                    {s.art === "distribute" && (
                      <div class="viz viz--distribute">
                        <div class="dis__fig">
                          <span class="dis__src">your long-form</span>
                          <span class="dis__eq">becomes</span>
                          <span class="dis__out" style={`--ac:${s.accent}`}>30+ posts</span>
                        </div>
                        <div class="dis__tiles">
                          {["a","b","c","a","c","b","b","a","c","a","b","c"].map((t, k) => (
                            <span class={`dis__tile dis__tile--${t} ${t === "b" ? "dis__tile--post" : "dis__tile--play"}`} style={`--d:${450 + k * 60}ms`}>
                              {t === "b" ? (
                                <span class="dis__glyph dis__glyph--post" aria-hidden="true"></span>
                              ) : (
                                <span class="dis__glyph dis__glyph--play" aria-hidden="true">
                                  <svg width="10" height="12" viewBox="0 0 10 12" fill="none"><path d="M1 1.4v9.2a.6.6 0 0 0 .92.5l7.3-4.6a.6.6 0 0 0 0-1L1.92.9A.6.6 0 0 0 1 1.4Z" fill="currentColor"/></svg>
                                </span>
                              )}
                            </span>
                          ))}
                        </div>
                        <div class="dis__plats">
                          {["Reels","Shorts","TikTok","X","LinkedIn","Threads"].map((p, k) => (
                            <span class="dis__plat" style={`--d:${900 + k * 80}ms`}>{p}</span>
                          ))}
                        </div>
                      </div>
                    )}

                    {s.art === "measure" && (
                      <div class="viz viz--measure">
                        <div class="mea__top">
                          <div class="mea__kpi">
                            <span class="mea__kv" data-count="350" data-suffix="+">350+</span>
                            <span class="mea__kl">posts a month</span>
                          </div>
                          <span class="mea__live"><span class="mea__pulse"></span>Live</span>
                        </div>
                        <div class="mea__chart">
                          <svg viewBox="0 0 120 46" fill="none" preserveAspectRatio="none">
                            <defs>
                              <linearGradient id="meafill" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0" stop-color="var(--coral)" stop-opacity="0.35"/>
                                <stop offset="1" stop-color="var(--coral)" stop-opacity="0"/>
                              </linearGradient>
                            </defs>
                            <path class="mea__area" d="M2 42 L20 36 L38 38 L56 26 L74 28 L92 14 L118 6 L118 46 L2 46 Z" fill="url(#meafill)"/>
                            <path class="mea__stroke" d="M2 42 L20 36 L38 38 L56 26 L74 28 L92 14 L118 6" stroke="var(--coral)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                          </svg>
                        </div>
                        <div class="mea__rows">
                          {[
                            { p: "Instagram", w: 92, c: "var(--coral)" },
                            { p: "TikTok", w: 74, c: "var(--plum)" },
                            { p: "YouTube", w: 58, c: "var(--brand)" },
                            { p: "LinkedIn", w: 40, c: "var(--green)" },
                          ].map((r, k) => (
                            <div class="mea__row">
                              <span class="mea__rp">{r.p}</span>
                              <span class="mea__dots">
                                {Array.from({ length: 10 }).map((_, d) => (
                                  <span class={`mea__d${d < Math.round(r.w / 10) ? " on" : ""}`} style={`--c:${r.c};--d:${(k * 10 + d) * 24}ms`}></span>
                                ))}
                              </span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}

                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      );
    })
  }

  <!-- ============ WHY THE METHOD WORKS ============ -->
  <section class="section why-sec">
    <div class="container">
      <div class="why__head" data-reveal>
        <span class="eyebrow eyebrow--star">Why the method works</span>
        <h2 class="why__h">Three things most content <span class="hl">operations skip.</span></h2>
        <p class="lead">
          These are the commitments that make it hold up, month after month.
        </p>
      </div>
      <div class="why__grid">
        {why.map((w, i) => (
          <article class="whycard" data-reveal data-reveal-delay={String(i + 1)}>
            <span class="whycard__ico" style={`--ic:${w.c}`} aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none" set:html={w.icon} />
            </span>
            <h3 class="whycard__t">{w.t}</h3>
            <p class="whycard__s">{w.s}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  /* ==================================================================
     HERO
  ================================================================== */
  .mhero {
    padding-top: clamp(6.5rem, 11vh, 8.5rem);
    padding-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .mhero__wrap {
    max-width: calc(var(--maxw) + var(--gutter) * 2);
  }
  .herocard {
    position: relative;
    overflow: hidden;
    border-radius: var(--r-card-lg);
    padding: clamp(1.75rem, 4vw, 3.25rem);
    color: #fff;
    box-shadow: var(--shadow-float);
    background:
      radial-gradient(78% 120% at 86% 8%, rgba(230, 169, 196, 0.42), transparent 58%),
      radial-gradient(70% 100% at 6% 96%, rgba(13, 40, 29, 0.9), transparent 62%),
      linear-gradient(135deg, var(--charcoal-2), var(--charcoal) 55%, var(--charcoal-3));
  }
  .herocard__glow {
    position: absolute;
    inset: -30% -10% auto auto;
    width: 60%;
    height: 80%;
    background: radial-gradient(50% 50% at 70% 30%, rgba(230, 169, 196, 0.28), transparent 70%);
    filter: blur(10px);
    pointer-events: none;
  }
  .herocard__body {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin-inline: auto;
    text-align: center;
  }
  .herocard__title {
    margin-top: var(--sp-4);
    font-size: clamp(2.3rem, 4vw, 3.5rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    color: #fff;
  }
  .herocard__accent {
    color: var(--gold);
  }
  .herocard__lead {
    margin-top: var(--sp-5);
    margin-inline: auto;
    max-width: 60ch;
    color: rgba(255, 255, 255, 0.82);
    font-size: var(--fs-lead);
    line-height: 1.5;
  }
  .herocard__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-3);
    margin-top: var(--sp-6);
  }
  .btn--ghost-dark {
    --btn-fg: #fff;
    border-color: rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.08);
  }
  .btn--ghost-dark:hover {
    background: rgba(255, 255, 255, 0.16);
  }

  /* ---- Animated 5-node flow ---- */
  .flowviz {
    position: relative;
    z-index: 2;
    list-style: none;
    margin: clamp(2rem, 4vw, 3rem) auto 0;
    max-width: 920px;
    display: grid;
    gap: var(--sp-3);
  }
  .flowviz__line {
    display: none;
  }
  .flowviz__pill {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    border-radius: var(--r-pill);
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      transform var(--dur-base) var(--ease),
      background var(--dur-base) var(--ease),
      border-color var(--dur-base) var(--ease);
  }
  .flowviz__pill:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.28);
  }
  .flowviz__num {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: var(--fs-sm);
    color: var(--gold);
    font-variant-numeric: tabular-nums;
  }
  .flowviz__k {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: #fff;
  }
  .flowviz__d {
    font-size: var(--fs-sm);
    color: rgba(255, 255, 255, 0.6);
    margin-left: auto;
  }
  .flowviz__node.is-active .flowviz__pill {
    background: rgba(230, 169, 196, 0.16);
    border-color: rgba(230, 169, 196, 0.5);
    box-shadow: 0 0 0 1px rgba(230, 169, 196, 0.3), 0 10px 30px -14px rgba(230, 169, 196, 0.6);
  }

  /* Traveling signal: the highlight moves through 01 -> 05 and loops.
     Every node runs the same keyframe, offset by --i so exactly one reads
     "active" at a time. 5 steps x 2.1s = 10.5s loop (~2.1s per step). */
  .flowviz__node .flowviz__pill {
    animation: flowpill 10.5s linear infinite;
    animation-delay: calc(var(--i) * 2.1s - 10.5s);
  }
  @keyframes flowpill {
    0%, 20% {
      background: rgba(230, 169, 196, 0.16);
      border-color: rgba(230, 169, 196, 0.5);
      box-shadow: 0 0 0 1px rgba(230, 169, 196, 0.3), 0 10px 30px -14px rgba(230, 169, 196, 0.6);
    }
    26%, 100% {
      background: rgba(255, 255, 255, 0.07);
      border-color: rgba(255, 255, 255, 0.14);
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0), 0 0 0 rgba(230, 169, 196, 0);
    }
  }
  @media (min-width: 900px) {
    .flowviz {
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      align-items: stretch;
    }
    .flowviz__line {
      display: block;
      position: absolute;
      left: 6%;
      right: 6%;
      top: 22px;
      height: 2px;
      background: rgba(255, 255, 255, 0.14);
      border-radius: 999px;
      overflow: hidden;
    }
    .flowviz__prog {
      display: block;
      height: 100%;
      width: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--gold), var(--coral-soft));
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 1.6s var(--ease) 0.3s;
    }
    .herocard.is-visible .flowviz__prog {
      transform: scaleX(1);
    }
    .flowviz__node {
      position: relative;
      padding: 0 6px;
    }
    .flowviz__pill {
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      height: 100%;
      padding: var(--sp-4);
    }
    .flowviz__node::before {
      content: "";
      position: absolute;
      top: 16px;
      left: 50%;
      transform: translateX(-50%);
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--charcoal);
      border: 2px solid rgba(255, 255, 255, 0.3);
      z-index: 3;
    }
    .flowviz__node.is-active::before {
      background: var(--gold);
      border-color: var(--gold);
      box-shadow: 0 0 0 5px rgba(230, 169, 196, 0.25);
    }
    /* Traveling node: the filled dot moves along the connector in step
       with the pill highlight (same 10.5s loop, same --i stagger). */
    .flowviz__node::before {
      animation: flownode 10.5s linear infinite;
      animation-delay: calc(var(--i) * 2.1s - 10.5s);
    }
    @keyframes flownode {
      0%, 20% {
        background: var(--gold);
        border-color: var(--gold);
        box-shadow: 0 0 0 5px rgba(230, 169, 196, 0.25);
      }
      26%, 100% {
        background: var(--charcoal);
        border-color: rgba(255, 255, 255, 0.3);
        box-shadow: 0 0 0 0 rgba(230, 169, 196, 0);
      }
    }
    .flowviz__pill {
      margin-top: 34px;
      border-radius: var(--r-card);
    }
    .flowviz__d {
      margin-left: 0;
    }
  }

  /* ---- Floating quick-stats ---- */
  .herostats {
    position: relative;
    z-index: 3;
    margin-top: var(--sp-6);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
    padding: 0 clamp(0.5rem, 3vw, 2rem);
  }
  .herostat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--sp-5);
    border-radius: var(--r-card);
    background: rgba(255, 255, 255, 0.66);
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.6),
      0 18px 40px -24px rgba(29, 42, 35, 0.4);
  }
  .herostat__num {
    font-family: var(--font-accent);
    font-weight: 700;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ic, var(--ink));
  }
  .herostat__lab {
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  @media (min-width: 800px) {
    .herostats {
      grid-template-columns: repeat(4, 1fr);
      margin-top: var(--sp-6);
    }
  }

  /* ==================================================================
     STEP ROWS
  ================================================================== */
  /* Soft, muted ambient wash behind each step, tinted by its accent */
  .step { position: relative; overflow: hidden; }
  .step > .container { position: relative; z-index: 1; }
  .step::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(40% 56% at 16% 20%, color-mix(in srgb, var(--st, var(--coral)) 13%, transparent), transparent 70%),
      radial-gradient(36% 52% at 86% 84%, rgba(230, 169, 196, 0.15), transparent 72%);
    filter: blur(14px);
    opacity: 0.7;
  }
  .section--ink.step::before { opacity: 0.5; }
  @media (prefers-reduced-motion: reduce) { .step::before { animation: none; } }

  .step__row {
    display: grid;
    gap: var(--sp-8);
    align-items: center;
  }
  @media (min-width: 900px) {
    .step__row {
      grid-template-columns: 1.02fr 0.98fr;
      gap: var(--sp-12);
    }
    .step__row--flip .step__text { order: 2; }
    .step__row--flip .step__visual { order: 1; }
  }
  .step__head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }
  .step__n {
    font-family: var(--font-accent);
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ac, var(--coral));
  }
  .section--ink .step__n { color: var(--gold); }
  .step__rule {
    flex: 1;
    height: 1px;
    background: var(--line-2);
    max-width: 80px;
  }
  .section--ink .step__rule { background: rgba(255, 255, 255, 0.2); }
  .step__of {
    font-family: var(--font-accent);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--muted);
  }
  .section--ink .step__of { color: rgba(255, 255, 255, 0.55); }
  .step__name {
    margin-top: var(--sp-4);
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  .step__promise {
    margin-top: var(--sp-3);
    font-size: var(--fs-lead);
    font-weight: 600;
    line-height: 1.4;
    color: var(--ink);
  }
  .section--ink .step__promise { color: #fff; }
  .step__body {
    margin-top: var(--sp-4);
    font-size: var(--fs-body);
    color: var(--ink-2);
    max-width: 52ch;
  }
  .section--ink .step__body { color: rgba(255, 255, 255, 0.72); }

  .step__cols {
    margin-top: var(--sp-6);
    display: grid;
    gap: var(--sp-5);
  }
  /* Only split the get/do lists once the visual sits beside the text (>=900),
     so the 560-899 band doesn't stretch two columns across the full width. */
  @media (min-width: 900px) {
    .step__cols { grid-template-columns: 1fr 1fr; gap: var(--sp-6); }
  }
  .step__coltag {
    display: inline-block;
    font-family: var(--font-accent);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ac, var(--coral));
  }
  .step__coltag--muted { color: var(--muted); }
  .section--ink .step__coltag { color: var(--gold); }
  .section--ink .step__coltag--muted { color: rgba(255, 255, 255, 0.5); }
  .step__list {
    list-style: none;
    margin-top: var(--sp-3);
    display: grid;
    gap: var(--sp-3);
  }
  .step__item {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--ink-2);
  }
  .section--ink .step__item { color: rgba(255, 255, 255, 0.82); }
  .step__tick {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    color: #fff;
    background: var(--ac, var(--coral));
    margin-top: 1px;
  }
  .step__dot {
    flex: 0 0 auto;
    width: 7px;
    height: 7px;
    margin-top: 7px;
    border-radius: 50%;
    background: var(--line-2);
  }
  .section--ink .step__dot { background: rgba(255, 255, 255, 0.4); }
  .step__item--you { color: var(--muted); }
  .section--ink .step__item--you { color: rgba(255, 255, 255, 0.66); }

  .step__outcome {
    margin-top: var(--sp-6);
    padding: var(--sp-4) var(--sp-5);
    border-radius: var(--r-input);
    background: color-mix(in srgb, var(--ac, var(--coral)) 8%, var(--paper));
    border: 1px solid color-mix(in srgb, var(--ac, var(--coral)) 22%, transparent);
    border-left: 3px solid var(--ac, var(--coral));
    font-size: var(--fs-sm);
    color: var(--ink);
  }
  .section--mist .step__outcome {
    background: color-mix(in srgb, var(--ac, var(--coral)) 10%, var(--paper));
  }
  .section--ink .step__outcome {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.14);
    border-left-color: var(--gold);
    color: rgba(255, 255, 255, 0.9);
  }
  .step__outlabel {
    display: inline-block;
    margin-right: var(--sp-2);
    font-family: var(--font-accent);
    font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    font-weight: 700;
    color: var(--ac, var(--coral));
  }
  .section--ink .step__outlabel { color: var(--gold); }

  /* ==================================================================
     STEP VISUAL CARD (browser-chrome frame)
  ================================================================== */
  .step__visual {
    display: flex;
    justify-content: center;
  }
  .stepcard {
    width: 100%;
    max-width: 560px;
    border-radius: var(--r-card);
    overflow: hidden;
    background: var(--paper);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-float);
  }
  .stepcard--ink {
    background: #0f1a15;
    border-color: rgba(255, 255, 255, 0.12);
  }
  .stepcard__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 11px 14px;
    background: var(--mist);
    border-bottom: 1px solid var(--line);
  }
  .stepcard--ink .stepcard__bar {
    background: rgba(255, 255, 255, 0.06);
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }
  .stepcard__d {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--line-2);
  }
  .stepcard--ink .stepcard__d { background: rgba(255, 255, 255, 0.2); }
  .stepcard__url {
    margin-left: 8px;
    font-family: var(--font-accent);
    font-size: 0.72rem;
    color: var(--muted);
  }
  .stepcard--ink .stepcard__url { color: rgba(255, 255, 255, 0.55); }
  .stepcard__core {
    padding: clamp(1.25rem, 4vw, var(--sp-8));
    min-height: 340px;
    display: flex;
    align-items: center;
  }
  .viz { width: 100%; }

  /* ---- 01 Decode ---- */
  .viz--decode { display: grid; gap: var(--sp-5); }
  .dcd__top { display: flex; align-items: center; justify-content: space-between; }
  .dcd__title { font-family: var(--font-accent); font-weight: 600; font-size: 0.95rem; color: var(--ink); }
  .dcd__chip {
    padding: 3px 11px; border-radius: 999px;
    background: var(--coral); color: #fff;
    font-family: var(--font-accent); font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .dcd__seg { display: grid; gap: 10px; }
  .dcd__row { display: grid; grid-template-columns: 6.5em 1fr; align-items: center; gap: var(--sp-3); }
  .dcd__rl { font-size: 0.78rem; color: var(--muted); }
  .dcd__track { height: 9px; border-radius: 999px; background: var(--mist); overflow: hidden; }
  .dcd__fill {
    display: block; height: 100%; width: 0; border-radius: 999px;
    background: linear-gradient(90deg, var(--coral), var(--coral-soft));
    transition: width 1s var(--ease) var(--d);
  }
  .stepcard.is-visible .dcd__fill,
  .step__visual.is-visible .dcd__fill { width: var(--w); }
  .dcd__scanwrap {
    position: relative; overflow: hidden;
    padding: var(--sp-4);
    border-radius: var(--r-input);
    background: var(--mist);
    border: 1px solid var(--line);
  }
  .dcd__scanlab {
    font-family: var(--font-accent); font-size: var(--fs-eyebrow);
    letter-spacing: var(--tracking-eyebrow); text-transform: uppercase; color: var(--muted);
  }
  .dcd__list { list-style: none; margin-top: 10px; display: grid; gap: 8px; }
  .dcd__list li {
    display: flex; align-items: center; gap: var(--sp-3);
    font-size: 0.8rem; color: var(--ink-2);
    /* start undiscovered; the sweep reveals each finding in turn */
    opacity: 0.28; transform: translateX(-4px);
  }
  .dcd__ldot {
    width: 8px; height: 8px; border-radius: 50%; flex: none;
    transform: scale(0.6); opacity: 0.4;
  }
  /* One shared loop; each item fires as the scan line crosses its row.
     4.2s cycle: ~0.5s per row of sweep travel + a hold at the end. */
  .step__visual.is-visible .dcd__list li {
    animation: dcdreveal 4.2s var(--ease) infinite;
    animation-delay: calc(var(--i) * 0.52s);
  }
  .step__visual.is-visible .dcd__list li .dcd__ldot {
    animation: dcddot 4.2s var(--ease) infinite;
    animation-delay: calc(var(--i) * 0.52s);
  }
  @keyframes dcdreveal {
    0% { opacity: 0.28; transform: translateX(-4px); }
    /* found the moment the line passes, then settle and hold */
    8% { opacity: 1; transform: translateX(2px); }
    16%, 82% { opacity: 1; transform: translateX(0); }
    /* fade back before the sweep restarts */
    96%, 100% { opacity: 0.28; transform: translateX(-4px); }
  }
  @keyframes dcddot {
    0% { transform: scale(0.6); opacity: 0.4; }
    8% { transform: scale(1.25); opacity: 1; }
    16%, 82% { transform: scale(1); opacity: 1; }
    96%, 100% { transform: scale(0.6); opacity: 0.4; }
  }
  .dcd__scan {
    position: absolute; left: 0; right: 0; top: 0; height: 28px;
    background: linear-gradient(180deg, rgba(28, 107, 74, 0.16), transparent);
    border-bottom: 1.5px solid rgba(28, 107, 74, 0.45);
    opacity: 0; transform: translateY(0);
  }
  .step__visual.is-visible .dcd__scan {
    animation: dcdscan 4.2s var(--ease) infinite;
  }
  /* Sweep down across the three rows in the first ~85% of the cycle
     (matching the reveal delays), then reset invisibly and repeat. */
  @keyframes dcdscan {
    0% { transform: translateY(2px); opacity: 0; }
    4% { opacity: 1; }
    12% { transform: translateY(16px); }
    50% { transform: translateY(52px); }
    82% { transform: translateY(84px); opacity: 1; }
    90% { transform: translateY(90px); opacity: 0; }
    100% { transform: translateY(90px); opacity: 0; }
  }

  /* ---- 02 Define ---- */
  .viz--define { display: grid; gap: var(--sp-4); }
  .def__grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: var(--sp-3); }
  .def__panel { padding: var(--sp-4); border-radius: var(--r-input); background: var(--mist); border: 1px solid var(--line); }
  .def__ptag { font-family: var(--font-accent); font-size: 0.64rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
  .def__row { display: flex; gap: 8px; margin-top: 10px; }
  .def__sw { width: 30px; height: 30px; border-radius: 9px; box-shadow: inset 0 1px 1px rgba(255,255,255,0.3); }
  .def__type { display: flex; flex-direction: column; }
  .def__aa { font-family: var(--font-display); font-weight: 700; font-size: 1.9rem; letter-spacing: -0.04em; color: var(--ink); line-height: 1; margin-top: 6px; }
  .def__lines { display: grid; gap: 5px; margin-top: 8px; }
  .def__lines span { height: 5px; width: var(--w); border-radius: 999px; background: var(--line-2); }
  .def__chips, .def__hooks { display: grid; gap: 8px; }
  .def__ctag { font-family: var(--font-accent); font-size: 0.64rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }
  .def__chiprow { display: flex; flex-wrap: wrap; gap: 6px; }
  .def__chip {
    padding: 6px 12px; border-radius: 999px;
    background: var(--brand-tint); color: var(--brand-night);
    font-size: 0.76rem; font-weight: 600;
    opacity: 0; transform: translateY(6px);
    transition: opacity 0.5s var(--ease) var(--d), transform 0.5s var(--ease) var(--d);
  }
  .step__visual.is-visible .def__chip { opacity: 1; transform: none; }
  .def__hookrow { display: flex; align-items: center; gap: var(--sp-3); }
  .def__hnum { font-family: var(--font-accent); font-weight: 700; font-size: 0.72rem; color: var(--brand-deep); }
  .def__hbar { flex: 1; height: 8px; border-radius: 999px; background: linear-gradient(90deg, var(--brand), var(--brand-tint)); width: 0; transition: width 0.9s var(--ease); }
  .def__hookrow:nth-child(2) .def__hbar { transition-delay: 0.15s; }
  .def__hookrow:nth-child(3) .def__hbar { transition-delay: 0.3s; }
  .step__visual.is-visible .def__hbar { width: var(--w); }

  /* ---- 03 Direct (on dark) ---- */
  .viz--direct { display: grid; gap: var(--sp-5); }
  .dir__split { display: flex; align-items: stretch; gap: 6px; }
  .dir__lane {
    flex: 1; display: flex; flex-direction: column; gap: 3px;
    padding: 10px 8px; border-radius: 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    text-align: center;
  }
  .dir__lane--gate {
    background: rgba(79, 164, 126, 0.18);
    border-color: rgba(79, 164, 126, 0.5);
  }
  .dir__lanel { font-size: 0.62rem; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(255, 255, 255, 0.55); }
  .dir__lanev { font-family: var(--font-accent); font-weight: 600; font-size: 0.82rem; color: #fff; }
  .dir__arrow { display: grid; place-items: center; color: rgba(255, 255, 255, 0.4); flex: 0 0 auto; }
  .dir__doc {
    position: relative;
    padding: var(--sp-5);
    border-radius: var(--r-input);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .dir__doctitle {
    display: block; margin-bottom: 12px;
    font-family: var(--font-accent); font-size: 0.7rem;
    letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255, 255, 255, 0.5);
  }
  .dir__line { display: block; height: 8px; width: var(--w); border-radius: 999px; background: rgba(255, 255, 255, 0.16); margin-bottom: 9px; }
  .dir__stamp {
    display: inline-flex; align-items: center; gap: var(--sp-2);
    margin-top: 10px; padding: 8px 14px;
    border-radius: 999px;
    background: rgba(79, 164, 126, 0.16);
    border: 1px solid rgba(79, 164, 126, 0.45);
    color: #fff; font-size: 0.82rem; font-weight: 600;
    transform: rotate(-4deg) scale(0.85);
    opacity: 0;
    transition: transform 0.6s var(--ease) 0.4s, opacity 0.6s var(--ease) 0.4s;
  }
  .step__visual.is-visible .dir__stamp { transform: rotate(-4deg) scale(1); opacity: 1; }
  .dir__stampic {
    display: grid; place-items: center; width: 22px; height: 22px;
    border-radius: 50%; background: var(--green); color: #fff;
  }

  /* ---- 04 Distribute ---- */
  .viz--distribute { display: grid; gap: var(--sp-5); }
  .dis__fig { display: flex; align-items: baseline; flex-wrap: wrap; gap: 8px; }
  .dis__src { font-family: var(--font-accent); font-weight: 700; font-size: 1.05rem; color: var(--ink); }
  .dis__eq { font-size: 0.82rem; color: var(--muted); }
  .dis__out { font-family: var(--font-accent); font-weight: 700; font-size: 1.6rem; letter-spacing: -0.03em; color: var(--ac, var(--plum)); }
  .dis__tiles { display: grid; grid-template-columns: repeat(6, 1fr); gap: 7px; }
  .dis__tile {
    position: relative;
    aspect-ratio: 1; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    /* start collapsed toward the source node (top-left of the block) */
    transform: translate(-14px, -18px) scale(0.35);
    transform-origin: top left;
  }
  /* each piece emanates from the single recording, one after another */
  .step__visual.is-visible .dis__tile {
    animation: disemanate 0.55s var(--ease-out, var(--ease)) both;
    animation-delay: var(--d);
  }
  @keyframes disemanate {
    0% { opacity: 0; transform: translate(-14px, -18px) scale(0.35); }
    60% { opacity: 1; transform: translate(1px, 2px) scale(1.06); }
    100% { opacity: 1; transform: translate(0, 0) scale(1); }
  }
  .dis__tile--a { background: color-mix(in srgb, var(--plum) 65%, white); }
  .dis__tile--b { background: color-mix(in srgb, var(--brand) 62%, white); }
  .dis__tile--c { background: color-mix(in srgb, var(--green) 58%, white); }
  /* content glyphs: play triangle = a video piece, bars = a written post */
  .dis__glyph { display: flex; align-items: center; justify-content: center; }
  .dis__glyph--play { color: rgba(255, 255, 255, 0.92); }
  .dis__glyph--play svg { display: block; }
  .dis__glyph--post {
    width: 54%; height: 54%;
    border-radius: 2px;
    background:
      linear-gradient(currentColor, currentColor) left 0 top 22% / 100% 2px no-repeat,
      linear-gradient(currentColor, currentColor) left 0 top 50% / 100% 2px no-repeat,
      linear-gradient(currentColor, currentColor) left 0 top 78% / 70% 2px no-repeat;
    color: rgba(255, 255, 255, 0.9);
  }
  .dis__plats { display: flex; flex-wrap: wrap; gap: 6px; }
  .dis__plat {
    padding: 6px 12px; border-radius: 999px;
    background: var(--mist); border: 1px solid var(--line);
    font-size: 0.75rem; font-weight: 600; color: var(--ink-2);
    opacity: 0; transform: translateY(6px);
    transition: opacity 0.5s var(--ease) var(--d), transform 0.5s var(--ease) var(--d);
  }
  .step__visual.is-visible .dis__plat { opacity: 1; transform: none; }

  /* ---- 05 Measure ---- */
  .viz--measure { display: grid; gap: var(--sp-5); }
  .mea__top { display: flex; align-items: center; justify-content: space-between; }
  .mea__kpi { display: flex; flex-direction: column; }
  .mea__kv { font-family: var(--font-accent); font-weight: 700; font-size: 2rem; letter-spacing: -0.04em; line-height: 1; color: var(--ink); }
  .mea__kl { font-size: 0.78rem; color: var(--muted); margin-top: 3px; }
  .mea__live {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 11px; border-radius: 999px;
    background: var(--coral-tint); color: var(--coral-ink);
    font-size: 0.72rem; font-weight: 600;
  }
  .mea__pulse {
    width: 7px; height: 7px; border-radius: 50%; background: var(--coral);
    animation: meapulse 2s var(--ease) infinite;
  }
  @keyframes meapulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.75); } }
  .mea__chart {
    padding: var(--sp-3);
    border-radius: var(--r-input);
    background: var(--mist);
    border: 1px solid var(--line);
  }
  .mea__chart svg { width: 100%; height: 52px; display: block; }
  .mea__stroke {
    stroke-dasharray: 260;
    stroke-dashoffset: 260;
    transition: stroke-dashoffset 1.6s var(--ease) 0.2s;
  }
  .step__visual.is-visible .mea__stroke { stroke-dashoffset: 0; }
  .mea__area { opacity: 0; transition: opacity 1s var(--ease) 0.9s; }
  .step__visible .mea__area,
  .step__visual.is-visible .mea__area { opacity: 1; }
  .mea__rows { display: grid; gap: 9px; }
  .mea__row { display: grid; grid-template-columns: 5.5em 1fr; align-items: center; gap: var(--sp-3); }
  .mea__rp { font-size: 0.76rem; color: var(--muted); }
  .mea__dots { display: flex; gap: 4px; }
  .mea__d {
    width: 100%; max-width: 12px; height: 8px; border-radius: 3px;
    background: var(--mist); flex: 1;
  }
  .mea__d.on {
    background: var(--c, var(--coral));
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.3s var(--ease) var(--d), transform 0.3s var(--ease) var(--d);
  }
  .step__visual.is-visible .mea__d.on { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .herocard__glow, .dcd__scan, .mea__pulse { animation: none; }
    /* Show all findings statically (no sweep to reveal them). */
    .step__visual.is-visible .dcd__list li,
    .step__visual.is-visible .dcd__list li .dcd__ldot { animation: none; }
    .dcd__list li { opacity: 1; transform: none; }
    .dcd__ldot { opacity: 1; transform: none; }
    .dcd__scan { opacity: 0; }
    /* Content pieces appear in place, no fan-out. */
    .dis__tile { animation: none; opacity: 1; transform: none; }
    /* Stop the traveling signal; leave step 01 highlighted via .is-active. */
    .flowviz__node .flowviz__pill,
    .flowviz__node::before { animation: none; }
    .flowviz__prog { transition: none; transform: scaleX(1); }
  }

  /* ==================================================================
     WHY THE METHOD WORKS
  ================================================================== */
  .why__head {
    max-width: 52ch;
    margin-bottom: var(--sp-10);
  }
  .why__h {
    margin-top: var(--sp-4);
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
  }
  .why__head .lead { margin-top: var(--sp-4); }
  .why__grid {
    display: grid;
    gap: var(--grid-gap);
  }
  .whycard {
    padding: clamp(1.5rem, 3vw, 2rem);
    border-radius: var(--r-card);
    background: var(--paper);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    transition: transform var(--dur-base) var(--ease), box-shadow var(--dur-base) var(--ease);
  }
  .whycard:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-float);
  }
  .whycard__ico {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    color: #fff;
    background: linear-gradient(140deg, var(--ic), color-mix(in srgb, var(--ic) 55%, #ffffff));
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.5),
      0 10px 20px -8px var(--ic);
  }
  .whycard__ico svg { stroke-width: 1.7; }
  .whycard__t {
    margin-top: var(--sp-4);
    font-size: var(--fs-h3);
  }
  .whycard__s {
    margin-top: var(--sp-3);
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: 1.55;
  }
  @media (min-width: 820px) {
    .why__grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ==================================================================
     MOBILE (<= 560px) — phone-first refinements, not a shrink.
     Desktop rules above are untouched; these only apply on small screens.
  ================================================================== */
  @media (max-width: 560px) {
    /* ---- Hero ---- */
    .mhero {
      padding-top: clamp(5rem, 15vh, 6.5rem);
      padding-bottom: var(--sp-6);
    }
    .herocard { padding: 1.5rem 1.25rem 1.75rem; }
    .herocard__title {
      font-size: clamp(2rem, 8.5vw, 2.4rem);
      line-height: 1.08;
    }
    .herocard__lead {
      font-size: 1rem;
      line-height: 1.55;
    }
    /* CTAs stacked and centered: the pink primary is the wide (but capped)
       action; the ghost secondary hugs its label underneath as a smaller,
       quiet link. Fluid so it reads the same at 390px and 430px — never a
       giant slab, never edge-to-edge. */
    .herocard__actions {
      flex-direction: column;
      align-items: center;
      gap: var(--sp-4);
    }
    .herocard__actions .btn--pink {
      width: 100%;
      max-width: 24rem;
      justify-content: center;
      min-height: 50px;
    }
    .herocard__actions .btn--ghost-dark {
      width: auto;
      max-width: 100%;
      justify-content: center;
      min-height: 44px;
      padding: 11px clamp(1rem, 5vw, 1.5rem);
    }

    /* ---- Flow timeline: readable stacked pills ---- */
    .flowviz { margin-top: var(--sp-6); gap: 10px; }
    .flowviz__pill {
      gap: var(--sp-3);
      padding: 13px 16px;
      min-height: 52px;
      border-radius: 16px;
    }
    /* Fixed-width number so the step names line up in a column */
    .flowviz__num { flex: 0 0 auto; width: 1.6em; }
    .flowviz__k { font-size: 1rem; }
    /* Description drops under the name instead of cramming on one line */
    .flowviz__d {
      flex-basis: 100%;
      margin-left: 0;
      padding-left: calc(1.6em + var(--sp-3));
      margin-top: -2px;
      font-size: 0.8rem;
      line-height: 1.3;
    }
    .flowviz__pill { flex-wrap: wrap; }

    /* ---- Quick-stats: the hero + step promises already carry every one of
       these numbers (5 steps, 120+ pieces, 13+ platforms, human-gated), so
       the stat block is pure duplication on mobile. Hide it entirely. ---- */
    .herostats { display: none; }

    /* ---- Tighten section padding: with the viz cards gone the steps are
       compact copy blocks, so the airy desktop section rhythm is too loose. ---- */
    .step.section { padding-top: var(--sp-8); padding-bottom: var(--sp-8); }
    .why-sec.section { padding-top: var(--sp-8); padding-bottom: var(--sp-8); }

    /* ---- Step rows ---- */
    .step__row { gap: var(--sp-6); }
    .step__head { gap: var(--sp-2); }
    .step__n { font-size: 2.4rem; }
    .step__rule { max-width: 44px; }
    .step__name { margin-top: var(--sp-3); font-size: 1.9rem; }
    .step__body { max-width: none; }
    .step__cols { margin-top: var(--sp-4); gap: var(--sp-4); }
    .step__list { gap: var(--sp-3); }
    .step__outcome { padding: var(--sp-4); }

    /* ---- The per-step viz mocks are the main length tax on mobile: each
       browser-chrome card runs ~1.3 screens. Hide them on mobile; the step
       copy carries the meaning. (Desktop keeps them beside the text.) ---- */
    .step__visual { display: none; }

    /* ---- Condense the two-list format. Each step shows "What you get"
       (checklist) + "What you do" (dotted list) + an outcome — three list
       formats stacked. On mobile keep the concrete checklist and the bold
       outcome; drop the redundant "What you do" column. ---- */
    .step__col + .step__col { display: none; }

    /* ---- 04 Distribute: 6-col grid is too tight at 390px -> 4-col ---- */
    .viz .dis__tiles { grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .dis__out { font-size: 1.4rem; }

    /* ---- Why cards ---- */
    .why__head { margin-bottom: var(--sp-8); }
    .why__h { font-size: 1.9rem; }
    .why__grid { gap: var(--sp-5); }
    .whycard { padding: 1.5rem 1.35rem; }
  }

  /* ==================================================================
     MOBILE STEP ACCORDION (<= 760px)
     Each step's copy is a <details>; the summary is the tappable row
     (number badge + step title + chevron), tapping expands the promise,
     checklist, and outcome. Step 01 is open by default (open attr in markup;
     the script enforces single-open on mobile). Desktop (>=760px) below
     dissolves all of this with display:contents so the layout is unchanged.
  ================================================================== */
  @media (max-width: 760px) {
    /* Force the copy block visible regardless of data-reveal so collapsed
       rows never leave empty scroll bands waiting on the reveal observer. */
    .step__acc[data-reveal] {
      opacity: 1 !important;
      transform: none !important;
    }
    .step__acc { display: block; }

    .step__accsummary {
      display: flex;
      align-items: center;
      gap: clamp(0.5rem, 3vw, var(--sp-3));
      min-height: 48px;
      padding: clamp(0.75rem, 3.5vw, 1rem) 0;
      list-style: none;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      border-top: 1px solid var(--line);
    }
    .step__accsummary::-webkit-details-marker { display: none; }
    .step__accsummary::marker { content: ""; }
    .step__accsummary:focus-visible {
      outline: 2px solid var(--ac, var(--coral));
      outline-offset: 3px;
      border-radius: 8px;
    }
    /* ---- Neutralize the dark (Direct / .section--ink) row so the accordion
       reads as ONE uniform light list. On desktop this row is a full-bleed deep
       forest band alternating with the light steps; on mobile that dark band
       collides with the light rows above and below it, so here we strip the row
       back to the light-mode surface + colors and let its own accent (--ac,
       green) drive the number/tick exactly like every other row. ---- */
    .step.section--ink { background: transparent; }
    /* Ambient wash tints the row dark — quiet it so it matches the light rows. */
    .section--ink.step::before { opacity: 0.5; }
    /* Number: coral/green accent like the other rows, not gold. */
    .section--ink .step__n { color: var(--ac, var(--coral)); }
    /* Head + eyebrow reset (eyebrow is hidden on mobile, reset for safety). */
    .section--ink .step__of { color: var(--muted); }
    .section--ink .step__rule { background: var(--line-2); }
    /* Copy back to dark-on-light. */
    .section--ink .step__promise { color: var(--ink); }
    .section--ink .step__body { color: var(--ink-2); }
    .section--ink .step__item { color: var(--ink-2); }
    .section--ink .step__item--you { color: var(--muted); }
    .section--ink .step__coltag { color: var(--ac, var(--coral)); }
    .section--ink .step__coltag--muted { color: var(--muted); }
    .section--ink .step__dot { background: var(--line-2); }
    .section--ink .step__outlabel { color: var(--ac, var(--coral)); }
    /* Outcome callout: light accent-tinted panel, dark text (matches non-ink). */
    .section--ink .step__outcome {
      background: color-mix(in srgb, var(--ac, var(--coral)) 8%, var(--paper));
      border-color: color-mix(in srgb, var(--ac, var(--coral)) 22%, transparent);
      border-left-color: var(--ac, var(--coral));
      color: var(--ink);
    }
    /* Light hairline divider on the summary row (was white-on-dark). */
    .section--ink .step__accsummary { border-top-color: var(--line); }

    /* Compact the head: hide the rule + "STEP 0X OF 05" line, keep the number
       badge leading the row so it stays tight. */
    .step__accsummary .step__head {
      flex: none;
      display: flex;
      align-items: center;
      gap: 0;
    }
    .step__accsummary .step__rule,
    .step__accsummary .step__of { display: none; }
    .step__accsummary .step__n {
      font-size: clamp(1.25rem, 5.5vw, 1.5rem);
      line-height: 1;
    }

    .step__accname {
      flex: 1;
      display: flex;
      align-items: center;
      gap: clamp(0.5rem, 3vw, var(--sp-3));
      min-width: 0;
    }
    .step__accsummary .step__name {
      flex: 1;
      min-width: 0;
      margin-top: 0;
      font-size: clamp(1.2rem, 5.5vw, 1.4rem);
      line-height: 1.15;
      text-wrap: balance;
    }
    .step__accchev {
      flex: none;
      display: grid;
      place-items: center;
      width: clamp(30px, 8.5vw, 34px);
      height: clamp(30px, 8.5vw, 34px);
      border-radius: 50%;
      color: #fff;
      background: var(--ac, var(--coral));
      transition: transform var(--dur-base, 0.25s) var(--ease);
    }
    .step__acc[open] .step__accchev { transform: rotate(180deg); }

    /* Expanded content sits under the row; keep it tight, not the airy
       desktop rhythm. */
    .step__accbody { padding: var(--sp-3) 0 var(--sp-4); }
    .step__accbody .step__promise { margin-top: 0; }

    /* Close the hairline rhythm at the last step so the section border isn't
       doubled up. */
    .step__row { gap: 0; }
  }

  @media (min-width: 760px) {
    /* --- Desktop bypass: dissolve the accordion so the original stacked copy
       (head, name, promise, body, cols, outcome) renders exactly as before,
       always expanded and non-interactive. --- */
    .step__acc { display: block; }              /* stays the grid column */
    .step__accsummary,
    .step__accname,
    .step__accbody { display: contents; }       /* children flow as before */
    .step__accsummary { cursor: default; }
    .step__accchev { display: none; }
  }
</style>

<script>
  // Mobile accordion controller for the five step blocks.
  // - Desktop (>=760px): every <details> is forced open and stays open, so the
  //   CSS `display:contents` bypass renders the original stacked step layout.
  // - Mobile (<=760px): steps start collapsed except 01; opening one closes the
  //   others (single-open) and hash links (#step-03) open + scroll the target.
  (() => {
    const accs = Array.from(
      document.querySelectorAll<HTMLDetailsElement>(".step .step__acc"),
    );
    if (!accs.length) return;
    const desktop = window.matchMedia("(min-width: 760px)");

    const syncToViewport = () => {
      if (desktop.matches) {
        // Force-open on desktop; layout is driven entirely by CSS.
        accs.forEach((d) => {
          d.open = true;
        });
      } else {
        // Mobile: lead with step 01 open, collapse the rest.
        accs.forEach((d, i) => {
          d.open = i === 0;
        });
      }
    };

    // Single-open behaviour on mobile only.
    accs.forEach((d) => {
      d.addEventListener("toggle", () => {
        if (desktop.matches || !d.open) return;
        accs.forEach((o) => {
          if (o !== d) o.open = false;
        });
      });
    });

    // Open the targeted step when arriving via #step-0N (mobile only; desktop
    // is always open).
    const openFromHash = () => {
      const id = location.hash.replace("#", "");
      if (!id) return;
      const section = document.getElementById(id);
      const d = section && section.querySelector<HTMLDetailsElement>(".step__acc");
      if (d && !desktop.matches) {
        d.open = true;
        d.querySelector<HTMLElement>(".step__accsummary")?.scrollIntoView({
          block: "start",
          behavior: "smooth",
        });
      }
    };

    syncToViewport();
    if (desktop.addEventListener) {
      desktop.addEventListener("change", syncToViewport);
    } else {
      // Safari <14 fallback
      desktop.addListener(syncToViewport);
    }
    window.addEventListener("hashchange", openFromHash);
    openFromHash();
  })();
</script>
